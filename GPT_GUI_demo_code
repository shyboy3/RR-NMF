    def _validate_manual_selection_for_current_target(self, sel):
        """Validate that selected rr entries belong to the source depth for the active manual target."""
        if getattr(self,"chk_manual_depth",None) is not None and self.chk_manual_depth.isChecked():
            md=self._active_manual_target_depth()
