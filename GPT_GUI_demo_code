    def _edge_windows_for_analysis(self, edge_name):
        edge_e = float(EELS_EDGE_DB[edge_name]["energy_eV"])
        pre0, pre1 = self.spin_eels_pre0.value(), self.spin_eels_pre1.value()
        int0, int1 = self.spin_eels_int0.value(), self.spin_eels_int1.value()
        # If user did not enter a meaningful range, use edge-relative defaults.
        if pre1 <= pre0:
            pre0, pre1 = edge_e - 40.0, edge_e - 5.0
        if int1 <= int0:
            int0, int1 = edge_e, edge_e + 50.0
        return pre0, pre1, int0, int1

    def run_eels_analysis(self):
        srcs = self._selected_spectrum_sources(self.list_eels_src)
        if not srcs:
            QMessageBox.warning(self, "No spectrum", "Select one or more spectrum sources.")
            return

        groups = [i.text() for i in self.list_eels_groups.selectedItems()] or ["All"]
        elements = list(getattr(self, "eels_elements", []))
        selected_edge = self.combo_eels_edge.currentText() if hasattr(self, "combo_eels_edge") else None
        selected_edges = self._selected_eels_edges()
        display_mode = self.combo_eels_line_display.currentText() if hasattr(self, "combo_eels_line_display") else "Selected edge only"
        compare_mode = self.combo_eels_compare.currentText() if hasattr(self, "combo_eels_compare") else "Single spectrum"
        edge_mode = getattr(self, "combo_eels_mode", None) is not None and self.combo_eels_mode.currentText() == "Edge analysis"

        all_rows = []
        edge_area_by_source = {}
        plot_srcs = []
        matched_all = []
        detected_by_source = {}
        candidate_markers_global = []
        edge_windows_global = []

        for si, src in enumerate(srcs):
            spec = np.asarray(src["spectrum"], dtype=np.float64)
            x = energy_axis_as_eV(src["axis"], len(spec))
            source_label = src.get("label", f"source {si+1}")
            features = detect_simple_peaks(x, spec, self.spin_eels_prom.value(), self.spin_eels_dist.value())
            hits = match_eels_edges_to_features(features, self.spin_eels_tol.value(), groups, elements)
            for row in hits:
                rr = dict(row); rr["source"] = source_label; rr["row_type"] = "matched_feature"; all_rows.append(rr)

            xmin = float(np.nanmin(x)) if x.size else 0.0
            xmax = float(np.nanmax(x)) if x.size else 0.0
            candidate_markers = []
            # Multi-edge overlay takes priority in Edge analysis mode or when user selected multiple edges.
            if selected_edges:
                for ed in selected_edges:
                    ev = float(EELS_EDGE_DB[ed]["energy_eV"])
                    if xmin <= ev <= xmax:
                        candidate_markers.append((ev, ed))
            else:
                candidate_markers = build_eels_candidate_markers(
                    groups, elements, xmin, xmax,
                    selected_edge=selected_edge,
                    display_mode=("Selected edge only" if display_mode == "Nearby selected edge ± range" else display_mode),
                )

            if display_mode == "Nearby selected edge ± range" and selected_edge in EELS_EDGE_DB:
                center = float(EELS_EDGE_DB[selected_edge]["energy_eV"])
                rng = float(self.spin_eels_nearby.value()) if hasattr(self, "spin_eels_nearby") else 50.0
                candidate_markers = build_eels_candidate_markers(groups, elements, center-rng, center+rng, selected_edge=None, display_mode="Selected elements/groups")
                candidate_markers = [(e, lab) for e, lab in candidate_markers if abs(float(e)-center) <= rng]
                candidate_markers.insert(0, (center, selected_edge))

            candidate_markers_global.extend(candidate_markers)
            matched_markers = []
            if display_mode in ["Matched edges only", "Selected elements/groups", "All candidate edges in current energy range", "Nearby selected edge ± range"]:
                matched_markers = [(float(r["edge_eV"]), str(r["edge"])) for r in hits]
            matched_all.extend(matched_markers)
            detected_by_source[si] = [float(ft["energy"]) for ft in features]

            # Multi-edge / node-wise edge analysis table.
            if edge_mode and selected_edges:
                edge_area_by_source[source_label] = {}
                for ed in selected_edges:
                    pre0, pre1, int0, int1 = self._edge_windows_for_analysis(ed)
                    edge_windows_global.append({"edge": ed, "edge_eV": float(EELS_EDGE_DB[ed]["energy_eV"]), "pre0": pre0, "pre1": pre1, "int0": int0, "int1": int1})
                    analysis_row = eels_edge_analysis_for_spectrum(x, spec, ed, pre0, pre1, int0, int1)
                    analysis_row["source"] = source_label
                    analysis_row["row_type"] = "edge_analysis"
                    all_rows.append(analysis_row)
                    edge_area_by_source[source_label][ed] = float(analysis_row.get("area_bg_subtracted", np.nan))
                # Edge ratio panel rows: pairwise ratios for selected edges.
                if len(selected_edges) >= 2:
                    for i in range(len(selected_edges)):
                        for j in range(i+1, len(selected_edges)):
                            a, b = selected_edges[i], selected_edges[j]
                            av = edge_area_by_source[source_label].get(a, np.nan)
                            bv = edge_area_by_source[source_label].get(b, np.nan)
                            ratio = av / bv if np.isfinite(av) and np.isfinite(bv) and abs(bv) > 1e-30 else np.nan
                            all_rows.append({
                                "row_type": "edge_ratio",
                                "source": source_label,
                                "ratio": f"{a}/{b}",
                                "numerator_edge": a,
                                "denominator_edge": b,
                                "numerator_area": av,
                                "denominator_area": bv,
                                "edge_area_ratio": ratio,
                            })
            elif edge_mode and selected_edge:
                pre0, pre1, int0, int1 = self._edge_windows_for_analysis(selected_edge)
                edge_windows_global.append({"edge": selected_edge, "edge_eV": float(EELS_EDGE_DB[selected_edge]["energy_eV"]), "pre0": pre0, "pre1": pre1, "int0": int0, "int1": int1})
                analysis_row = eels_edge_analysis_for_spectrum(x, spec, selected_edge, pre0, pre1, int0, int1)
                analysis_row["source"] = source_label
                analysis_row["row_type"] = "edge_analysis"
                all_rows.insert(0, analysis_row)
                if display_mode == "Selected edge only":
                    candidate_markers = [(float(EELS_EDGE_DB[selected_edge]["energy_eV"]), selected_edge)]

            ss = dict(src); ss["energy"] = x; plot_srcs.append(ss)

        def dedup(seq):
            out=[]; seen=set()
            for xv, lab in seq:
                key=(round(float(xv), 6), str(lab))
                if key not in seen:
                    seen.add(key); out.append((float(xv), str(lab)))
            return out
        candidate_markers_global = dedup(candidate_markers_global)
        matched_all = dedup(matched_all)
        # Deduplicate selected edge-analysis windows.
        _wins = []
        _seen_wins = set()
        for win in edge_windows_global:
            key = (win.get("edge"), round(float(win.get("pre0", 0)), 6), round(float(win.get("pre1", 0)), 6), round(float(win.get("int0", 0)), 6), round(float(win.get("int1", 0)), 6))
            if key not in _seen_wins:
                _seen_wins.add(key); _wins.append(win)
        edge_windows_global = _wins
        show_detected = bool(getattr(self, "chk_eels_show_detected", None) is not None and self.chk_eels_show_detected.isChecked())

        if len(plot_srcs) > 1 or compare_mode == "Selected sources stacked":
            plot_multi_source_interpretation(
                self.canvas_eels.fig, plot_srcs, candidate_markers_global, matched_all,
                f"EELS Interpretation: {len(plot_srcs)} selected sources", "Energy (eV)",
                self.combo_eels_norm.currentText(), self.combo_cmap.currentText(), detected_by_source,
                edge_windows=edge_windows_global, show_detected=show_detected,
            )
        elif compare_mode == "Basis vs weighted raw stacked" and srcs[0].get("pair_key") is not None:
            src = srcs[0]
            basis = self.find_paired_source(src, "basis")
            weighted = self.find_paired_source(src, "weighted")
            if basis is not None and weighted is not None:
                x = energy_axis_as_eV(basis["axis"], len(basis["spectrum"]))
                plot_stacked_basis_weighted(
                    self.canvas_eels.fig, x,
                    np.asarray(basis["spectrum"], dtype=np.float64),
                    np.asarray(weighted["spectrum"], dtype=np.float64),
                    basis["label"], weighted["label"],
                    candidate_markers_global, matched_all, "Energy (eV)",
                    norm=self.combo_eels_norm.currentText(),
                    source_image=src.get("image", None),
                    cmap=self.combo_cmap.currentText(),
                    detected_features=detected_by_source.get(0, []),
                    edge_windows=edge_windows_global,
                    show_detected=show_detected,
                )
            else:
                plot_multi_source_interpretation(self.canvas_eels.fig, plot_srcs, candidate_markers_global, matched_all, "EELS Interpretation", "Energy (eV)", self.combo_eels_norm.currentText(), self.combo_cmap.currentText(), detected_by_source, edge_windows=edge_windows_global, show_detected=show_detected)
        else:
            src = srcs[0]
            spec = np.asarray(src["spectrum"], dtype=np.float64)
            x = energy_axis_as_eV(src["axis"], len(spec))
            plot_interpretation(
                self.canvas_eels.fig, x, spec, candidate_markers_global,
                "EELS Interpretation: " + src["label"], "Energy (eV)",
                self.combo_eels_norm.currentText(),
                source_image=src.get("image", None),
                cmap=self.combo_cmap.currentText(),
                matched_markers=matched_all,
                detected_features=detected_by_source.get(0, []),
                edge_windows=edge_windows_global,
                show_detected=show_detected,
            )

        self.canvas_eels.set_base(); self.canvas_eels.draw()
        self.eels_hits = all_rows
        df = pd.DataFrame(all_rows)
        if not df.empty:
            # Keep the most useful columns toward the front without dropping anything.
            front = [c for c in ["row_type", "source", "edge", "ratio", "element", "edge_eV", "area_bg_subtracted", "edge_area_ratio", "onset_5pct_eV", "fit_r", "status"] if c in df.columns]
            df = df[front + [c for c in df.columns if c not in front]]
        self.dataframe_to_table(df, self.table_eels)

