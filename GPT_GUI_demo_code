def fro_energy(A):
    A = np.asarray(A)
    return float(np.sum(A*A, dtype=np.float64))


def nonnegative(X, mode="clip"):
    X = np.asarray(X, dtype=np.float32)
    if mode == "abs":
        return np.abs(X)
    if mode == "shift":
        mn = float(np.nanmin(X))
        return X - mn if mn < 0 else X
    if mode == "none":
        return X
    return np.clip(X, 0, None)


def normalize_spectra(X, mode="none", eps=1e-12):
    X = np.asarray(X, dtype=np.float32)
    if mode == "global_max":
        return X / (float(np.nanmax(X)) + eps)
    if mode == "max":
        return X / (np.nanmax(X, axis=1, keepdims=True) + eps)
    if mode == "area":
        return X / (np.nansum(X, axis=1, keepdims=True) + eps)
    return X


def normalize_1d(y, mode="none"):
    y = np.asarray(y, dtype=np.float64)
    if mode == "max":
        m = float(np.nanmax(np.abs(y))) if y.size else 0
        return y/m if m > 0 else y
    if mode == "area":
        s = float(np.nansum(np.abs(y))) if y.size else 0
        return y/s if s > 0 else y
    return y


def component_energy_no_outer(w, h):
    return float(np.sum(w*w, dtype=np.float64) * np.sum(h*h, dtype=np.float64))


def compute_residual_summary(X, W, H, image_shape, chunk_size=2048):
    N, L = X.shape
    ih, iw = image_shape
    img = np.zeros(N, dtype=np.float64)
    spec = np.zeros(L, dtype=np.float64)
    eng = 0.0
    H32 = H.astype(np.float32, copy=False)
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        R = X[st:en].astype(np.float32, copy=False) - W[st:en].astype(np.float32, copy=False) @ H32
        img[st:en] = np.sum(R, axis=1)
        spec += np.sum(R, axis=0)
        eng += float(np.sum(R*R, dtype=np.float64))
    return img.reshape(ih, iw), spec, eng


def make_child_matrix_chunked(X, W, H, comp_i, rank, residual_mode, residual_nonnegative, chunk_size=2048):
    N, L = X.shape
    out = np.empty((N, L), dtype=np.float32)
    H32 = H.astype(np.float32, copy=False)
    hi = H32[comp_i]
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        Xc = X[st:en].astype(np.float32, copy=False)
        Wc = W[st:en].astype(np.float32, copy=False)
        S = np.outer(Wc[:, comp_i], hi)
        if residual_mode == "redistribute_equal":
            S = S + (Xc - Wc @ H32) / float(rank)
        out[st:en] = nonnegative(S, residual_nonnegative)
    return out


def make_residual_branch_chunked(X, W, H, residual_nonnegative, chunk_size=2048):
    N, L = X.shape
    out = np.empty((N, L), dtype=np.float32)
    H32 = H.astype(np.float32, copy=False)
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        R = X[st:en].astype(np.float32, copy=False) - W[st:en].astype(np.float32, copy=False) @ H32
        out[st:en] = nonnegative(R, residual_nonnegative)
    return out


def make_default_axis_info(shape):
    return AxisInfo(energy_axis=np.arange(shape[2], dtype=np.float32))


def estimate_cube_from_array(arr):
    arr = np.asarray(arr)
    if arr.ndim == 3:
        return arr.astype(np.float32), arr.shape
    if arr.ndim == 2:
        N, L = arr.shape
        return arr.reshape(N, 1, L).astype(np.float32), (N, 1, L)
    raise ValueError("Expected 2D or 3D array")


def try_extract_axis_info_from_signal(sig, shape):
    ai = make_default_axis_info(shape)
    try:
        axes = list(sig.axes_manager._axes)
        sizes = [int(getattr(a, "size", 1)) for a in axes]
        si = int(np.argmax(sizes)) if max(sizes) >= 128 else len(axes)-1
        ax = axes[si]
        L = shape[2]
        scale = float(getattr(ax, "scale", 1.0))
        off = float(getattr(ax, "offset", 0.0))
        unit = str(getattr(ax, "units", "channel")) or "channel"
        ai.energy_axis = np.arange(L, dtype=np.float32) * scale + off
        ai.energy_unit = unit
        ai.energy_label = f"Energy ({unit})" if unit != "channel" else "Channel"
    except Exception:
        pass
    return ai


def load_hyperspectral_file(path):
    ext = os.path.splitext(path)[1].lower()
    meta = {"path": path, "extension": ext}
    if ext == ".npy":
        cube, shape = estimate_cube_from_array(np.load(path))
        return cube, {**meta, "loader": "numpy", "shape": shape}, make_default_axis_info(cube.shape)
    if ext == ".npz":
        z = np.load(path)
        key = list(z.keys())[0]
        cube, shape = estimate_cube_from_array(z[key])
        return cube, {**meta, "loader": "npz", "key": key, "shape": shape}, make_default_axis_info(cube.shape)
    try:
        import hyperspy.api as hs
    except Exception as e:
        raise RuntimeError(f"Install hyperspy/exspy/rosettasciio for this format: {e}")
    sigs = hs.load(path, lazy=False)
    sigs = sigs if isinstance(sigs, list) else [sigs]
    for idx, sig in enumerate(sigs):
        data = np.asarray(sig.data)
        if data.ndim == 3:
            spec_axis = int(np.argmax(data.shape)) if max(data.shape) >= 128 else 2
            cube = np.moveaxis(data, spec_axis, -1).astype(np.float32)
            return cube, {**meta, "loader": "hyperspy", "signal_index": idx}, try_extract_axis_info_from_signal(sig, cube.shape)
    for idx, sig in enumerate(sigs):
        data = np.asarray(sig.data)
        if data.ndim == 2:
            cube, _ = estimate_cube_from_array(data)
            return cube, {**meta, "loader": "hyperspy", "signal_index": idx}, make_default_axis_info(cube.shape)
    raise ValueError("No 2D/3D spectral dataset found")


def nearest_channel_from_energy(energy_axis, value):
    e = np.asarray(energy_axis, dtype=np.float64)
    return 0 if e.size == 0 else int(np.argmin(np.abs(e - float(value))))


def safe_powerlaw_energy_axis(e):
    e = np.asarray(e, dtype=np.float64).copy()
    if e.size == 0:
        return e
    if not np.any(np.isfinite(e)):
        return np.arange(len(e), dtype=np.float64) + 1
    mn = float(np.nanmin(e[np.isfinite(e)]))
    if mn <= 0:
        e = e - mn + 1e-6
    e[e <= 0] = 1e-6
    return e


def fit_powerlaw_exponent_from_roi(cube, axis_info, spatial_roi, channel_roi):
    y0, y1, x0, x1 = spatial_roi
    l0, l1 = channel_roi
    sub = cube[y0:y1, x0:x1, l0:l1].astype(np.float64, copy=False)
    if sub.size == 0:
        raise ValueError("Background ROI is empty")
    spec = np.nanmean(sub.reshape(-1, sub.shape[-1]), axis=0)
    e = safe_powerlaw_energy_axis(axis_info.energy_axis)[l0:l1]
    if len(e) != len(spec):
        e = np.arange(len(spec), dtype=np.float64) + 1
    m = np.isfinite(e) & np.isfinite(spec) & (e > 0) & (spec > 0)
    if np.count_nonzero(m) < 3:
        raise ValueError("Not enough positive points for power-law fit")
    slope, inter = np.polyfit(np.log(e[m]), np.log(spec[m]), 1)
    r = -float(slope)
    A = float(np.exp(inter))
    fit = A * e[m] ** (-r)
    return {"A_mean": A, "r": r, "rmse": float(np.sqrt(np.mean((spec[m] - fit) ** 2))), "n_points": int(np.count_nonzero(m))}


def apply_powerlaw_background_correction(cube, axis_info, fit_channel_roi, exponent_r, clip_negative=True, chunk_pixels=8192):
    h, w, L = cube.shape
    l0, l1 = fit_channel_roi
    e = safe_powerlaw_energy_axis(axis_info.energy_axis)
    if len(e) != L:
        e = np.arange(L, dtype=np.float64) + 1
    basis = (np.maximum(e, 1e-6) ** (-float(exponent_r))).astype(np.float32)
    amp_basis = (np.maximum(e[l0:l1], 1e-6) ** float(exponent_r)).astype(np.float32)
    X = cube.reshape(h*w, L).astype(np.float32, copy=False)
    out = np.empty_like(X)
    for st in range(0, X.shape[0], chunk_pixels):
        en = min(st+chunk_pixels, X.shape[0])
        Xc = X[st:en]
        A = np.nanmean(Xc[:, l0:l1] * amp_basis.reshape(1, -1), axis=1).astype(np.float32)
        corr = Xc - A.reshape(-1, 1) * basis.reshape(1, -1)
        out[st:en] = np.clip(corr, 0, None) if clip_negative else corr
    return out.reshape(h, w, L)


def energy_axis_as_keV(axis_info, L):
    e = np.asarray(axis_info.energy_axis, dtype=np.float64)
    if len(e) != L:
        return np.arange(L, dtype=np.float64)
    label = (axis_info.energy_label + " " + axis_info.energy_unit).lower()
    if "kev" in label:
        return e
    if "ev" in label or np.nanmax(e) > 200:
        return e / 1000.0
    return e


def energy_axis_as_eV(axis_info, L):
    e = np.asarray(axis_info.energy_axis, dtype=np.float64)
    if len(e) != L:
        return np.arange(L, dtype=np.float64)
    label = (axis_info.energy_label + " " + axis_info.energy_unit).lower()
    if "kev" in label:
        return e * 1000.0
    return e


def detect_simple_peaks(x, y, min_prom_rel=0.03, min_distance_channels=3):
    x = np.asarray(x, dtype=np.float64)
    y = np.nan_to_num(np.asarray(y, dtype=np.float64), nan=0, posinf=0, neginf=0)
    if y.size < 3:
        return []
    ymax, ymin = float(np.nanmax(y)), float(np.nanmin(y))
    thr = ymin + max(0, float(min_prom_rel)) * max(1e-12, ymax-ymin)
    out, last = [], -10**9
    for i in range(1, len(y)-1):
        if y[i] >= thr and y[i] >= y[i-1] and y[i] >= y[i+1]:
            if i-last < int(min_distance_channels):
                if out and y[i] > out[-1]["intensity"]:
                    out[-1] = {"index": int(i), "energy": float(x[i]), "intensity": float(y[i])}
                    last = i
            else:
                out.append({"index": int(i), "energy": float(x[i]), "intensity": float(y[i])})
                last = i
    out.sort(key=lambda r: r["intensity"], reverse=True)
    return out




def weighted_raw_spectrum_by_map(X_raw: np.ndarray, w_map: np.ndarray, eps: float = 1e-12) -> np.ndarray:
    """Extract an actual-data spectrum from X_raw using a component W-map as spatial weights."""
    X = np.asarray(X_raw, dtype=np.float64)
    w = np.asarray(w_map, dtype=np.float64).reshape(-1)
    if X.ndim != 2:
        X = X.reshape(-1, X.shape[-1])
    w = np.nan_to_num(w, nan=0.0, posinf=0.0, neginf=0.0)
    w = np.clip(w, 0, None)
    denom = float(np.sum(w))
    if denom <= eps:
        return np.nanmean(X, axis=0)
    return (w.reshape(1, -1) @ X).reshape(-1) / denom



def normalize_for_shape_compare(y: np.ndarray, mode: str = "max", eps: float = 1e-12) -> np.ndarray:
    """Normalize a 1D spectrum only for visual shape comparison."""
    y = np.asarray(y, dtype=np.float64)
    if mode == "area":
        s = float(np.nansum(np.abs(y)))
        return y / (s + eps) if s > 0 else y
    if mode == "none":
        return y
    m = float(np.nanmax(np.abs(y))) if y.size else 0.0
    return y / (m + eps) if m > 0 else y




def safe_shape_correlation(a: np.ndarray, b: np.ndarray, norm_mode: str = "max") -> float:
    """Correlation after visual/shape normalization; original spectra remain unscaled for plotting."""
    aa = normalize_for_shape_compare(np.asarray(a, dtype=np.float64), norm_mode)
    bb = normalize_for_shape_compare(np.asarray(b, dtype=np.float64), norm_mode)
    m = np.isfinite(aa) & np.isfinite(bb)
    if np.count_nonzero(m) < 3:
        return np.nan
    aa = aa[m] - np.nanmean(aa[m])
    bb = bb[m] - np.nanmean(bb[m])
    den = float(np.sqrt(np.nansum(aa * aa) * np.nansum(bb * bb)))
    return float(np.nansum(aa * bb) / den) if den > 0 else np.nan

def roi_mean_std_spectrum(cube: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
    X = np.asarray(cube, dtype=np.float64).reshape(-1, cube.shape[-1])
    return np.nanmean(X, axis=0), np.nanstd(X, axis=0)

def get_source_pair_label(label: str) -> Optional[str]:
    """Return the paired NMF-basis or W-weighted source label."""
    import re
    m = re.match(r"rr D(\d+) N(\d+) H(\d+) \(NMF basis\)", label)
    if m:
        d, n, c = m.groups()
        return f"rr D{d} N{n} weighted raw by W{c}"
    m = re.match(r"rr D(\d+) N(\d+) weighted raw by W(\d+)", label)
    if m:
        d, n, c = m.groups()
        return f"rr D{d} N{n} H{c} (NMF basis)"
    m = re.match(r"Conv H(\d+) \(NMF basis\)", label)
    if m:
        c = m.group(1)
        return f"Conv weighted raw by W{c}"
    m = re.match(r"Conv weighted raw by W(\d+)", label)
    if m:
        c = m.group(1)
        return f"Conv H{c} (NMF basis)"
    return None


def apply_reference_bg_low_energy_scaling(
    cube: np.ndarray,
    axis_info: AxisInfo,
    spatial_roi: Tuple[int, int, int, int],
    fit_channel_roi: Tuple[int, int],
    scale_channel_roi: Tuple[int, int],
    after_mode: str = "shift_min",
    chunk_pixels: int = 8192,
    eps: float = 1e-12,
) -> Tuple[np.ndarray, Dict[str, float]]:
    """
    Fitted reference BG subtraction:
        1. Fit a global reference background curve from selected spatial ROI and fitting channel range:
             BG_ref(E) = A_ref * E^(-r_ref)
        2. For each pixel, compute alpha_p from low-energy reference channels:
             alpha_p = mean(X_p[scale_start:scale_end]) / mean(BG_ref[scale_start:scale_end])
        3. Subtract:
             Xcorr_p(E) = X_p(E) - alpha_p * BG_ref(E)

    This matches the user's older workflow more closely than using the raw ROI mean spectrum as BG_ref.
    """
    h, w, L = cube.shape
    y0, y1, x0, x1 = spatial_roi
    f0, f1 = fit_channel_roi
    s0, s1 = scale_channel_roi

    f0 = max(0, min(int(f0), L - 1))
    f1 = max(f0 + 1, min(int(f1), L))
    s0 = max(0, min(int(s0), L - 1))
    s1 = max(s0 + 1, min(int(s1), L))

    # Fit global reference BG curve from selected spatial ROI + fit range.
    fit_info = fit_powerlaw_exponent_from_roi(
        cube,
        axis_info,
        spatial_roi=(y0, y1, x0, x1),
        channel_roi=(f0, f1),
    )
    r_ref = float(fit_info["r"])
    A_ref = float(fit_info["A_mean"])

    e = safe_powerlaw_energy_axis(axis_info.energy_axis)
    if len(e) != L:
        e = np.arange(L, dtype=np.float64) + 1.0
    e = np.maximum(e, 1e-6)
    bg_ref = A_ref * np.power(e, -r_ref)
    bg_scale = float(np.nanmean(bg_ref[s0:s1]))
    if not np.isfinite(bg_scale) or abs(bg_scale) <= eps:
        raise ValueError("Fitted reference BG scale window is zero or invalid.")

    X = cube.reshape(h * w, L).astype(np.float32, copy=False)
    out = np.empty_like(X, dtype=np.float32)
    alpha_min, alpha_max, alpha_sum, n_alpha = np.inf, -np.inf, 0.0, 0
    bg32 = bg_ref.astype(np.float32)

    for st in range(0, X.shape[0], int(chunk_pixels)):
        en = min(st + int(chunk_pixels), X.shape[0])
        Xc = X[st:en].astype(np.float32, copy=False)
        pix_scale = np.nanmean(Xc[:, s0:s1], axis=1).astype(np.float32)
        alpha = (pix_scale / np.float32(bg_scale)).astype(np.float32)
        alpha = np.nan_to_num(alpha, nan=0.0, posinf=0.0, neginf=0.0)

        corr = Xc - alpha.reshape(-1, 1) * bg32.reshape(1, -1)
        if after_mode == "shift_min":
            mn = np.nanmin(corr, axis=1, keepdims=True)
            corr = corr - mn
        elif after_mode == "clip":
            corr = np.clip(corr, 0, None)
        out[st:en] = corr.astype(np.float32)

        if alpha.size:
            alpha_min = min(alpha_min, float(np.nanmin(alpha)))
            alpha_max = max(alpha_max, float(np.nanmax(alpha)))
            alpha_sum += float(np.nansum(alpha))
            n_alpha += int(alpha.size)

    meta = {
        "A_ref": A_ref,
        "r_ref": r_ref,
        "fit_rmse": float(fit_info.get("rmse", np.nan)),
        "fit_start": float(f0),
        "fit_end": float(f1),
        "bg_scale": bg_scale,
        "scale_start": float(s0),
        "scale_end": float(s1),
        "alpha_min": float(alpha_min if np.isfinite(alpha_min) else 0.0),
        "alpha_mean": float(alpha_sum / max(1, n_alpha)),
        "alpha_max": float(alpha_max if np.isfinite(alpha_max) else 0.0),
    }
    return out.reshape(h, w, L), meta


def build_eels_candidate_markers(
    groups: Optional[List[str]],
    elements: Optional[List[str]],
    energy_min: float,
    energy_max: float,
    selected_edge: Optional[str] = None,
    display_mode: str = "Selected elements/groups",
) -> List[Tuple[float, str]]:
    group_set = set(groups or [])
    element_set = set(elements or [])
    markers: List[Tuple[float, str]] = []

    if display_mode == "Matched edges only":
        return markers

    for name, row in EELS_EDGE_DB.items():
        e = float(row["energy_eV"])
        if e < energy_min or e > energy_max:
            continue
        if display_mode == "Selected edge only":
            if selected_edge and name == selected_edge:
                markers.append((e, name))
            continue

        row_groups = set(row.get("groups", []))
        if group_set and "All" not in group_set and not (group_set & row_groups):
            continue
        if element_set and row.get("element") not in element_set:
            continue
        markers.append((e, name))
    return sorted(markers, key=lambda x: x[0])


def eels_edge_analysis_for_spectrum(
    energy_eV: np.ndarray,
    spectrum: np.ndarray,
    edge_name: str,
    pre_start: float,
    pre_end: float,
    int_start: float,
    int_end: float,
) -> Dict[str, Any]:
    """Edge-specific pre-edge power-law fit and post-edge integration for one spectrum."""
    x = np.asarray(energy_eV, dtype=np.float64)
    y = np.asarray(spectrum, dtype=np.float64)
    row = EELS_EDGE_DB.get(edge_name, {})
    pre_mask = np.isfinite(x) & np.isfinite(y) & (x >= pre_start) & (x <= pre_end) & (x > 0) & (y > 0)
    if np.count_nonzero(pre_mask) < 3:
        return {
            "edge": edge_name, "element": row.get("element", ""), "edge_eV": row.get("energy_eV", np.nan),
            "status": "not enough positive pre-edge points",
        }

    slope, intercept = np.polyfit(np.log(x[pre_mask]), np.log(y[pre_mask]), 1)
    r = -float(slope)
    A = float(np.exp(intercept))
    bg = A * np.power(np.maximum(x, 1e-9), -r)
    sub = y - bg

    int_mask = np.isfinite(x) & np.isfinite(sub) & (x >= int_start) & (x <= int_end)
    area = float(np.trapz(np.clip(sub[int_mask], 0, None), x[int_mask])) if np.count_nonzero(int_mask) >= 2 else np.nan

    post_mask = np.isfinite(x) & np.isfinite(sub) & (x >= int_start)
    onset = np.nan
    if np.count_nonzero(post_mask) >= 2:
        yp = np.clip(sub[post_mask], 0, None)
        xp = x[post_mask]
        if yp.size and np.nanmax(yp) > 0:
            thr = 0.05 * float(np.nanmax(yp))
            idx = np.where(yp >= thr)[0]
            if idx.size:
                onset = float(xp[int(idx[0])])

    return {
        "edge": edge_name,
        "element": row.get("element", ""),
        "edge_type": row.get("edge", ""),
        "edge_eV": float(row.get("energy_eV", np.nan)),
        "pre_start_eV": float(pre_start),
        "pre_end_eV": float(pre_end),
        "integration_start_eV": float(int_start),
        "integration_end_eV": float(int_end),
        "fit_A": A,
        "fit_r": r,
        "area_bg_subtracted": area,
        "onset_5pct_eV": onset,
        "status": "ok",
    }


def _difference_penalty_matrix(n: int, order: int = 2) -> np.ndarray:
    """Return D.T @ D for 1st- or 2nd-order finite differences over spectrum channels."""
    if n <= 2:
        return np.eye(n, dtype=np.float64)
    if order == 1:
        D = np.zeros((n - 1, n), dtype=np.float64)
        for i in range(n - 1):
            D[i, i] = -1.0
            D[i, i + 1] = 1.0
    else:
        D = np.zeros((n - 2, n), dtype=np.float64)
        for i in range(n - 2):
            D[i, i] = 1.0
            D[i, i + 1] = -2.0
            D[i, i + 2] = 1.0
    return D.T @ D


def smooth_refit_h_with_fixed_w(
    X_raw: np.ndarray,
    W_maps: List[np.ndarray],
    lam: float = 1e-2,
    order: int = 2,
    eps: float = 1e-8,
) -> np.ndarray:
    """
    Refit H with W fixed:
        min_H ||X - W H||_F^2 + lam ||D H||_F^2, then clip H >= 0.
    This is an interpretation-only spectrum; it does not change the rr-NMF tree.
    """
    X = np.asarray(X_raw, dtype=np.float64)
    if X.ndim != 2:
        X = X.reshape(-1, X.shape[-1])
    W = np.stack([np.asarray(m, dtype=np.float64).reshape(-1) for m in W_maps], axis=1)
    W = np.nan_to_num(W, nan=0.0, posinf=0.0, neginf=0.0)
    W = np.clip(W, 0, None)
    k = W.shape[1]
    L = X.shape[1]
    A = W.T @ W + eps * np.eye(k, dtype=np.float64)
    C = W.T @ X
    lam = float(max(0.0, lam))
    if lam <= 0:
        H = np.linalg.solve(A, C)
        return np.clip(H, 0, None).astype(np.float32)

    B = lam * _difference_penalty_matrix(L, order=order)
    try:
        from scipy.linalg import solve_sylvester
        H = solve_sylvester(A, B, C)
    except Exception:
        # Fallback: no spectral coupling, but still W-fixed NNLS-like least squares.
        H = np.linalg.solve(A, C)
    return np.clip(H, 0, None).astype(np.float32)


def match_eds_lines_to_peaks(peaks, selected_elements, tolerance_keV=0.05, line_filter="Major + minor"):
    hits = []
    include_minor = line_filter != "Major only"
    for pk in peaks:
        pe = float(pk["energy"])
        for el in selected_elements:
            for row in EDS_XRAY_LINE_DB.get(el, []):
                if row["type"] == "minor" and not include_minor:
                    continue
                d = pe - float(row["energy_keV"])
                if abs(d) <= float(tolerance_keV):
                    hits.append({"peak_keV": pe, "peak_intensity": float(pk["intensity"]), "element": el, "line": row["line"], "line_type": row["type"], "line_keV": row["energy_keV"], "delta_keV": d})
    return sorted(hits, key=lambda r: (r["peak_keV"], abs(r["delta_keV"])))


def match_eels_edges_to_features(features, tolerance_eV=5.0, groups=None, elements=None):
    group_set = set(groups or [])
    element_set = set(elements or [])
    names = []
    for name, row in EELS_EDGE_DB.items():
        row_groups = set(row.get("groups", []))
        if group_set and "All" not in group_set and not (group_set & row_groups):
            continue
        if element_set and row.get("element") not in element_set:
            continue
        names.append(name)

    hits = []
    for ft in features:
        fe = float(ft["energy"])
        for name in names:
            row = EELS_EDGE_DB[name]
            d = fe - float(row["energy_eV"])
            if abs(d) <= float(tolerance_eV):
                hits.append({
                    "feature_eV": fe,
                    "feature_intensity": float(ft["intensity"]),
                    "edge": name,
                    "element": row.get("element", ""),
                    "edge_type": row.get("edge", ""),
                    "edge_eV": float(row["energy_eV"]),
                    "delta_eV": d,
                    "groups": ", ".join(row.get("groups", [])),
                })
    return sorted(hits, key=lambda r: (r["feature_eV"], abs(r["delta_eV"])))


def run_conventional_nmf(X, image_shape, n_components=20, max_iter=300, init="random", solver="mu", random_state=0, chunk_size=4096):
    X = nonnegative(X, "clip").astype(np.float32)
    ih, iw = image_shape
    E = fro_energy(X)
    model = NMF(n_components=n_components, init=init, solver=solver, max_iter=max_iter, random_state=random_state)
    W = model.fit_transform(X)
    H = model.components_
    rimg, rspec, R = compute_residual_summary(X, W, H, image_shape, chunk_size)
    recs, Wimgs, Hspecs = [], [], []
    for i in range(n_components):
        Wi, Hi = W[:, i], H[i]
        ei = component_energy_no_outer(Wi, Hi)
        Wimgs.append(Wi.reshape(ih, iw))
        Hspecs.append(Hi.copy())
        recs.append({"method": "conventional_nmf", "depth": 0, "node_id": 0, "component_id": i, "type": "component", "energy": ei, "node_energy": E, "global_energy": E, "node_ratio": ei/E if E > 0 else np.nan, "global_ratio": ei/E if E > 0 else np.nan})
    recs.append({"method": "conventional_nmf", "depth": 0, "node_id": 0, "component_id": "R", "type": "residual", "energy": R, "node_energy": E, "global_energy": E, "node_ratio": R/E if E > 0 else np.nan, "global_ratio": R/E if E > 0 else np.nan})
    corrH = np.corrcoef(H) if H.shape[0] > 1 else np.ones((1,1))
    corrW = np.corrcoef(W.T) if W.shape[1] > 1 else np.ones((1,1))
    return ConventionalNMFResult(W, H, Wimgs, Hspecs, rimg, rspec, pd.DataFrame(recs), corrH, corrW)


def run_rr_nmf(X, image_shape, rank=2, max_depth=3, residual_mode="redistribute_equal", residual_nonnegative="clip", decompose_residual_branch=False, max_iter=300, init="random", solver="mu", random_state=0, chunk_size=2048, manual_groups=None):
    X = nonnegative(X, "clip").astype(np.float32)
    ih, iw = image_shape
    GE = fro_energy(X)
    erecs, nrecs, summaries = [], [], []
    nodes = [{"X": X, "node_id": 0, "parent_id": -1, "path": "root", "node_type": "root"}]
    nid = 1
    manual_groups = manual_groups or {}
    prepared_manual_groups = {}
    for md, groups in manual_groups.items():
        try:
            md_int = int(md)
        except Exception:
            continue
        prepared = []
        for gi, g in enumerate(groups or []):
            Xg = g.get("X", g.get("matrix", None)) if isinstance(g, dict) else g
            if Xg is None:
                continue
            Xg = nonnegative(np.asarray(Xg, dtype=np.float32), residual_nonnegative)
            if Xg.ndim != 2 or Xg.shape != X.shape:
                continue
            name = g.get("name", f"manual_group_{gi+1}") if isinstance(g, dict) else f"manual_group_{gi+1}"
            members = g.get("members", []) if isinstance(g, dict) else []
            prepared.append({"X": Xg, "name": name, "members": members})
        if prepared:
            prepared_manual_groups[md_int] = prepared
    for d in range(max_depth+1):
        slist, nxt = [], []
        for li, node in enumerate(nodes):
            Xd = nonnegative(node["X"], "clip").astype(np.float32)
            NE = fro_energy(Xd)
            node_id, parent_id = node["node_id"], node["parent_id"]
            nrecs.append({"depth": d, "node_local_index": li, "node_id": node_id, "parent_id": parent_id, "path": node["path"], "node_type": node["node_type"], "node_energy": NE, "global_ratio": NE/GE if GE > 0 else np.nan})
            if NE <= 0 or Xd.shape[0] < rank:
                continue
            if node["node_type"] == "residual" and not decompose_residual_branch:
                continue
            model = NMF(n_components=rank, init=init, solver=solver, max_iter=max_iter, random_state=random_state)
            W = model.fit_transform(Xd)
            H = model.components_
            rimg, rspec, RE = compute_residual_summary(Xd, W, H, image_shape, chunk_size)
            ns = RRNodeSummary(d, node_id, parent_id, node["path"], residual_image=rimg, residual_spectrum=rspec, residual_energy=RE)
            ns.node_type = node.get("node_type", "component")
            ns.combined_name = node.get("name", "")
            ns.combined_members = list(node.get("members", []))
            for ci in range(rank):
                Wi, Hi = W[:,ci], H[ci]
                ei = component_energy_no_outer(Wi, Hi)
                wm = Wi.reshape(ih, iw)
                ns.component_maps.append(wm)
                ns.component_spectra.append(Hi.copy())
                erecs.append({"method": "rr_nmf", "depth": d, "node_local_index": li, "node_id": node_id, "parent_id": parent_id, "component_id": ci, "type": "component", "energy": ei, "node_energy": NE, "global_energy": GE, "node_ratio": ei/NE if NE > 0 else np.nan, "global_ratio": ei/GE if GE > 0 else np.nan, "path": f'{node["path"]}/C{ci}'})
                # Always compute the exact child matrix so Manual Depth can merge
                # depth-1 components as true next-depth inputs, including residual redistribution.
                child = make_child_matrix_chunked(Xd, W, H, ci, rank, residual_mode, residual_nonnegative, chunk_size)
                ns.child_matrices.append(child)
                if d < max_depth:
                    nxt.append({"X": child, "node_id": nid, "parent_id": node_id, "path": f'{node["path"]}/C{ci}', "node_type": "component"})
                    nid += 1
            erecs.append({"method": "rr_nmf", "depth": d, "node_local_index": li, "node_id": node_id, "parent_id": parent_id, "component_id": "R", "type": "residual", "energy": RE, "node_energy": NE, "global_energy": GE, "node_ratio": RE/NE if NE > 0 else np.nan, "global_ratio": RE/GE if GE > 0 else np.nan, "path": node["path"] + "/R"})
            if residual_mode == "explicit_branch" and d < max_depth:
                rb = make_residual_branch_chunked(Xd, W, H, residual_nonnegative, chunk_size)
                nxt.append({"X": rb, "node_id": nid, "parent_id": node_id, "path": node["path"] + "/R", "node_type": "residual"})
                nid += 1
            slist.append(ns)
        summaries.append(slist)
        if d < max_depth:
            next_depth = d + 1
            if next_depth in prepared_manual_groups:
                nodes = []
                for gi, g in enumerate(prepared_manual_groups[next_depth]):
                    nodes.append({
                        "X": g["X"],
                        "node_id": nid,
                        "parent_id": -1,
                        "path": f"manualD{next_depth}/G{gi+1}:{g['name']}",
                        "node_type": "manual_combined",
                        "name": g.get("name", f"manual_group_{gi+1}"),
                        "members": list(g.get("members", [])),
                    })
                    nid += 1
            else:
                nodes = nxt
        else:
            nodes = []
    return RRNMFResult(summaries, pd.DataFrame(erecs), pd.DataFrame(nrecs), rank)


def add_colorbar(fig, ax, im):
    cax = make_axes_locatable(ax).append_axes("right", size="4%", pad=0.05)
    cb = fig.colorbar(im, cax=cax)
    cb.ax.tick_params(labelsize=7)


class Canvas(FigureCanvas):
    def __init__(self, w=12, h=8):
        self.fig = Figure(figsize=(w,h), dpi=100)
        super().__init__(self.fig)
        self.base = (w,h)
        self.zoom = 1.0
        self.setSizePolicy(QSizePolicy.Fixed, QSizePolicy.Fixed)
        self.resize_canvas()
    def resize_canvas(self):
        w,h = self.fig.get_size_inches()
        self.setFixedSize(int(w*100), int(h*100))
    def draw(self, *a, **k):
        self.resize_canvas()
        super().draw(*a, **k)
    def set_base(self):
        self.base = tuple(self.fig.get_size_inches())
        self.zoom = 1.0
    def zoom_in(self): self.zoom *= 1.25; self.apply_zoom()
    def zoom_out(self): self.zoom /= 1.25; self.apply_zoom()
    def reset_zoom(self): self.zoom = 1.0; self.apply_zoom()
    def apply_zoom(self):
        self.zoom = max(0.2, min(8, self.zoom))
        self.fig.set_size_inches(self.base[0]*self.zoom, self.base[1]*self.zoom, forward=True)
        self.draw()
    def clear(self): self.fig.clear(); self.draw()


class PlotPanel(QWidget):
    def __init__(self, canvas):
        super().__init__()
        self.canvas = canvas
        self.scroll = QScrollArea()
        self.scroll.setWidget(canvas)
        self.scroll.setWidgetResizable(False)
        tb = QHBoxLayout()
        for txt, cb in [("Zoom +", canvas.zoom_in), ("Zoom -", canvas.zoom_out), ("Reset", canvas.reset_zoom)]:
            b = QPushButton(txt); b.clicked.connect(cb); tb.addWidget(b)
        tb.addStretch(1)
        lay = QVBoxLayout(self)
        lay.addLayout(tb)
        lay.addWidget(self.scroll)


def plot_raw(
    fig,
    cube,
    axis,
    cmap="viridis",
    full_cube=None,
    spatial_roi=None,
    raw_roi_before_bg=None,
    corrected_roi=None,
    bg_applied=False,
    selected_pixel=None,
    corrected_full_cube=None,
):
    """Raw-data view with click-selected single-pixel spectrum.

    The spinbox ROI still defines the analysis ROI. Mouse interaction on this tab now only
    selects one spatial pixel for inspection and does not modify the analysis ROI.
    """
    fig.clear()
    if bg_applied and corrected_full_cube is not None:
        fig.set_size_inches(16, 9.2, forward=True)
        gs = fig.add_gridspec(2, 2, width_ratios=[1.0, 1.35], height_ratios=[1, 1])
        ax = fig.add_subplot(gs[0, 0])
        ax_corr = fig.add_subplot(gs[1, 0])
        sp = fig.add_subplot(gs[:, 1])
    else:
        fig.set_size_inches(16, 6.4, forward=True)
        gs = fig.add_gridspec(1, 2, width_ratios=[1.0, 1.35])
        ax = fig.add_subplot(gs[0, 0])
        ax_corr = None
        sp = fig.add_subplot(gs[0, 1])

    show_cube = full_cube if full_cube is not None else cube
    raw_img = np.sum(show_cube, axis=2)
    im = ax.imshow(raw_img, cmap=cmap, origin="upper", aspect="equal")
    ax.set_title("Raw sum image: click a pixel to inspect spectrum", pad=18)
    ax.set_xlabel("X"); ax.set_ylabel("Y")

    if spatial_roi is not None:
        y0, y1, x0, x1 = spatial_roi
        rect = Rectangle((x0, y0), max(1, x1 - x0), max(1, y1 - y0), fill=False, linewidth=1.8)
        ax.add_patch(rect)
        ax.text(
            0.02, 0.98, f"Analysis ROI x[{x0}:{x1}] y[{y0}:{y1}]",
            transform=ax.transAxes,
            fontsize=9, va="top", ha="left", clip_on=True,
            bbox=dict(facecolor="white", alpha=0.82, edgecolor="black", linewidth=0.3, pad=2.5),
        )

    if selected_pixel is not None:
        px, py = selected_pixel
        ax.plot([px], [py], marker="x", markersize=8, markeredgewidth=1.8)
        ax.text(
            0.02, 0.08, f"Selected pixel: x={px}, y={py}",
            transform=ax.transAxes,
            fontsize=9, va="bottom", ha="left", clip_on=True,
            bbox=dict(facecolor="white", alpha=0.82, edgecolor="black", linewidth=0.3, pad=2.5),
        )
    add_colorbar(fig, ax, im)

    if ax_corr is not None:
        corr_img = np.sum(corrected_full_cube, axis=2)
        im2 = ax_corr.imshow(corr_img, cmap=cmap, origin="upper", aspect="equal")
        ax_corr.set_title("Background-corrected raw image", pad=12)
        ax_corr.set_xlabel("X"); ax_corr.set_ylabel("Y")
        if spatial_roi is not None:
            y0, y1, x0, x1 = spatial_roi
            ax_corr.add_patch(Rectangle((x0, y0), max(1, x1 - x0), max(1, y1 - y0), fill=False, linewidth=1.8))
        if selected_pixel is not None:
            px, py = selected_pixel
            ax_corr.plot([px], [py], marker="x", markersize=8, markeredgewidth=1.8)
        add_colorbar(fig, ax_corr, im2)

    # Spectrum: single clicked pixel. If no pixel is selected yet, use the analysis-ROI mean
    # as a safe default and label it explicitly.
    src_raw = raw_roi_before_bg if raw_roi_before_bg is not None else cube
    src_corr = corrected_roi if corrected_roi is not None else cube
    if selected_pixel is not None:
        px, py = selected_pixel
        l0_len = src_corr.shape[-1]
        if full_cube is not None and 0 <= py < full_cube.shape[0] and 0 <= px < full_cube.shape[1]:
            # selected pixel in full-image coordinates; channel range is already matched to axis
            # by caller via current_channel_bounds.
            raw_spec = np.asarray(src_raw[py, px, :], dtype=np.float64) if src_raw.ndim == 3 and src_raw.shape[:2] == full_cube.shape[:2] else None
            corr_spec = np.asarray(src_corr[py, px, :], dtype=np.float64) if src_corr.ndim == 3 and src_corr.shape[:2] == full_cube.shape[:2] else None
        else:
            raw_spec = corr_spec = None
        if raw_spec is None:
            raw_spec, _ = roi_mean_std_spectrum(src_raw)
        if corr_spec is None:
            corr_spec, _ = roi_mean_std_spectrum(src_corr)
        spec_title = f"Single-pixel spectrum x={px}, y={py}"
    else:
        raw_spec, raw_std = roi_mean_std_spectrum(src_raw)
        corr_spec, corr_std = roi_mean_std_spectrum(src_corr)
        spec_title = "Analysis ROI mean spectrum (click image for one pixel)"

    x = axis.energy_axis if len(axis.energy_axis) == len(raw_spec) else np.arange(len(raw_spec))
    sp.plot(x, raw_spec, linewidth=1.4, label="raw pixel" if selected_pixel is not None else "ROI raw mean")
    if selected_pixel is None:
        sp.fill_between(x, raw_spec - raw_std, raw_spec + raw_std, alpha=0.16, label="ROI raw ±1σ")
    if bg_applied and corrected_roi is not None:
        bg_spec = raw_spec - corr_spec
        sp.plot(x, bg_spec, linewidth=1.2, label="estimated BG = raw - corrected")
        sp.plot(x, corr_spec, linewidth=1.5, label="raw - BG / corrected")
        if selected_pixel is None:
            sp.fill_between(x, corr_spec - corr_std, corr_spec + corr_std, alpha=0.12, label="corrected ±1σ")
    sp.set_title(spec_title)
    sp.set_xlabel(axis.energy_label); sp.set_ylabel("Intensity")
    sp.grid(True, alpha=.3); sp.legend(fontsize=8)
    fig.subplots_adjust(left=.055, right=.97, top=.93, bottom=.09, wspace=.34, hspace=.34)

