        self.tabs.addTab(self.canvas_tree, "rr-NMF Tree")

        self.canvas_conv = MplCanvas(width=10, height=8)
        self.tabs.addTab(self.canvas_conv, "Conventional NMF")

        self.canvas_energy = MplCanvas(width=10, height=8)
        self.tabs.addTab(self.canvas_energy, "Energy Summary")

        self.table_energy = QTableWidget()
        self.tabs.addTab(self.table_energy, "Energy Table")

        self.table_nodes = QTableWidget()
        self.tabs.addTab(self.table_nodes, "Node Table")

    def append_log(self, msg: str):
        self.log.append(msg)

    def load_file(self):
        path, _ = QFileDialog.getOpenFileName(
            self,
            "Load EELS/EDS Data",
            "",
            "Data Files (*.npy *.npz *.hspy *.hdf5 *.h5 *.emd *.dm3 *.dm4 *.msa);;All Files (*.*)",
        )
        if not path:
            return
        try:
            self.append_log(f"Loading: {path}")
            cube, meta = load_hyperspectral_file(path)
            cube = nonnegative(cube, "clip")
            self.cube = cube
            H_img, W_img, L = cube.shape
            self.image_shape = (H_img, W_img)
            X = cube.reshape(H_img * W_img, L)
            X = normalize_spectra(X, self.combo_norm.currentText())
            self.X = nonnegative(X, "clip")
            self.metadata = meta
            self.lbl_file.setText(os.path.basename(path))
            self.lbl_shape.setText(f"{cube.shape} -> X={self.X.shape}")
            self.append_log(f"Loaded cube shape: {cube.shape}")
            self.append_log(f"Metadata: {meta}")
        except Exception as e:
            QMessageBox.critical(self, "Load failed", str(e))
            self.append_log(traceback.format_exc())

    def collect_params(self) -> Dict[str, Any]:
        return {
            "run_conventional": self.chk_conv.isChecked(),
            "conv_components": self.spin_conv_k.value(),
            "run_rr": self.chk_rr.isChecked(),
            "rr_rank": self.spin_rr_rank.value(),
            "rr_depth": self.spin_rr_depth.value(),
            "residual_mode": self.combo_residual_mode.currentText(),
            "residual_nonnegative": self.combo_residual_nonnegative.currentText(),
            "decompose_residual_branch": self.chk_decompose_residual.isChecked(),
            "max_iter": self.spin_iter.value(),
            "init": self.combo_init.currentText(),
            "solver": self.combo_solver.currentText(),
            "random_state": self.spin_seed.value(),
        }

    def run_analysis(self):
        if self.X is None or self.image_shape is None:
            QMessageBox.warning(self, "No data", "Load data first.")
            return
        self.btn_run.setEnabled(False)
        self.append_log("Starting analysis...")
        params = self.collect_params()
        self.worker = AnalysisWorker(self.X, self.image_shape, params)
        self.worker.finished_ok.connect(self.on_analysis_finished)
        self.worker.failed.connect(self.on_analysis_failed)
        self.worker.start()

    def on_analysis_finished(self, conv_result: Optional[ConventionalNMFResult], rr_result: Optional[RRNMFResult], logs: str):
        self.conv_result = conv_result
        self.rr_result = rr_result
        self.append_log(logs)
        self.btn_run.setEnabled(True)
        self.refresh_views()

    def on_analysis_failed(self, err: str):
        self.btn_run.setEnabled(True)
        QMessageBox.critical(self, "Analysis failed", err)
        self.append_log(err)

    def refresh_views(self):
        if self.rr_result is not None:
            plot_tree_with_H_and_edges(self.canvas_tree.fig, self.rr_result)
            self.canvas_tree.draw()
        else:
            self.canvas_tree.clear()

        if self.conv_result is not None:
            plot_w_h_gallery(self.canvas_conv.fig, self.conv_result.W_images, self.conv_result.H_spectra, "Conventional NMF W/H")
            self.canvas_conv.draw()
        else:
            self.canvas_conv.clear()

        plot_energy_summary(self.canvas_energy.fig, self.conv_result, self.rr_result)
        self.canvas_energy.draw()

        self.refresh_tables()

    def dataframe_to_table(self, df: pd.DataFrame, table: QTableWidget, max_rows: int = 2000):
        if df is None or df.empty:
            table.clear()
            table.setRowCount(0)
            table.setColumnCount(0)
            return
        df_show = df.head(max_rows).copy()
        table.setRowCount(len(df_show))
        table.setColumnCount(len(df_show.columns))
        table.setHorizontalHeaderLabels([str(c) for c in df_show.columns])
        for r in range(len(df_show)):
            for c, col in enumerate(df_show.columns):
                val = df_show.iloc[r, c]
                if isinstance(val, float):
                    txt = f"{val:.6g}"
                else:
                    txt = str(val)
                table.setItem(r, c, QTableWidgetItem(txt))
        table.resizeColumnsToContents()

    def refresh_tables(self):
        dfs = []
        if self.conv_result is not None:
            dfs.append(self.conv_result.energy_records)
        if self.rr_result is not None:
            dfs.append(self.rr_result.energy_records)
        if dfs:
            df_energy = pd.concat(dfs, ignore_index=True)
        else:
            df_energy = pd.DataFrame()
        self.dataframe_to_table(df_energy, self.table_energy)

        if self.rr_result is not None:
            self.dataframe_to_table(self.rr_result.node_records, self.table_nodes)
        else:
            self.dataframe_to_table(pd.DataFrame(), self.table_nodes)

    def export_csv(self):
        if self.conv_result is None and self.rr_result is None:
            QMessageBox.warning(self, "No result", "Run analysis first.")
            return
        out_dir = QFileDialog.getExistingDirectory(self, "Select output directory")
        if not out_dir:
            return
        try:
            if self.conv_result is not None:
                self.conv_result.energy_records.to_csv(os.path.join(out_dir, "conventional_nmf_energy.csv"), index=False)
                pd.DataFrame(self.conv_result.h_corr).to_csv(os.path.join(out_dir, "conventional_H_corr.csv"), index=False)
                pd.DataFrame(self.conv_result.w_corr).to_csv(os.path.join(out_dir, "conventional_W_corr.csv"), index=False)
            if self.rr_result is not None:
                self.rr_result.energy_records.to_csv(os.path.join(out_dir, "rr_nmf_energy.csv"), index=False)
                self.rr_result.node_records.to_csv(os.path.join(out_dir, "rr_nmf_nodes.csv"), index=False)
            self.append_log(f"CSV exported to {out_dir}")
        except Exception as e:
            QMessageBox.critical(self, "Export failed", str(e))
            self.append_log(traceback.format_exc())

    def export_npz(self):
        if self.conv_result is None and self.rr_result is None:
            QMessageBox.warning(self, "No result", "Run analysis first.")
            return
        path, _ = QFileDialog.getSaveFileName(self, "Save NPZ result", "rr2_nmf_results.npz", "NPZ (*.npz)")
        if not path:
            return
        try:
            payload: Dict[str, Any] = {}
            if self.conv_result is not None:
                payload["conv_W"] = self.conv_result.W
                payload["conv_H"] = self.conv_result.H
                payload["conv_R"] = self.conv_result.R
                payload["conv_h_corr"] = self.conv_result.h_corr
                payload["conv_w_corr"] = self.conv_result.w_corr
            if self.rr_result is not None:
                # Object arrays because depth lists may vary in length
                payload["rr_W_images_by_depth"] = np.array(self.rr_result.W_images_by_depth, dtype=object)
                payload["rr_H_spectra_by_depth"] = np.array(self.rr_result.H_spectra_by_depth, dtype=object)
                payload["rr_errors_by_depth"] = np.array(self.rr_result.errors_by_depth, dtype=object)
                payload["rr_targets_by_depth"] = np.array(self.rr_result.targets_by_depth, dtype=object)
                payload["rr_residuals_by_depth"] = np.array(self.rr_result.residuals_by_depth, dtype=object)
            np.savez_compressed(path, **payload)
            self.append_log(f"NPZ exported: {path}")
        except Exception as e:
            QMessageBox.critical(self, "Export failed", str(e))
            self.append_log(traceback.format_exc())


