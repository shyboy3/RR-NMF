    return labels, C


def auto_score_pair_from_entries(e1, e2, corr_weight=0.50, w_downsample_factor=4):
    """Score = a*Corr(W_downsampled) + (1-a)*Corr(H). Both terms are clipped to 0..1."""
    a = float(np.clip(corr_weight, 0.0, 1.0))
    wm1 = downsample_map_mean(np.asarray(e1.get("W_map"), dtype=np.float64), factor=w_downsample_factor).reshape(-1)
    wm2 = downsample_map_mean(np.asarray(e2.get("W_map"), dtype=np.float64), factor=w_downsample_factor).reshape(-1)
    hs1 = np.asarray(e1.get("H_spec"), dtype=np.float64).reshape(-1)
    hs2 = np.asarray(e2.get("H_spec"), dtype=np.float64).reshape(-1)
    w_corr = safe_pearson_1d(wm1, wm2)
    h_corr = safe_pearson_1d(hs1, hs2)
    w_corr_pos = float(np.clip(w_corr if np.isfinite(w_corr) else 0.0, 0.0, 1.0))
    h_corr_pos = float(np.clip(h_corr if np.isfinite(h_corr) else 0.0, 0.0, 1.0))
    score = a * w_corr_pos + (1.0 - a) * h_corr_pos
    return float(score), w_corr_pos, h_corr_pos


def auto_score_groups_from_entries(entries, corr_weight=0.50, threshold_pct=55.0, w_downsample_factor=4):
    """Cluster components by Score=a*W-downsample-corr+(1-a)*H-corr using connected components."""
    entries = list(entries or [])
    n = len(entries)
    if n == 0:
        return [], []
    thr = float(threshold_pct) / 100.0
    parent = list(range(n))
    def find(x):
        while parent[x] != x:
            parent[x] = parent[parent[x]]
            x = parent[x]
        return x
    def union(a, b):
        ra, rb = find(a), find(b)
        if ra != rb:
            parent[rb] = ra
    pair_rows = []
    for i in range(n):
        for j in range(i + 1, n):
            score, w_corr, h_corr = auto_score_pair_from_entries(entries[i], entries[j], corr_weight, w_downsample_factor=w_downsample_factor)
            pair_rows.append({"i": i, "j": j, "label_i": entries[i].get("label", str(i)), "label_j": entries[j].get("label", str(j)), "score": score, "w_corr_down": w_corr, "h_corr": h_corr, "corr": h_corr})
            if score >= thr:
                union(i, j)
    bins = {}
    for i, e in enumerate(entries):
        bins.setdefault(find(i), []).append((i, e))
    indexed_groups = list(bins.values())
    indexed_groups.sort(key=lambda g: min(i for i, _ in g) if g else 999999)
    groups = [[e for _, e in g] for g in indexed_groups]
    return groups, pair_rows



def normalize_map_for_display(wm, eps=1e-12):
    """Normalize a W-like image to 0..1 for provenance-only display."""
    a = np.asarray(wm, dtype=np.float64)
    a = np.nan_to_num(a, nan=0.0, posinf=0.0, neginf=0.0)
    mn = float(np.nanmin(a)) if a.size else 0.0
    mx = float(np.nanmax(a)) if a.size else 0.0
    if mx - mn <= eps:
        return np.zeros_like(a, dtype=np.float64)
    return (a - mn) / (mx - mn)


def combine_w_maps_for_provenance(entries):
    """Return a W-only visual summary for a merged/pass set.

    This is deliberately not the child-matrix summed-intensity image.  It is used only
    to show which morphology is being passed/merged, so PASS output thumbnails remain
    visually identical to their source W image.
    """
    maps = []
    for e in entries or []:
        wm = e.get("W_map", None) if isinstance(e, dict) else None
        if wm is not None:
            maps.append(normalize_map_for_display(wm))
    if not maps:
        return None
    if len(maps) == 1:
        return maps[0]
    return np.nanmean(np.stack(maps, axis=0), axis=0)




def _entry_lookup_by_label(rr):
    """Map full component labels (e.g. D3 N1 C0) to rr component entries."""
    return {e.get("label", ""): e for e in collect_rr_component_entries(rr)}


def _short_set_label(c, idx):
    kind = "P" if bool(c.get("pass_through", False)) else "M"
    name = str(c.get("name", f"{kind}{idx+1}"))
    if name.startswith("AutoScore_"):
        name = name.replace("AutoScore_", "")
    if name.startswith("AutoPass_"):
        name = name.replace("AutoPass_", "")
    name = name.replace(" ", "")
    if len(name) > 14:
        name = name[:12] + "…"
    return f"{kind}{idx+1}:{name}"


def residual_free_mergepass_representations(rr, manual_depth_groups, target_key, w_downsample_factor=4):
    """Return residual-free W-like images and H-like spectra for merge/pass output sets.

    target_key K means the merge/pass operation made from source depth K-1 and used as
    the input to depth K.  For this diagnostic we deliberately rebuild every set from
    pure outer products sum(W_i H_i), with no residual/r term, even when the real
    continuation used child matrices.  This lets the user check whether the merge/pass
    grouping itself produced mutually distinct W/H representations.
    """
    groups = (manual_depth_groups or {}).get(int(target_key), []) or []
    lookup = _entry_lookup_by_label(rr)
    labels, images, spectra = [], [], []
    for idx, c in enumerate(groups):
        members = list(c.get("member_labels", c.get("members", [])) or [])
        entries = [lookup[m] for m in members if m in lookup]
        if not entries:
            continue
        try:
            ds = build_combined_dataset(entries, _short_set_label(c, idx), use_child_matrix=False)
            labels.append(_short_set_label(c, idx))
            images.append(np.asarray(downsample_map_mean(ds["image"], factor=w_downsample_factor), dtype=np.float64).reshape(-1))
            spectra.append(np.asarray(ds["spectrum"], dtype=np.float64).reshape(-1))
        except Exception:
            continue
    return labels, images, spectra


def _corr_matrix_from_vectors(vectors, nonnegative_display=True):
    n = len(vectors or [])
    if n == 0:
        return np.zeros((0, 0), dtype=np.float64)
    M = np.eye(n, dtype=np.float64)
    for i in range(n):
        for j in range(i + 1, n):
            c = safe_pearson_1d(vectors[i], vectors[j])
            M[i, j] = M[j, i] = c if np.isfinite(c) else 0.0
    if nonnegative_display:
        M = np.clip(M, 0.0, 1.0)
    return M


def compute_residual_free_mergepass_corr(rr, manual_depth_groups, target_key, w_downsample_factor=4):
    labels, wvecs, hvecs = residual_free_mergepass_representations(
        rr, manual_depth_groups, target_key, w_downsample_factor=w_downsample_factor
    )
    return labels, _corr_matrix_from_vectors(wvecs), _corr_matrix_from_vectors(hvecs)


def matrix_diagonality_score(M):
    """Return a compact 0-1 diagonal-dominance score for similarity matrices.

    1 means diagonal is much stronger than off-diagonal similarity; 0 means
    off-diagonal similarity is as large as the diagonal on average.
    """
    if M is None:
        return np.nan
    A = np.clip(np.asarray(M, dtype=np.float64), 0.0, 1.0)
    if A.ndim != 2 or A.size == 0:
        return np.nan
    n = min(A.shape)
    if n <= 1:
        return 1.0
    diag_mean = float(np.nanmean(np.diag(A[:n, :n])))
    mask = ~np.eye(n, dtype=bool)
    off = A[:n, :n][mask]
    off_mean = float(np.nanmean(off)) if off.size else 0.0
    if not np.isfinite(diag_mean) or diag_mean <= 1e-12:
        return np.nan
    return float(np.clip((diag_mean - off_mean) / max(diag_mean, 1e-12), 0.0, 1.0))


def _plot_corr_heatmap(ax, fig, labels, M, title, annotate_limit=14):
    if M is None or M.size == 0:
        ax.axis("off")
        ax.text(0.5, 0.5, "No data", ha="center", va="center")
        ax.set_title(title, fontsize=10)
        return
    Mdisp = np.clip(np.asarray(M, dtype=np.float64), 0.0, 1.0)
    im = ax.imshow(Mdisp, vmin=0, vmax=1, cmap="viridis", aspect="equal")
    diag_score = matrix_diagonality_score(Mdisp)
    diag_txt = f" | diag={diag_score:.2f}" if np.isfinite(diag_score) else ""
    ax.set_title(f"{title}{diag_txt}", fontsize=10)
    if len(labels) <= 24:
        ax.set_xticks(range(len(labels)))
        ax.set_xticklabels(labels, rotation=90, fontsize=5.5)
        ax.set_yticks(range(len(labels)))
        ax.set_yticklabels(labels, fontsize=5.5)
    else:
        ax.set_xticks([]); ax.set_yticks([])
    if Mdisp.shape[0] <= annotate_limit:
        for ii in range(Mdisp.shape[0]):
            for jj in range(Mdisp.shape[1]):
                ax.text(jj, ii, f"{Mdisp[ii, jj]:.2f}", ha="center", va="center", fontsize=5.2)
    add_colorbar(fig, ax, im)


def local_shape_match_mask(h, w, threshold_pct=80.0, window=None):
    """Find energy-channel regions where H and weighted raw have local shape agreement.

    Uses sliding-window Pearson correlation, so baseline offset and absolute intensity scale
    are removed. threshold_pct is 0-100 and internally mapped to 0.0-1.0.
    """
    h = np.asarray(h, dtype=np.float64).reshape(-1)
    w = np.asarray(w, dtype=np.float64).reshape(-1)
    L = min(len(h), len(w))
    if L <= 3:
        return np.zeros(L, dtype=bool), np.full(L, np.nan), []
    h = h[:L]
    w = w[:L]
    if window is None:
        window = max(9, int(round(L / 40)))
    window = int(max(5, min(window, max(5, L))))
    if window % 2 == 0:
        window += 1
    half = window // 2
    corr = np.full(L, np.nan, dtype=np.float64)
    for k in range(L):
        a = max(0, k - half)
        b = min(L, k + half + 1)
        if b - a >= 5:
            corr[k] = safe_pearson_1d(h[a:b], w[a:b])
    thr = float(threshold_pct) / 100.0
    mask = np.isfinite(corr) & (corr >= thr)
    intervals = []
    st = None
    for i, ok in enumerate(mask):
        if ok and st is None:
            st = i
        if (not ok or i == L - 1) and st is not None:
            en = i if not ok else i + 1
            if en - st >= 2:
                intervals.append((st, en))
            st = None
    return mask, corr, intervals


def _shade_match_intervals(ax, x, intervals, ymin=0.0, ymax=1.0):
    """Draw semi-transparent match windows on an axis."""
    if x is None or len(x) == 0:
        return
    x = np.asarray(x)
    for st, en in intervals:
        st = max(0, min(int(st), len(x) - 1))
        en_i = max(st, min(int(en) - 1, len(x) - 1))
        ax.axvspan(float(x[st]), float(x[en_i]), ymin=ymin, ymax=ymax, alpha=0.14)


def plot_rr_diagnostics_summary(fig, rr, axis, X_for_weight=None, match_threshold_pct=80.0, match_window=21, w_downsample_factor=4, manual_depth_groups=None):
    """Summary tab: W morphology correlation maps and H/raw local-match ratios by depth."""
    fig.clear()
    if rr is None:
        fig.set_size_inches(12, 5, forward=True)
        ax = fig.add_subplot(111)
        ax.axis("off")
        ax.text(0.5, 0.5, "Run rr-NMF first", ha="center", va="center", fontsize=14)
        return
    depths = rr.node_summaries_by_depth
    manual_depth_groups = manual_depth_groups or {}
    # Add one extra diagnostic row for each merge/pass operation.  Target key K
    # corresponds to the merge/pass output made from source depth K-1.
    merge_keys = sorted([int(k) for k, v in manual_depth_groups.items() if v])
    row_plan = [("depth", d) for d in range(len(depths))]
    for key in merge_keys:
        src = int(key) - 1
        if 0 <= src < len(depths):
            row_plan.append(("merge", key))
    nrows = max(1, len(row_plan))
    fig.set_size_inches(28, max(5, nrows * 3.9), forward=True)
    gs = fig.add_gridspec(nrows, 5, width_ratios=[1.0, 1.0, 1.35, 1.0, 1.0])
    for row_idx, (row_type, row_key) in enumerate(row_plan):
        if row_type == "merge":
            key = int(row_key)
            source_depth = key - 1
            labels_mp, Wmp, Hmp = compute_residual_free_mergepass_corr(rr, manual_depth_groups, key, w_downsample_factor=w_downsample_factor)
            ax0 = fig.add_subplot(gs[row_idx, 0:3])
            ax0.axis("off")
            ax0.text(
                0.02, 0.62,
                f"Residual-free merge/pass diagnostic from D{source_depth} → D{key}",
                ha="left", va="center", fontsize=12, fontweight="bold"
            )
            ax0.text(
                0.02, 0.32,
                "Matrices compare the merge/pass output sets rebuilt as sum(W_i H_i), without residual/r.\n"
                "High off-diagonal values mean merge/pass outputs are still similar; low values mean grouping produced distinct outputs.",
                ha="left", va="center", fontsize=9
            )
            axw = fig.add_subplot(gs[row_idx, 3])
            _plot_corr_heatmap(axw, fig, labels_mp, Wmp, f"D{source_depth} merge/pass\nW DownCorr no-R")
            axh = fig.add_subplot(gs[row_idx, 4])
            _plot_corr_heatmap(axh, fig, labels_mp, Hmp, f"D{source_depth} merge/pass\nH Corr no-R")
            continue

        d = int(row_key)
        nodes = depths[d]
        axc = fig.add_subplot(gs[row_idx, 0])
        labels, C = compute_w_morphology_downcorr_for_depth(nodes, factor=w_downsample_factor)
        if C.size:
            Cdisp = np.clip(C, 0.0, 1.0)
            im = axc.imshow(Cdisp, vmin=0, vmax=1, cmap="viridis", aspect="equal")
            diag_c = matrix_diagonality_score(Cdisp)
            diag_txt = f" | diag={diag_c:.2f}" if np.isfinite(diag_c) else ""
            axc.set_title(f"Depth {d}: W DownCorr similarity (factor={int(w_downsample_factor)}){diag_txt}", fontsize=11)
            if len(labels) <= 24:
                axc.set_xticks(range(len(labels))); axc.set_xticklabels(labels, rotation=90, fontsize=6)
                axc.set_yticks(range(len(labels))); axc.set_yticklabels(labels, fontsize=6)
            else:
                axc.set_xticks([]); axc.set_yticks([])
            if Cdisp.shape[0] <= 12:
                for _ii in range(Cdisp.shape[0]):
                    for _jj in range(Cdisp.shape[1]):
                        axc.text(_jj, _ii, f"{Cdisp[_ii, _jj]:.2f}", ha="center", va="center", fontsize=6)
            add_colorbar(fig, axc, im)
        else:
            axc.axis("off"); axc.text(0.5, 0.5, f"Depth {d}: no W maps", ha="center", va="center")

        axs = fig.add_subplot(gs[row_idx, 1])
        labels_h, Hcorr = compute_h_basis_corr_for_depth(nodes)
        if Hcorr.size:
            im2 = axs.imshow(np.clip(Hcorr, 0.0, 1.0), vmin=0, vmax=1, cmap="viridis", aspect="equal")
            diag_h = matrix_diagonality_score(Hcorr)
            diag_txt_h = f" | diag={diag_h:.2f}" if np.isfinite(diag_h) else ""
            axs.set_title(f"Depth {d}: H Corr similarity{diag_txt_h}", fontsize=11)
            if len(labels_h) <= 24:
                axs.set_xticks(range(len(labels_h))); axs.set_xticklabels(labels_h, rotation=90, fontsize=6)
                axs.set_yticks(range(len(labels_h))); axs.set_yticklabels(labels_h, fontsize=6)
            else:
                axs.set_xticks([]); axs.set_yticks([])
            if Hcorr.shape[0] <= 12:
                for _ii in range(Hcorr.shape[0]):
                    for _jj in range(Hcorr.shape[1]):
                        axs.text(_jj, _ii, f"{Hcorr[_ii, _jj]:.2f}", ha="center", va="center", fontsize=6)
            add_colorbar(fig, axs, im2)
        else:
            axs.axis("off"); axs.text(0.5, 0.5, f"Depth {d}: no H spectra", ha="center", va="center")

        axb = fig.add_subplot(gs[row_idx, 2])
        names, vals, fullcorrs = [], [], []
        if X_for_weight is not None:
            for ni, ns in enumerate(nodes):
                for ci, h in enumerate(getattr(ns, "component_spectra", []) or []):
                    try:
                        wspec = weighted_raw_spectrum_by_map(X_for_weight, ns.component_maps[ci])
                        mask, _, _ = local_shape_match_mask(h, wspec, match_threshold_pct, window=match_window)
                        names.append(f"N{ni}C{ci}")
                        vals.append(100.0 * float(np.count_nonzero(mask)) / max(1, len(mask)))
                        fullcorrs.append(safe_pearson_1d(normalize_for_shape_compare(h, "max"), normalize_for_shape_compare(wspec, "max")))
                    except Exception:
                        pass
        if vals:
            axb.bar(range(len(vals)), vals)
            axb.set_ylim(0, 100)
            axb.set_ylabel("matched channels (%)")
            axb.set_title(f"Depth {d}: H vs weighted raw local shape match ≥ {match_threshold_pct:.0f}% (window={int(match_window)} ch)", fontsize=11)
            axb.set_xticks(range(len(names)))
            axb.set_xticklabels(names, rotation=90, fontsize=7)
            axb.grid(True, axis="y", alpha=0.25)
            # annotate full-spectrum shape corr when space allows
            if len(vals) <= 28:
                for k, (v, c) in enumerate(zip(vals, fullcorrs)):
                    if np.isfinite(c):
                        axb.text(k, min(98, v + 2), f"r={c:.2f}", ha="center", va="bottom", rotation=90, fontsize=6)
        else:
            axb.axis("off")
            axb.text(0.5, 0.5, "No weighted raw spectra available", ha="center", va="center")
    fig.suptitle("rr-NMF interpretation diagnostics: component similarity, H/raw agreement, and residual-free merge/pass distinctness", fontsize=14)
    fig.subplots_adjust(left=0.06, right=0.975, top=0.94, bottom=0.045, hspace=0.65, wspace=0.32)


def _short_component_label(label: str) -> str:
    """Compact label for provenance plots."""
    try:
        return str(label).replace(" ", "")
    except Exception:
        return str(label)


def _auto_pair_stats_for_labels(pair_rows, labels):
    """Return aggregate score/W-downCorr/H-corr among selected labels."""
    labs = set(labels or [])
    rows = [r for r in (pair_rows or []) if r.get("label_i") in labs and r.get("label_j") in labs]
    if not rows:
        return None
    vals = {}
    for key in ("score", "w_corr_down", "h_corr", "corr"):
        arr = np.asarray([float(r.get(key, np.nan)) for r in rows], dtype=np.float64)
        arr = arr[np.isfinite(arr)]
        vals[key + "_mean"] = float(np.mean(arr)) if arr.size else np.nan
        vals[key + "_max"] = float(np.max(arr)) if arr.size else np.nan
        vals[key + "_min"] = float(np.min(arr)) if arr.size else np.nan
    vals["n_pairs"] = len(rows)
    return vals




def plot_auto_merge_w_provenance(fig, rr=None, manual_depth_groups=None, cmap="viridis"):
    """Auto-Step provenance tree with stable left-to-right arrows.

    Columns are interleaved as:
        Dk W results -> Dk->D(k+1) merge/pass -> D(k+1) W results

    Direct rr-NMF branches without an explicit merge/pass column, such as D0->D1
    before the first manual/auto merge depth, are also connected.
    """
    fig.clear()
    manual_depth_groups = manual_depth_groups or {}
    rr_depths = list(getattr(rr, "node_summaries_by_depth", []) or [])
    if not rr_depths and not manual_depth_groups:
        fig.set_size_inches(12, 5, forward=True)
        ax = fig.add_subplot(111); ax.axis("off")
        ax.text(0.5, 0.55, "No Auto-Step merge provenance yet", ha="center", va="center", fontsize=14)
        ax.text(0.5, 0.43, "Run Auto Step to create merge/pass groups.", ha="center", va="center", fontsize=10)
        return

    max_result_depth = max(0, len(rr_depths) - 1)
    output_keys = sorted([int(k) for k, v in manual_depth_groups.items() if v])

    comp_by_depth = {}
    node_lookup = {}
    for d, nodes in enumerate(rr_depths):
        comps = []
        for ni, ns in enumerate(nodes or []):
            node_lookup[(d, ni)] = ns
            for ci, wm in enumerate(getattr(ns, "component_maps", []) or []):
                comps.append({
                    "label": f"D{d} N{ni} C{ci}",
                    "map": wm,
                    "node_index": ni,
                    "node_id": getattr(ns, "node_id", ni),
                    "path": str(getattr(ns, "path", "")),
                    "component": ci,
                })
        comp_by_depth[d] = comps

    xslots = []
    for d in range(max_result_depth + 1):
        xslots.append(("result", d))
        if (d + 1) in output_keys:
            xslots.append(("output", d + 1))
    for k in output_keys:
        if k > max_result_depth and ("output", k) not in xslots:
            xslots.append(("output", k))

    ncols = max(1, len(xslots))
    col_index = {item: i for i, item in enumerate(xslots)}
    max_items = 1
    for d in range(max_result_depth + 1):
        max_items = max(max_items, len(comp_by_depth.get(d, [])))
    for k in output_keys:
        out_sets = [c for c in (manual_depth_groups.get(k, []) or []) if c.get("auto_score", False)]
        max_items = max(max_items, len(out_sets))

    # Keep thumbnails readable while leaving enough horizontal space for arrows.
    # Earlier versions made thumb_w almost equal to the column spacing, which made
    # arrow segments collapse into tiny strokes between images.
    fig_w = max(18.0, min(80.0, ncols * 3.05 + 3.5))
    fig_h = max(8.0, 0.62 * max_items + 3.0)
    fig.set_size_inches(fig_w, fig_h, forward=True)
    ax = fig.add_subplot(111)
    ax.set_xlim(0, 1); ax.set_ylim(0, 1); ax.axis("off")

    left_margin, right_margin = 0.030, 0.030
    usable_w = 1.0 - left_margin - right_margin
    col_gap = usable_w / max(1, ncols - 1)
    def x_for(item):
        if ncols == 1:
            return 0.5
        return left_margin + usable_w * (col_index[item] / (ncols - 1))

    thumb_w = min(0.080, max(0.026, col_gap * 0.52))
    thumb_h = min(0.095, 0.78 / max(1, max_items))
    y_top, y_bottom = 0.865, 0.12

    pos_comp = {}
    comp_meta = {}
    pos_out = {}

    def add_thumb(x, y, img, title, fontsize=7.7):
        iax = inset_axes(
            ax, width="100%", height="100%",
            bbox_to_anchor=(x - thumb_w/2, y - thumb_h/2, thumb_w, thumb_h),
            bbox_transform=ax.transAxes, borderpad=0
        )
        iax.imshow(img, cmap=cmap, origin="upper", aspect="equal")
        iax.set_xticks([]); iax.set_yticks([])
        iax.set_title(title, fontsize=fontsize, pad=1.0)
        return iax

    def edge_point(x, y, side):
        # Use thumbnail edge in the parent axes coordinate, with a small overreach
        # so arrows visually touch the image instead of floating in the gap.
        if side == "right":
            return (x + thumb_w * 0.505, y)
        if side == "left":
            return (x - thumb_w * 0.505, y)
        return (x, y)

    def draw_arrow(x0, y0, x1, y1, color="0.15", lw=1.85, alpha=0.88, rad=0.0):
        arr = FancyArrowPatch(
            (x0, y0), (x1, y1), transform=ax.transAxes,
            arrowstyle="-|>", mutation_scale=14.0,
            linewidth=lw, color=color, alpha=alpha,
            shrinkA=0, shrinkB=0,
            connectionstyle=f"arc3,rad={rad}"
        )
        ax.add_patch(arr)

    # Result columns.
    for d in range(max_result_depth + 1):
        item = ("result", d)
        x = x_for(item)
        ax.text(x, 0.976, f"Depth {d}\nW results", ha="center", va="top", fontsize=11.0,
                fontweight="bold", transform=ax.transAxes)
        comps = comp_by_depth.get(d, [])
        ys = np.linspace(y_top, y_bottom, len(comps)) if len(comps) > 1 else np.array([(y_top + y_bottom) / 2])
        for idx, comp in enumerate(comps):
            y = float(ys[idx])
            lab = comp["label"]
            pos_comp[lab] = (x, y)
            comp_meta[lab] = comp
            add_thumb(x, y, comp["map"], lab.replace(" ", ""), fontsize=7.4)

    # Direct decomposition arrows for transitions without explicit merge/pass output columns.
    for d in range(max_result_depth):
        if (d + 1) in output_keys:
            continue
        for slab, smeta in list(comp_meta.items()):
            if int(smeta.get("node_index", -1)) < 0 or not slab.startswith(f"D{d} "):
                continue
            s_node_id = smeta.get("node_id", None)
            s_comp = int(smeta.get("component", -1))
            targets = []
            for tni, tns in enumerate(rr_depths[d + 1] or []):
                if getattr(tns, "parent_id", None) == s_node_id and str(getattr(tns, "path", "")).endswith(f"/C{s_comp}"):
                    for tci in range(len(getattr(tns, "component_maps", []) or [])):
                        tlab = f"D{d+1} N{tni} C{tci}"
                        if tlab in pos_comp:
                            targets.append(tlab)
            if not targets:
                continue
            sx, sy = pos_comp[slab]
            for ti, tlab in enumerate(targets):
                tx, ty = pos_comp[tlab]
                x0, y0 = edge_point(sx, sy, "right")
                x1, y1 = edge_point(tx, ty, "left")
                rad = 0.0 if len(targets) <= 1 else (ti - (len(targets)-1)/2) * 0.022
                draw_arrow(x0, y0, x1, y1, color="0.25", lw=1.45, alpha=0.55, rad=rad)

    # Merge/pass columns and arrows.
    for key in output_keys:
        out_sets = [c for c in (manual_depth_groups.get(key, []) or []) if c.get("auto_score", False)]
        if not out_sets:
            continue
        source_depth = key - 1
        item = ("output", key)
        if item not in col_index:
            continue
        x = x_for(item)
        title = f"D{source_depth} → D{key}\nmerge/pass" if key <= max_result_depth else f"D{source_depth}\nFINAL result"
        ax.text(x, 0.976, title, ha="center", va="top", fontsize=10.7,
                fontweight="bold", transform=ax.transAxes)
        ys = np.linspace(y_top, y_bottom, len(out_sets)) if len(out_sets) > 1 else np.array([(y_top + y_bottom) / 2])
        for gi, c in enumerate(out_sets):
            y = float(ys[gi])
            pos_out[(key, gi)] = (x, y)
            members = list(c.get("member_labels", c.get("members", [])) or [])
            stats = c.get("auto_pair_stats", {}) or {}
            is_pass = bool(c.get("pass_through", False)) or len(members) <= 1
            gimg = c.get("provenance_image", None)
            if gimg is None:
                maps = list(c.get("member_maps", []) or [])
                if maps:
                    gimg = maps[0] if is_pass else np.nanmean(np.stack([normalize_map_for_display(m) for m in maps], axis=0), axis=0)
                else:
                    gimg = c.get("image", None)
            if gimg is not None:
                add_thumb(x, y, gimg, ("PASS" if is_pass else "MERGE") + f" G{gi+1}", fontsize=7.7)

            if is_pass:
                metric = "PASS"
            else:
                metric = (
                    f"S {100*stats.get('score_mean', np.nan):.1f}\n"
                    f"W {100*stats.get('w_corr_down_mean', np.nan):.1f}/"
                    f"H {100*stats.get('h_corr_mean', stats.get('corr_mean', np.nan)):.1f}"
                )
            # Place metric between source W results and merge/pass output, not between output and next depth.
            ax.text(x - thumb_w*0.62, y, metric, fontsize=8.8, ha="right", va="center",
                    transform=ax.transAxes,
                    bbox=dict(boxstyle="round,pad=0.10", fc="white", ec="0.65", alpha=0.88))

            for m_i, mlab in enumerate(members):
                if mlab in pos_comp:
                    sx, sy = pos_comp[mlab]
                    x0, y0 = edge_point(sx, sy, "right")
                    x1, y1 = edge_point(x, y, "left")
                    rad = 0.0 if len(members) <= 1 else (m_i - (len(members)-1)/2) * 0.030
                    draw_arrow(x0, y0, x1, y1, color="0.18", lw=1.75, alpha=0.82, rad=rad)

            if key <= max_result_depth:
                target_labels = sorted([lab for lab in pos_comp if lab.startswith(f"D{key} N{gi} C")])
                for t_i, tlab in enumerate(target_labels):
                    tx, ty = pos_comp[tlab]
                    x0, y0 = edge_point(x, y, "right")
                    x1, y1 = edge_point(tx, ty, "left")
                    rad = 0.0 if len(target_labels) <= 1 else (t_i - (len(target_labels)-1)/2) * 0.025
                    draw_arrow(x0, y0, x1, y1, color="0.05", lw=1.85, alpha=0.88, rad=rad)

    ax.text(0.012, 0.025,
            "W-only provenance tree. Final outputs after the last recursive depth are merge/pass results without residual/r.",
            fontsize=8, ha="left", va="bottom", transform=ax.transAxes)
    fig.suptitle("Auto-Step merge provenance: W results → merge/pass outputs → next-depth W results", fontsize=13.2)
    fig.subplots_adjust(left=0.010, right=0.990, top=0.935, bottom=0.045)


class Canvas(FigureCanvas):
    def __init__(self, w=12, h=8):
        self.fig = Figure(figsize=(w,h), dpi=100)
        super().__init__(self.fig)
        self.base = (w,h)
        self.zoom = 1.0
        self.setSizePolicy(QSizePolicy.Fixed, QSizePolicy.Fixed)
        self.resize_canvas()
    def resize_canvas(self):
        w,h = self.fig.get_size_inches()
        self.setFixedSize(int(w*100), int(h*100))
    def draw(self, *a, **k):
        self.resize_canvas()
        super().draw(*a, **k)
    def set_base(self):
        self.base = tuple(self.fig.get_size_inches())
        self.zoom = 1.0
    def zoom_in(self): self.zoom *= 1.25; self.apply_zoom()
    def zoom_out(self): self.zoom /= 1.25; self.apply_zoom()
    def reset_zoom(self): self.zoom = 1.0; self.apply_zoom()
    def apply_zoom(self):
        self.zoom = max(0.2, min(8, self.zoom))
        self.fig.set_size_inches(self.base[0]*self.zoom, self.base[1]*self.zoom, forward=True)
        self.draw()
    def clear(self): self.fig.clear(); self.draw()


class PlotPanel(QWidget):
    def __init__(self, canvas):
        super().__init__()
        self.canvas = canvas
        self.scroll = QScrollArea()
        self.scroll.setWidget(canvas)
        self.scroll.setWidgetResizable(False)
        tb = QHBoxLayout()
        for txt, cb in [("Zoom +", canvas.zoom_in), ("Zoom -", canvas.zoom_out), ("Reset", canvas.reset_zoom)]:
            b = QPushButton(txt); b.clicked.connect(cb); tb.addWidget(b)
        tb.addStretch(1)
        lay = QVBoxLayout(self)
        lay.addLayout(tb)
        lay.addWidget(self.scroll)




def plot_raw(
    fig,
    cube,
    axis,
    cmap="viridis",
    full_cube=None,
    spatial_roi=None,
    raw_roi_before_bg=None,
    corrected_roi=None,
    bg_applied=False,
    selected_pixel=None,
    corrected_full_cube=None,
):
    """Raw-data view with click-selected single-pixel spectrum.

    The spinbox ROI still defines the analysis ROI. Mouse interaction on this tab now only
    selects one spatial pixel for inspection and does not modify the analysis ROI.
    """
    fig.clear()
    if bg_applied and corrected_full_cube is not None:
        fig.set_size_inches(16, 9.2, forward=True)
        gs = fig.add_gridspec(2, 2, width_ratios=[1.0, 1.35], height_ratios=[1, 1])
        ax = fig.add_subplot(gs[0, 0])
        ax_corr = fig.add_subplot(gs[1, 0])
        sp = fig.add_subplot(gs[:, 1])
    else:
        fig.set_size_inches(16, 6.4, forward=True)
        gs = fig.add_gridspec(1, 2, width_ratios=[1.0, 1.35])
        ax = fig.add_subplot(gs[0, 0])
        ax_corr = None
        sp = fig.add_subplot(gs[0, 1])

    show_cube = full_cube if full_cube is not None else cube
    raw_img = np.sum(show_cube, axis=2)
    im = ax.imshow(raw_img, cmap=cmap, origin="upper", aspect="equal")
    ax.set_title("Raw sum image: click a pixel to inspect spectrum", pad=18)
    ax.set_xlabel("X"); ax.set_ylabel("Y")

    if spatial_roi is not None:
        y0, y1, x0, x1 = spatial_roi
        rect = Rectangle((x0, y0), max(1, x1 - x0), max(1, y1 - y0), fill=False, linewidth=1.8)
        ax.add_patch(rect)
        ax.text(
            0.02, 0.98, f"Analysis ROI x[{x0}:{x1}] y[{y0}:{y1}]",
            transform=ax.transAxes,
            fontsize=9, va="top", ha="left", clip_on=True,
            bbox=dict(facecolor="white", alpha=0.82, edgecolor="black", linewidth=0.3, pad=2.5),
        )

    if selected_pixel is not None:
        px, py = selected_pixel
        ax.plot([px], [py], marker="x", markersize=8, markeredgewidth=1.8)
        ax.text(
            0.02, 0.08, f"Selected pixel: x={px}, y={py}",
            transform=ax.transAxes,
            fontsize=9, va="bottom", ha="left", clip_on=True,
            bbox=dict(facecolor="white", alpha=0.82, edgecolor="black", linewidth=0.3, pad=2.5),
        )
    add_colorbar(fig, ax, im)

    if ax_corr is not None:
        corr_img = np.sum(corrected_full_cube, axis=2)
        im2 = ax_corr.imshow(corr_img, cmap=cmap, origin="upper", aspect="equal")
        ax_corr.set_title("Background-corrected raw image", pad=12)
        ax_corr.set_xlabel("X"); ax_corr.set_ylabel("Y")
        if spatial_roi is not None:
            y0, y1, x0, x1 = spatial_roi
            ax_corr.add_patch(Rectangle((x0, y0), max(1, x1 - x0), max(1, y1 - y0), fill=False, linewidth=1.8))
        if selected_pixel is not None:
            px, py = selected_pixel
            ax_corr.plot([px], [py], marker="x", markersize=8, markeredgewidth=1.8)
        add_colorbar(fig, ax_corr, im2)

    # Spectrum: single clicked pixel. If no pixel is selected yet, use the analysis-ROI mean
    # as a safe default and label it explicitly.
    src_raw = raw_roi_before_bg if raw_roi_before_bg is not None else cube
    src_corr = corrected_roi if corrected_roi is not None else cube
    if selected_pixel is not None:
        px, py = selected_pixel
        l0_len = src_corr.shape[-1]
        if full_cube is not None and 0 <= py < full_cube.shape[0] and 0 <= px < full_cube.shape[1]:
            # selected pixel in full-image coordinates; channel range is already matched to axis
            # by caller via current_channel_bounds.
            raw_spec = np.asarray(src_raw[py, px, :], dtype=np.float64) if src_raw.ndim == 3 and src_raw.shape[:2] == full_cube.shape[:2] else None
            corr_spec = np.asarray(src_corr[py, px, :], dtype=np.float64) if src_corr.ndim == 3 and src_corr.shape[:2] == full_cube.shape[:2] else None
        else:
            raw_spec = corr_spec = None
        if raw_spec is None:
            raw_spec, _ = roi_mean_std_spectrum(src_raw)
        if corr_spec is None:
            corr_spec, _ = roi_mean_std_spectrum(src_corr)
        spec_title = f"Single-pixel spectrum x={px}, y={py}"
    else:
        raw_spec, raw_std = roi_mean_std_spectrum(src_raw)
        corr_spec, corr_std = roi_mean_std_spectrum(src_corr)
        spec_title = "Analysis ROI mean spectrum (click image for one pixel)"

    x = axis.energy_axis if len(axis.energy_axis) == len(raw_spec) else np.arange(len(raw_spec))
    sp.plot(x, raw_spec, linewidth=1.4, label="raw pixel" if selected_pixel is not None else "ROI raw mean")
    if selected_pixel is None:
        sp.fill_between(x, raw_spec - raw_std, raw_spec + raw_std, alpha=0.16, label="ROI raw ±1σ")
    if bg_applied and corrected_roi is not None:
        bg_spec = raw_spec - corr_spec
        sp.plot(x, bg_spec, linewidth=1.2, label="estimated BG = raw - corrected")
        sp.plot(x, corr_spec, linewidth=1.5, label="raw - BG / corrected")
        if selected_pixel is None:
            sp.fill_between(x, corr_spec - corr_std, corr_spec + corr_std, alpha=0.12, label="corrected ±1σ")
    sp.set_title(spec_title)
    sp.set_xlabel(axis.energy_label); sp.set_ylabel("Intensity")
    sp.grid(True, alpha=.3); sp.legend(fontsize=8)
    fig.subplots_adjust(left=.055, right=.97, top=.93, bottom=.09, wspace=.34, hspace=.34)

