def _normalize_maps_for_composite(images, mode="percentile 99", eps=1e-12):
    arrs = [np.asarray(im, dtype=np.float64).copy() for im in (images or [])]
    if not arrs:
        return []
    mode = str(mode or "percentile 99").lower()
    if mode == "none":
        # Shift each map only if negative values exist so RGB compositing remains displayable.
        out=[]
        for a in arrs:
            b=a.copy()
            mn=float(np.nanmin(b)) if b.size else 0.0
            if mn < 0:
                b=b-mn
            mx=float(np.nanmax(b)) if b.size else 0.0
            out.append(b/(mx+eps) if mx>0 else b)
        return out
    if mode == "global max":
        g=max([float(np.nanmax(np.abs(a))) if a.size else 0.0 for a in arrs] + [0.0])
        return [np.clip((a if np.nanmin(a)>=0 else a-np.nanmin(a))/(g+eps),0,1) if g>0 else np.zeros_like(a) for a in arrs]
    out=[]
    for a in arrs:
        b=a.copy()
        mn=float(np.nanmin(b)) if b.size else 0.0
        if mn < 0:
            b=b-mn
        if mode == "each component max":
            mx=float(np.nanmax(b)) if b.size else 0.0
        else:
            mx=float(np.nanpercentile(b,99)) if b.size else 0.0
        out.append(np.clip(b/(mx+eps),0,1) if mx>0 else np.zeros_like(b))
    return out


def _component_colors(n):
    import matplotlib.cm as cm
    cmap = cm.get_cmap('tab20' if n <= 20 else 'hsv', max(n, 1))
    return [np.asarray(cmap(i)[:3], dtype=np.float64) for i in range(n)]


def make_component_composite(images, mode="sum weighted color", norm_mode="percentile 99"):
    norm = _normalize_maps_for_composite(images, norm_mode)
    if not norm:
        return None, [], []
    h,w = norm[0].shape
    n=len(norm)
    colors=_component_colors(n)
    mode=str(mode or "sum weighted color").lower()
    if mode == "max-color winner":
        stack=np.stack(norm,axis=0)
        idx=np.nanargmax(stack,axis=0)
        amp=np.nanmax(stack,axis=0)
        rgb=np.zeros((h,w,3),dtype=np.float64)
        for i,c in enumerate(colors):
            mask=(idx==i)
            rgb[mask]=amp[mask,None]*c.reshape(1,3)
        return np.clip(rgb,0,1), norm, colors
    rgb=np.zeros((h,w,3),dtype=np.float64)
    if mode == "rgb cycle":
        base=[np.array([1,0,0.0]),np.array([0,1,0.0]),np.array([0,0,1.0])]
        colors=[base[i%3] for i in range(n)]
    for a,c in zip(norm,colors):
        rgb += a[...,None]*c.reshape(1,1,3)
    mx=float(np.nanmax(rgb)) if rgb.size else 0.0
    if mx>1:
        rgb=rgb/mx
    return np.clip(rgb,0,1), norm, colors


