    def collect_residual_free_mergepass_sources(self):
        """Collect rr-NMF merge/pass spectra rebuilt without residual/r.

        These are interpretation sources only.  For every merge/pass group made from
        source depth D and stored under target key D+1, each output is rebuilt as
        sum(W_i H_i) from the selected source components.  No residual/r term is
        added, so the spectra correspond to the pure merged/pass component content.
        """
        out = []
        rr = getattr(self, "rr_result", None)
        groups_by_depth = getattr(self, "manual_depth_groups", {}) or {}
        if rr is None or not groups_by_depth:
            return out
        lookup = _entry_lookup_by_label(rr)
        for target_key, groups in sorted(groups_by_depth.items()):
            try:
                tk = int(target_key)
            except Exception:
                tk = target_key
            source_depth = int(tk) - 1 if isinstance(tk, int) else tk
            for idx, c in enumerate(groups or []):
                members = list(c.get("member_labels", c.get("members", [])) or [])
                entries = [lookup[m] for m in members if m in lookup]
                if not entries:
                    continue
                try:
                    ds = build_combined_dataset(entries, _short_set_label(c, idx), use_child_matrix=False)
                except Exception:
                    continue
                label = f"rr Merge/Pass no-R D{source_depth}->{tk} {idx + 1}: {_short_set_label(c, idx)}"
                out.append({
                    "label": label,
                    "spectrum": np.asarray(ds.get("spectrum"), dtype=np.float64),
                    "axis": self.roi_axis_info,
                    "image": ds.get("image", None),
                    "kind": "rr_mergepass_noR",
                    "pair_key": None,
                    "source_group": "rr-NMF (Depth Merge/Pass Results)",
                })
        return out

    def collect_spectrum_sources(self):
        sources = []
        if self.cube is not None:
            try:
                roi, Xraw, shape, axis = self.get_roi_cube_and_X()
                raw_img = np.sum(roi, axis=2)
                raw_spec = np.sum(roi, axis=(0, 1))
                sources.append({
                    "label": "Raw ROI Sum",
                    "spectrum": raw_spec,
                    "axis": axis,
                    "image": raw_img,
                    "kind": "raw",
                    "pair_key": None,
                })
            except Exception:
                Xraw = None
        else:
            Xraw = None

        if getattr(self, "X", None) is not None:
            X_for_weight = self.X
        else:
            try:
                _, X_for_weight, _, _ = self.get_roi_cube_and_X()
            except Exception:
                X_for_weight = None

        if self.rr_result is not None:
            for d, nodes in enumerate(self.rr_result.node_summaries_by_depth):
                for n, ns in enumerate(nodes):
                    for c, spec in enumerate(ns.component_spectra):
                        wmap = ns.component_maps[c]
                        pair_key = f"rr:{d}:{n}:{c}"
                        sources.append({
                            "label": f"rr D{d} N{n} H{c} (NMF basis)",
                            "spectrum": np.asarray(spec),
                            "axis": self.roi_axis_info,
                            "image": wmap,
                            "kind": "basis",
                            "source_group": "rr-NMF (Depth Results)",
                            "pair_key": pair_key,
                        })
                        if X_for_weight is not None:
                            sources.append({
                                "label": f"rr D{d} N{n} weighted raw by W{c}",
                                "spectrum": weighted_raw_spectrum_by_map(X_for_weight, wmap),
                                "axis": self.roi_axis_info,
                                "image": wmap,
                                "kind": "weighted",
                                "source_group": "rr-NMF (Depth Results)",
                                "pair_key": pair_key,
                            })

        if self.conv_result is not None:
            for c, spec in enumerate(self.conv_result.H_spectra):
                wmap = self.conv_result.W_images[c]
                pair_key = f"conv:{c}"
                sources.append({
                    "label": f"Conv H{c} (NMF basis)",
                    "spectrum": np.asarray(spec),
                    "axis": self.roi_axis_info,
                    "image": wmap,
                    "kind": "basis",
                    "source_group": "Conventional NMF",
                    "pair_key": pair_key,
                })
                if X_for_weight is not None:
                    sources.append({
                        "label": f"Conv weighted raw by W{c}",
                        "spectrum": weighted_raw_spectrum_by_map(X_for_weight, wmap),
                        "axis": self.roi_axis_info,
                        "image": wmap,
                        "kind": "weighted",
                        "source_group": "Conventional NMF",
                        "pair_key": pair_key,
                    })

        if self.pca_result is not None:
            for c, spec in enumerate(getattr(self.pca_result, "H_spectra", []) or []):
                wmap = self.pca_result.W_images[c] if c < len(getattr(self.pca_result, "W_images", []) or []) else None
                sources.append({
                    "label": f"PCA PC{c+1} loading",
                    "spectrum": np.asarray(spec),
                    "axis": self.roi_axis_info,
                    "image": wmap,
                    "kind": "pca",
                    "source_group": "PCA",
                    "pair_key": None,
                })

        # Residual-free merge/pass spectra are listed separately from ordinary rr-NMF depth results.
        # They are rebuilt as sum(W_i H_i), without residual/r, for cleaner EDS/EELS interpretation.
        sources.extend(self.collect_residual_free_mergepass_sources())
        # Saved decomposition results loaded from NPZ can be analyzed without rerunning NMF/PCA/rr-NMF.
        sources.extend(list(getattr(self, "loaded_decomp_sources", []) or []))
        return sources


    def _populate_spectrum_source_list(self, list_widget, sources):
        list_widget.clear()
        groups = [
            "Raw",
            "Conventional NMF",
            "PCA",
            "rr-NMF (Depth Results)",
            "rr-NMF (Depth Merge/Pass Results)",
            "Loaded Conventional NMF",
            "Loaded PCA",
            "Loaded rr-NMF Depth Results",
            "Loaded rr-NMF Merge/Pass no-R",
            "Loaded Saved Results",
        ]
        used = set()
        for group in groups:
            idxs = [i for i, s in enumerate(sources) if s.get("source_group", "Raw") == group]
            if not idxs:
                continue
            header = QListWidgetItem(f"--- {group} ---")
            header.setFlags(Qt.NoItemFlags)
            try:
                header.setForeground(Qt.darkBlue)
            except Exception:
                pass
            list_widget.addItem(header)
            for i in idxs:
                item = QListWidgetItem(sources[i]["label"])
                item.setData(Qt.UserRole, int(i))
                list_widget.addItem(item)
                used.add(i)
        other = [i for i in range(len(sources)) if i not in used]
        if other:
            header = QListWidgetItem("--- Other ---")
            header.setFlags(Qt.NoItemFlags)
            list_widget.addItem(header)
            for i in other:
                item = QListWidgetItem(sources[i]["label"])
                item.setData(Qt.UserRole, int(i))
                list_widget.addItem(item)

