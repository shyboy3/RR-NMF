def plot_rr(fig, rr, axis, cmap="viridis", X_for_weight=None, overlay_mode="max"):
    fig.clear()
    depths = rr.node_summaries_by_depth

    # Generalized layout for recursive rank >= 2.
    # Each node occupies "rank" columns:
    #   row 1: C0 ... C{rank-1} images
    #   row 2: H0 ... H{rank-1} spectra
    #   row 3: residual image spanning rank columns
    #   row 4: residual spectrum spanning rank columns
    rank = max(1, int(getattr(rr, "rank", 2)))
    cols_node = rank
    rows_node = 4

    # Keep the display reasonably wide without forcing too many nodes per row.
    # Examples:
    #   rank=2 -> 4 nodes/row => 8 component columns
    #   rank=3 -> 3 nodes/row => 9 component columns
    #   rank=4 -> 2 nodes/row => 8 component columns
    max_nodes = max(1, min(4, 10 // max(1, rank)))

    ratios = []
    starts = []
    cur = 0
    for d, nodes in enumerate(depths):
        wraps = max(1, int(np.ceil(max(1, len(nodes)) / max_nodes)))
        starts.append(cur)
        ratios.append(0.45)
        cur += 1
        for _ in range(wraps):
            ratios.extend([3.0, 1.0, 3.0, 1.0])
            cur += rows_node
        ratios.append(0.20)
        cur += 1

    total_cols = max_nodes * cols_node
    fig.set_size_inches(max(30.0, total_cols * 4.1), max(8, sum(ratios) * 1.55), forward=True)
    gs = fig.add_gridspec(cur, total_cols, height_ratios=ratios)

    def _short_text(txt, max_len=70):
        txt = str(txt).replace("\n", " ").strip()
        return txt if len(txt) <= max_len else txt[:max(0, max_len - 3)] + "..."

    def _combined_title(ns, base, max_name=42, max_members=78):
        """Return a title string. Combined-data nodes are always rendered as exactly 2 lines."""
        if not str(getattr(ns, "path", "")).startswith("manualD"):
            return base
        name = _short_text(str(getattr(ns, "combined_name", "") or "Combined"), max_name)
        members = list(getattr(ns, "combined_members", []) or [])
        if members:
            mtxt = ", ".join(map(str, members))
        else:
            mtxt = "selected previous-depth components"
        mtxt = _short_text(mtxt, max_members)
        return f"COMBINED DATA: {name} | {base}\nMerged: {mtxt}"

    for d, nodes in enumerate(depths):
        axd = fig.add_subplot(gs[starts[d], :])
        axd.axis("off")
        combined_count = sum(1 for _ns in nodes if str(getattr(_ns, "path", "")).startswith("manualD"))
        header = f"Depth {d}" + (f"   |   {combined_count} combined-data node(s)" if combined_count else "")
        axd.text(0, 0.5, header, fontweight="bold", fontsize=13, va="center")

        for i, ns in enumerate(nodes):
            wr = i // max_nodes
            wc = i % max_nodes
            br = starts[d] + 1 + wr * rows_node
            bc = wc * cols_node

            n_comp = len(ns.component_maps)
            for ci in range(n_comp):
                ax = fig.add_subplot(gs[br, bc + ci])
                sp = fig.add_subplot(gs[br + 1, bc + ci])
                wmap = ns.component_maps[ci]
                hspec = np.asarray(ns.component_spectra[ci])

                im = ax.imshow(wmap, cmap=cmap, origin="upper", aspect="equal")
                ax.set_title(_combined_title(ns, f"D{d} N{i} C{ci}"), fontsize=9)
                ax.set_xticks([])
                ax.set_yticks([])
                add_colorbar(fig, ax, im)

                x = axis.energy_axis if len(axis.energy_axis) == len(hspec) else np.arange(len(hspec))
                corr_txt = ""
                if X_for_weight is not None:
                    try:
                        wspec = weighted_raw_spectrum_by_map(X_for_weight, wmap)
                        corr = safe_shape_correlation(hspec, wspec, overlay_mode)
                        corr_txt = f", corr({overlay_mode})={corr:.3f}" if np.isfinite(corr) else ", corr=nan"
                        line1, = sp.plot(x, hspec, linewidth=1.0, label="H basis (left)")
                        sp2 = sp.twinx()
                        line2, = sp2.plot(x, wspec, linewidth=1.2, linestyle="-", color="red", label="weighted raw (right)")
                        # Keep the right axis attached to the spectrum axes; avoid outward offset.
                        sp.set_ylabel("H basis", fontsize=7)
                        sp2.set_ylabel("weighted raw", fontsize=7, labelpad=2)
                        sp2.tick_params(axis="y", labelsize=7, pad=2)
                        sp.legend([line1, line2], [line1.get_label(), line2.get_label()], fontsize=6, loc="best")
                    except Exception:
                        sp.plot(x, hspec, linewidth=1.0, label="H basis")
                        sp.legend(fontsize=6, loc="best")
                else:
                    sp.plot(x, hspec, linewidth=1.0, label="H basis")
                    sp.legend(fontsize=6, loc="best")

                sp.set_title(f"H{ci}{corr_txt}", fontsize=9)
                sp.set_xlabel(axis.energy_label, fontsize=8)
                sp.grid(True, alpha=0.25)
                sp.tick_params(labelsize=7)

            # If n_comp < rank for a degenerate node, leave the remaining slots blank.
            for ci in range(n_comp, rank):
                ax_blank = fig.add_subplot(gs[br, bc + ci])
                ax_blank.axis("off")
                sp_blank = fig.add_subplot(gs[br + 1, bc + ci])
                sp_blank.axis("off")

            if ns.residual_image is not None:
                # Display residual image as mean residual per spectral channel.
                L_res = len(ns.residual_spectrum) if ns.residual_spectrum is not None else 1
                rimg_mean = np.asarray(ns.residual_image, dtype=np.float64) / max(1, int(L_res))
                ax = fig.add_subplot(gs[br + 2, bc:bc + rank])
                im = ax.imshow(rimg_mean, cmap=cmap, origin="upper", aspect="equal")
                ax.set_title(_combined_title(ns, f"D{d} N{i} Residual mean"), fontsize=9)
                ax.set_xticks([])
                ax.set_yticks([])
                add_colorbar(fig, ax, im)

            if ns.residual_spectrum is not None:
                # Display residual spectrum as mean residual per spatial pixel.
                Npix = int(np.prod(ns.residual_image.shape)) if ns.residual_image is not None else 1
                rspec_mean = np.asarray(ns.residual_spectrum, dtype=np.float64) / max(1, Npix)
                x = axis.energy_axis if len(axis.energy_axis) == len(rspec_mean) else np.arange(len(rspec_mean))

                # Keep the residual spectrum half-width, but center it under the residual image.
