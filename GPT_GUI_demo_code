def collect_rr_component_entries(rr):
    out=[]
    if rr is None: return out
    for d,nodes in enumerate(rr.node_summaries_by_depth):
        for n,ns in enumerate(nodes):
            for c,(wm,hs) in enumerate(zip(ns.component_maps,ns.component_spectra)):
                out.append({"label":f"D{d} N{n} C{c}","W_map":wm,"H_spec":hs,"child_matrix": (ns.child_matrices[c] if c < len(getattr(ns, "child_matrices", [])) else None),"depth":d,"node_index":n,"component":c})
    return out


def build_combined_dataset(entries, name="", use_child_matrix=True):
    """Build a combined/pass-through dataset from selected rr-NMF components.

    use_child_matrix=True uses the exact next-depth child matrix W_i H_i + R/r
    when available.  For final displayed outputs after the last recursive depth,
    use_child_matrix=False so the final result is the selected W_i H_i signal
    itself, without adding another residual fraction.
    """
    if not entries: raise ValueError("No components selected")
    h,w=entries[0]["W_map"].shape; L=len(entries[0]["H_spec"])
    X=np.zeros((h*w,L),dtype=np.float32); labels=[]; used_child=False
    for e in entries:
        child = e.get("child_matrix", None) if use_child_matrix else None
        if child is not None:
            X += np.asarray(child, dtype=np.float32)
            used_child = True
        else:
            X += np.outer(e["W_map"].reshape(-1).astype(np.float32), e["H_spec"].astype(np.float32))
        labels.append(e["label"])
    return {"name":name or f"Combined {len(entries)} component(s)", "members":labels, "matrix":X, "image":np.sum(X,axis=1).reshape(h,w), "spectrum":np.sum(X,axis=0), "uses_child_matrix": used_child, "final_no_residual": (not use_child_matrix)}


