            mn,mx=float(np.nanmin(e)),float(np.nanmax(e)); pad=abs(mx-mn)*.1+1; self.bg_e0.setRange(mn-pad,mx+pad); self.bg_e1.setRange(mn-pad,mx+pad); end=max(3,int(l*.15)); self.bg_e0.setValue(float(e[0])); self.bg_e1.setValue(float(e[min(end,l)-1]))
        else:
