    def collect_params(self, include_manual=True, max_manual_depth=None):
        params={"run_conventional":self.chk_conv.isChecked(),"conv_components":self.spin_k.value(),"run_rr":self.chk_rr.isChecked(),"rr_rank":self.spin_rank.value(),"rr_depth":self.spin_depth.value(),"residual_mode":self.combo_res_mode.currentText(),"residual_nonnegative":self.combo_res_nn.currentText(),"decompose_residual_branch":self.chk_decomp_res.isChecked(),"max_iter":self.spin_iter.value(),"init":self.combo_init.currentText(),"solver":self.combo_solver.currentText(),"random_state":self.spin_seed.value(),"chunk_size":self.spin_chunk.value()}
        if include_manual and getattr(self,"chk_manual_depth",None) is not None and self.chk_manual_depth.isChecked():
            manual_groups={}
            group_dict=getattr(self,"manual_depth_groups",{}) or {}
            for md, sets in sorted(group_dict.items()):
                md_int=int(md)
                if max_manual_depth is not None and md_int > int(max_manual_depth):
                    continue
                valid=[]
                for i,c in enumerate(sets):
                    if "matrix" not in c:
                        continue
                    valid.append({"name":c.get("name",f"Merged D{md_int}.{i+1}"),"members":c.get("members",[]),"X":np.asarray(c["matrix"],dtype=np.float32)})
                if valid:
                    manual_groups[md_int]=valid
            if manual_groups:
                params["manual_groups"]=manual_groups
        return params

    def _current_manual_depth(self):
        return int(self.spin_manual_depth.value()) if hasattr(self,"spin_manual_depth") else 1

    def _active_manual_target_depth(self):
        """Return the current target depth in the repeated manual workflow.

        Manual start depth S means: merge depth S-1 components to create depth S,
        continue the analysis, then automatically expose depth S components to create
        depth S+1, and so on up to Recursive depth.
        """
        start = self._current_manual_depth()
        final = int(self.spin_depth.value()) if hasattr(self, "spin_depth") else start
        final = max(start, final)
        computed_max = -1
        if getattr(self, "rr_result", None) is not None:
            try:
                computed_max = len(self.rr_result.node_summaries_by_depth) - 1
            except Exception:
                computed_max = -1
        groups = getattr(self, "manual_depth_groups", {}) or {}
        for d in range(start, final + 1):
            sets = groups.get(d, []) or []
            source_depth = d - 1
            if computed_max < source_depth:
                return d
            # If a merge for this target already exists but has not yet been used to compute
            # this target depth, stay here so the user can add/delete more sets before continuing.
            if sets and computed_max <= source_depth:
                return d
            if not sets:
                return d
            # Otherwise this manual depth has already been used; advance to the next target.
        return final

    def _get_current_depth_sets(self):
        md=self._active_manual_target_depth()
        if not hasattr(self,"manual_depth_groups") or self.manual_depth_groups is None:
            self.manual_depth_groups={}
        return self.manual_depth_groups.setdefault(md, [])

    def _sync_current_combined_alias(self):
        self.rr_combined_sets=self._get_current_depth_sets()

    def _set_run_buttons_enabled(self, enabled: bool):
        for name in ("btn_run", "btn_run_conv_only", "btn_run_auto_stage", "btn_continue_manual", "btn_auto_score_step"):
            b = getattr(self, name, None)
            if b is not None:
                b.setEnabled(enabled)

    def run_auto_until_manual_depth(self):
        """Run rr-NMF only to the source depth for the currently selected manual merge.

        For manual target depth D, this computes only through D-1. Previously saved manual
        merges at depths < D are applied, so the D-1 candidates reflect earlier manual choices.
        """
        if not self.chk_manual_depth.isChecked():
            QMessageBox.warning(self, "Manual depth disabled", "Enable 'Manual depth workflow' first."); return
        md = self._active_manual_target_depth()
        stop_depth = max(0, md - 1)
        try: roi,X,shape,axis=self.get_roi_cube_and_X()
        except Exception as e: QMessageBox.warning(self,"ROI/Data error",str(e)); return
        self.roi_cube=roi; self.X=X; self.image_shape=shape; self.roi_axis_info=axis
        params=self.collect_params(include_manual=True, max_manual_depth=md-1)
        params["run_conventional"] = False
        params["run_rr"] = True
        params["rr_depth"] = stop_depth
        self._set_run_buttons_enabled(False)
        self.worker=AnalysisWorker(X,shape,params)
        self.worker.finished_ok.connect(self.on_analysis_finished)
        self.worker.failed.connect(self.on_analysis_failed)
        self.worker.start()
        lower=[d for d in sorted((getattr(self,"manual_depth_groups",{}) or {}).keys()) if int(d)<md and self.manual_depth_groups[d]]
        self.append_log(f"Manual step: running rr-NMF to source depth {stop_depth} for target depth {md}. Earlier manual merge depths used: {lower if lower else 'none'}. Select depth {stop_depth} components and create one or more merged sets for depth {md}.")

    def continue_from_manual_merge(self):
        """Advance exactly one manual target depth using the saved merge groups.

        Example: Recursive depth=4, Manual start depth=2.
        - First, run/refresh computes through D1 and exposes D1 components.
        - User creates merged set(s) for target D2.
        - This button computes only through D2 using those D2 merged nodes.
        - The panel then advances to target D3, where the user can merge D2 results.
        It does not jump directly to the final depth.
        """
        if not self.chk_manual_depth.isChecked():
            QMessageBox.warning(self, "Manual depth disabled", "Enable 'Manual depth workflow' first."); return
        self._sync_current_combined_alias()
        md = self._active_manual_target_depth()
        final_depth = int(self.spin_depth.value()) if hasattr(self, "spin_depth") else md
        if md > final_depth:
            QMessageBox.information(self, "Manual workflow complete", "The manual workflow has already reached the final recursive depth."); return
        sets = (getattr(self, "manual_depth_groups", {}) or {}).get(md, []) or []
        if not sets:
            QMessageBox.warning(self, "No merged sets", f"Create at least one merged set or pass-through set for target depth {md} before continuing."); return
        try: roi,X,shape,axis=self.get_roi_cube_and_X()
        except Exception as e: QMessageBox.warning(self,"ROI/Data error",str(e)); return
        self.roi_cube=roi; self.X=X; self.image_shape=shape; self.roi_axis_info=axis
        params=self.collect_params(include_manual=True, max_manual_depth=md)
        params["run_conventional"] = False
        params["run_rr"] = True
        params["rr_depth"] = md
        self._set_run_buttons_enabled(False)
        self.worker=AnalysisWorker(X,shape,params)
        self.worker.finished_ok.connect(self.on_analysis_finished)
        self.worker.failed.connect(self.on_analysis_failed)
        self.worker.start()
        summary=", ".join([f"D{d}:{len((getattr(self,'manual_depth_groups',{}) or {}).get(d,[]) or [])} set(s)" for d in range(self._current_manual_depth(), md+1) if (getattr(self,'manual_depth_groups',{}) or {}).get(d,[])])
        self.append_log(f"Manual continue: computing exactly to depth {md} using saved manual merge groups ({summary}). After completion, the panel will expose depth {md} components for target depth {md+1 if md < final_depth else 'final complete'}.")


    def _entries_for_depth(self, depth):
        return [e for e in collect_rr_component_entries(self.rr_result) if int(e.get("depth", -999)) == int(depth)]

    def _build_auto_score_sets_for_target(self, target_depth, final_no_residual=False):
        source_depth = int(target_depth) - 1
        entries = self._entries_for_depth(source_depth)
        if not entries:
            raise ValueError(f"No rr-NMF components found at source depth {source_depth}.")
        groups, pairs = auto_score_groups_from_entries(
            entries,
            corr_weight=self.spin_auto_corr_weight.value(),
            threshold_pct=self.spin_auto_score_thresh.value(),
            w_downsample_factor=self.spin_auto_w_downsample.value() if hasattr(self, "spin_auto_w_downsample") else 4,
        )
        sets=[]
        merged_count=0
        for gi, g in enumerate(groups):
            labels=[e.get("label", "") for e in g]
            if len(g) >= 2:
                name=f"AutoScore_D{target_depth}_G{gi+1}"
                merged_count += 1
                c=build_combined_dataset(g, name, use_child_matrix=(not final_no_residual))
                c["pass_through"] = False
            else:
                name=f"AutoPass_{labels[0].replace(' ', '_')}"
                c=build_combined_dataset(g, name, use_child_matrix=(not final_no_residual))
                c["pass_through"] = True
            c["target_depth"] = int(target_depth)
            c["auto_score"] = True
            c["final_no_residual"] = bool(final_no_residual)
            c["member_maps"] = [np.asarray(e.get("W_map"), dtype=np.float32).copy() for e in g if e.get("W_map") is not None]
            c["member_labels"] = labels
            # W-only provenance image.  Do not use c["image"] here because that is a
            # child-matrix summed-intensity image and can look different from the source
            # W map even for PASS data.
            c["provenance_image"] = combine_w_maps_for_provenance(g)
            c["auto_pair_details"] = [r for r in pairs if r.get("label_i") in labels and r.get("label_j") in labels]
            c["auto_pair_stats"] = _auto_pair_stats_for_labels(pairs, labels)
            sets.append(c)
        self.manual_depth_groups[int(target_depth)] = sets

        # Data-count based stopping should compare the number of datasets that entered
        # the current source depth with the number of datasets generated for the next
        # target depth. This is different from len(entries), which is the number of
        # source-depth NMF components (= source datasets * rank).
        if source_depth in getattr(self, "manual_depth_groups", {}):
            source_data_count = len(self.manual_depth_groups.get(source_depth, []))
        else:
            try:
                source_data_count = len(self.rr_result.node_summaries_by_depth[source_depth])
            except Exception:
                source_data_count = 0

        best_pairs=sorted(pairs, key=lambda r: r.get("score",0.0), reverse=True)[:8]
        pair_txt="; ".join([f"{r['label_i']}+{r['label_j']}: score={100*r['score']:.1f}% WdownCorr={100*r.get('w_corr_down', np.nan):.1f}% Hcorr={100*r.get('h_corr', r.get('corr', np.nan)):.1f}%" for r in best_pairs])
        w_downsample_val = self.spin_auto_w_downsample.value() if hasattr(self, "spin_auto_w_downsample") else 4
        self.append_log(
            f"Auto score grouping for target D{target_depth} from source D{source_depth}: "
            f"{len(entries)} source components from {source_data_count} source dataset(s) -> "
            f"{len(sets)} next-depth dataset(s), merged_groups={merged_count}, "
            f"threshold={self.spin_auto_score_thresh.value():.1f}%, "
            f"a={self.spin_auto_corr_weight.value():.3f}, "
            f"h_corr_weight={1.0-self.spin_auto_corr_weight.value():.3f}, "
            f"W_downsample={w_downsample_val}"
        )
        if pair_txt:
            self.append_log("Top auto-score pairs (Score / W-downCorr / H-corr): " + pair_txt)
        return source_data_count, len(entries), len(sets), merged_count

    def _ensure_final_auto_output_sets(self, final_depth):
        """Build final merge/pass output sets from the final displayed depth for provenance only.

        Recursive depth N means D0..DN are NMF results.  The final user-facing
        result after Auto-Step is the merge/pass output made from DN, even though
        it is not decomposed further.  Store those output sets at key N+1 so the
        Auto Merge W Tree can show D(N) final merge/pass results.
        """
        try:
            final_depth = int(final_depth)
            key = final_depth + 1
            existing = getattr(self, "manual_depth_groups", {}).get(key, None)
            if existing and all(bool(c.get("final_no_residual", False)) for c in existing):
                return
            if existing:
                self.manual_depth_groups.pop(key, None)
            if self.rr_result is None or len(self.rr_result.node_summaries_by_depth) - 1 < final_depth:
                return
            self._build_auto_score_sets_for_target(key, final_no_residual=True)
            self.append_log(f"Built final Auto-Step merge/pass output from D{final_depth} for display only; no D{key} NMF is run; residual/r is not added to final outputs.")
        except Exception:
            self.append_log("Final Auto-Step output build failed:\n" + traceback.format_exc())

    def start_auto_score_merge_workflow(self):
        """Automatically create merge/pass sets using Score=a*W-downsample-corr+(1-a)*H-corr, then advance depth by depth."""
        if self.cube is None:
            QMessageBox.warning(self, "No data", "Load data first."); return
        try:
            roi,X,shape,axis=self.get_roi_cube_and_X()
        except Exception as e:
            QMessageBox.warning(self,"ROI/Data error",str(e)); return
        self.roi_cube=roi; self.X=X; self.image_shape=shape; self.roi_axis_info=axis
        self.chk_manual_depth.setChecked(True)
        start=int(self.spin_manual_depth.value())
        final=int(self.spin_depth.value())
        if start < 1 or start > final:
            QMessageBox.warning(self,"Auto score depth error",f"Manual start depth must be between 1 and Recursive depth ({final})."); return
        # Fresh auto run from the selected start depth: keep earlier groups below start if user made them,
        # but replace all groups from start onward.
        self.manual_depth_groups={int(d):v for d,v in (getattr(self,"manual_depth_groups",{}) or {}).items() if int(d) < start}
        self._auto_score_active=True
        self._auto_score_target_depth=start
        self._auto_score_stop_after_current=False
        self._auto_score_unchanged_count=0
        self.append_log(f"Auto score workflow started: start D{start}, final D{final}, score=a*W-downCorr+(1-a)*H-corr, threshold={self.spin_auto_score_thresh.value():.1f}%.")
        # First compute to the source depth of the start target.
        params=self.collect_params(include_manual=True, max_manual_depth=start-1)
        params["run_conventional"] = False
        params["run_rr"] = True
        params["rr_depth"] = start - 1
        self._set_run_buttons_enabled(False)
        self.worker=AnalysisWorker(X,shape,params)
        self.worker.finished_ok.connect(self.on_analysis_finished)
        self.worker.failed.connect(self.on_analysis_failed)
        self.worker.start()

    def _continue_auto_score_after_worker(self):
        if not getattr(self, "_auto_score_active", False):
            return
        try:
            final=int(self.spin_depth.value())
            target=int(self._auto_score_target_depth or self.spin_manual_depth.value())
            if target > final:
                self._ensure_final_auto_output_sets(final)
                self._auto_score_active=False
                self.append_log("Auto score workflow complete: reached final recursive depth.")
                self.refresh_rr_component_list()
                return
            computed_max=len(self.rr_result.node_summaries_by_depth)-1 if self.rr_result is not None else -1
            # If we have just computed target depth, decide whether to advance or stop.
            if computed_max >= target:
                if self._auto_score_stop_after_current:
                    self._ensure_final_auto_output_sets(target)
                    self._auto_score_active=False
                    self.append_log(
                        f"Auto score workflow stopped after D{target}: "
                        "unchanged dataset-count patience reached. Final merge/pass output from the stopped depth was built for display only."
                    )
                    self.refresh_rr_component_list()
                    return
                self._auto_score_target_depth=target+1
                target=int(self._auto_score_target_depth)
                if target > final:
                    self._ensure_final_auto_output_sets(final)
                    self._auto_score_active=False
                    self.append_log("Auto score workflow complete: reached final recursive depth.")
                    self.refresh_rr_component_list()
                    return
            source_depth=target-1
            computed_max=len(self.rr_result.node_summaries_by_depth)-1 if self.rr_result is not None else -1
            if computed_max < source_depth:
                # Need to refresh/run to the required source depth first.
                roi,X,shape,axis=self.get_roi_cube_and_X()
                params=self.collect_params(include_manual=True, max_manual_depth=target-1)
                params["run_conventional"] = False
                params["run_rr"] = True
                params["rr_depth"] = source_depth
                self._set_run_buttons_enabled(False)
                self.worker=AnalysisWorker(X,shape,params)
                self.worker.finished_ok.connect(self.on_analysis_finished)
                self.worker.failed.connect(self.on_analysis_failed)
                self.worker.start()
                return
            source_data_count, source_component_count, output_count, merged_count = self._build_auto_score_sets_for_target(target)
            self._sync_current_combined_alias()
            self.refresh_rr_component_list()
            # Stop criterion requested for D>=3 with patience:
            # compare DATASET counts, not component counts. If the next-depth dataset count
            # is unchanged for N consecutive depth steps, stop after computing the current target.
            if target >= 3 and output_count == source_data_count:
                self._auto_score_unchanged_count = int(getattr(self, "_auto_score_unchanged_count", 0)) + 1
            else:
                self._auto_score_unchanged_count = 0
            patience = int(self.spin_auto_patience.value()) if hasattr(self, "spin_auto_patience") else 2
            self._auto_score_stop_after_current = (target >= 3 and self._auto_score_unchanged_count >= patience)
            if self._auto_score_stop_after_current:
                self.append_log(f"Auto score stop scheduled after D{target}: dataset count unchanged for {self._auto_score_unchanged_count}/{patience} consecutive step(s) ({source_data_count} -> {output_count}).")
            elif target >= 3 and output_count == source_data_count:
                self.append_log(f"Auto score unchanged-count patience: {self._auto_score_unchanged_count}/{patience} consecutive step(s) ({source_data_count} -> {output_count}); continuing.")
            roi,X,shape,axis=self.get_roi_cube_and_X()
            params=self.collect_params(include_manual=True, max_manual_depth=target)
            params["run_conventional"] = False
            params["run_rr"] = True
            params["rr_depth"] = target
            self._set_run_buttons_enabled(False)
            self.worker=AnalysisWorker(X,shape,params)
            self.worker.finished_ok.connect(self.on_analysis_finished)
            self.worker.failed.connect(self.on_analysis_failed)
            self.worker.start()
        except Exception as e:
            self._auto_score_active=False
            self._set_run_buttons_enabled(True)
            QMessageBox.critical(self,"Auto score workflow failed",str(e))
            self.append_log(traceback.format_exc())

