    def _full_mapping_items(self):
        method = self.combo_map_method.currentText() if hasattr(self,"combo_map_method") else "Conventional NMF"
        items=[]
        if method == "Conventional NMF":
            conv=getattr(self,"conv_result",None)
            if conv is not None:
                for i,(im,sp) in enumerate(zip(getattr(conv,"W_images",[]) or [], getattr(conv,"H_spectra",[]) or [])):
                    items.append({"label":f"Conv C{i}","image":np.asarray(im),"spectrum":np.asarray(sp)})
        elif method == "PCA":
            pca=getattr(self,"pca_result",None)
            if pca is not None:
                clip=bool(self.chk_map_pca_clip.isChecked()) if hasattr(self,"chk_map_pca_clip") else False
                for i,(im,sp) in enumerate(zip(getattr(pca,"W_images",[]) or [], getattr(pca,"H_spectra",[]) or [])):
                    arr=np.asarray(im,dtype=np.float64).copy()
                    if clip:
                        arr=np.maximum(arr,0.0)
                    items.append({"label":f"PCA PC{i+1}","image":arr,"spectrum":np.asarray(sp)})
        else:
            rr=getattr(self,"rr_result",None)
            if rr is not None:
                depth=int(self.combo_map_depth.currentData()) if hasattr(self,"combo_map_depth") and self.combo_map_depth.currentData() is not None else 0
                target_key=depth+1
                groups=(getattr(self,"manual_depth_groups",{}) or {}).get(target_key,[]) or []
                lookup=_entry_lookup_by_label(rr)
                tmp=[]
                for idx,c in enumerate(groups):
                    members=list(c.get("member_labels", c.get("members", [])) or [])
                    entries=[lookup[m] for m in members if m in lookup]
                    if not entries:
                        continue
                    try:
                        ds=build_combined_dataset(entries,_short_set_label(c,idx),use_child_matrix=False)
                        mat=np.asarray(ds.get("matrix"),dtype=np.float32)
                        energy=float(np.nansum(mat*mat,dtype=np.float64)) if mat.size else 0.0
                        tmp.append((energy,{"label":_short_set_label(c,idx),"image":np.asarray(ds["image"]),"spectrum":np.asarray(ds["spectrum"])}))
                    except Exception:
                        continue
                tmp.sort(key=lambda t:t[0], reverse=True)
                items=[t[1] for t in tmp]
                if not items and depth < len(getattr(rr,"node_summaries_by_depth",[]) or []):
                    # Fallback: show direct depth results if merge/pass outputs are not available.
                    for n,ns in enumerate(rr.node_summaries_by_depth[depth]):
                        for c,(im,sp) in enumerate(zip(ns.component_maps, ns.component_spectra)):
                            items.append({"label":f"D{depth} N{n} C{c}","image":np.asarray(im),"spectrum":np.asarray(sp)})
        return items

