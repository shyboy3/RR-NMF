            "EDS Analysis: " + src["label"], "Energy (keV)",
            self.combo_eds_norm.currentText(),
            source_image=src.get("image", None),
            cmap=self.combo_cmap.currentText(),
            matched_markers=matched_markers,
            detected_features=detected,
        )
        self.canvas_eds.set_base()
        self.canvas_eds.draw()
        self.eds_hits = hits
        self.dataframe_to_table(pd.DataFrame(hits), self.table_eds)

    def run_eels_analysis(self):
        row = self.list_eels_src.currentRow()
        if row < 0 or row >= len(self.sources):
            QMessageBox.warning(self, "No spectrum", "Select a spectrum source.")
            return

        groups = [i.text() for i in self.list_eels_groups.selectedItems()] or ["All"]
        elements = list(getattr(self, "eels_elements", []))

        src = self.sources[row]
        spec = np.asarray(src["spectrum"], dtype=np.float64)
        x = energy_axis_as_eV(src["axis"], len(spec))
        features = detect_simple_peaks(x, spec, self.spin_eels_prom.value(), self.spin_eels_dist.value())
        hits = match_eels_edges_to_features(features, self.spin_eels_tol.value(), groups, elements)

        selected_edge = self.combo_eels_edge.currentText() if hasattr(self, "combo_eels_edge") else None
        display_mode = self.combo_eels_line_display.currentText() if hasattr(self, "combo_eels_line_display") else "Selected elements/groups"
        xmin = float(np.nanmin(x)) if x.size else 0.0
        xmax = float(np.nanmax(x)) if x.size else 0.0

        candidate_markers = build_eels_candidate_markers(
            groups, elements, xmin, xmax,
            selected_edge=selected_edge,
            display_mode=display_mode,
        )
        matched_markers = []
        if display_mode in ["Matched edges only", "Selected elements/groups", "All candidate edges in current energy range"]:
            matched_markers = [(float(r["edge_eV"]), str(r["edge"])) for r in hits]
        detected = [float(ft["energy"]) for ft in features]

        rows = list(hits)

        if getattr(self, "combo_eels_mode", None) is not None and self.combo_eels_mode.currentText() == "Edge analysis" and selected_edge:
            edge_e = float(EELS_EDGE_DB[selected_edge]["energy_eV"])
            # If the user has not filled ranges, make a conservative default around the selected edge.
            pre0 = self.spin_eels_pre0.value()
            pre1 = self.spin_eels_pre1.value()
            int0 = self.spin_eels_int0.value()
            int1 = self.spin_eels_int1.value()
            if pre1 <= pre0:
                pre0 = edge_e - 40.0
                pre1 = edge_e - 5.0
            if int1 <= int0:
                int0 = edge_e
                int1 = edge_e + 50.0

            analysis_row = eels_edge_analysis_for_spectrum(x, spec, selected_edge, pre0, pre1, int0, int1)
            rows = [analysis_row] + rows

            if display_mode == "Selected edge only":
                candidate_markers = [(edge_e, selected_edge)]

        compare_mode = self.combo_eels_compare.currentText() if hasattr(self, "combo_eels_compare") else "Single spectrum"
        if compare_mode == "Basis vs weighted raw stacked" and src.get("pair_key") is not None:
            basis = self.find_paired_source(src, "basis")
            weighted = self.find_paired_source(src, "weighted")
            if basis is not None and weighted is not None:
                bspec = np.asarray(basis["spectrum"], dtype=np.float64)
                wspec = np.asarray(weighted["spectrum"], dtype=np.float64)
                plot_stacked_basis_weighted(
                    self.canvas_eels.fig,
                    x,
                    bspec,
                    wspec,
                    basis["label"],
                    weighted["label"],
                    candidate_markers,
                    matched_markers,
                    "Energy (eV)",
                    norm=self.combo_eels_norm.currentText(),
                    source_image=src.get("image", None),
                    cmap=self.combo_cmap.currentText(),
                    detected_features=detected,
                )
            else:
                plot_interpretation(
                    self.canvas_eels.fig, x, spec, candidate_markers,
                    "EELS Interpretation: " + src["label"], "Energy (eV)",
                    self.combo_eels_norm.currentText(),
                    source_image=src.get("image", None),
                    cmap=self.combo_cmap.currentText(),
                    matched_markers=matched_markers,
                    detected_features=detected,
                )
        else:
            plot_interpretation(
                self.canvas_eels.fig, x, spec, candidate_markers,
                "EELS Interpretation: " + src["label"], "Energy (eV)",
                self.combo_eels_norm.currentText(),
                source_image=src.get("image", None),
                cmap=self.combo_cmap.currentText(),
                matched_markers=matched_markers,
                detected_features=detected,
            )

        self.canvas_eels.set_base()
        self.canvas_eels.draw()
        self.eels_hits = rows
        self.dataframe_to_table(pd.DataFrame(rows), self.table_eels)


    def dataframe_to_table(self,df,table,max_rows=2000):
        if df is None or df.empty: table.clear(); table.setRowCount(0); table.setColumnCount(0); return
        df=df.head(max_rows); table.setRowCount(len(df)); table.setColumnCount(len(df.columns)); table.setHorizontalHeaderLabels([str(c) for c in df.columns])
        for r in range(len(df)):
            for c,col in enumerate(df.columns):
                v=df.iloc[r,c]; table.setItem(r,c,QTableWidgetItem(f"{v:.6g}" if isinstance(v,float) else str(v)))
        table.resizeColumnsToContents()

    def refresh_tables(self):
        dfs=[]
        if self.conv_result is not None: dfs.append(self.conv_result.energy_records)
        if self.rr_result is not None: dfs.append(self.rr_result.energy_records)
        self.dataframe_to_table(pd.concat(dfs,ignore_index=True) if dfs else pd.DataFrame(),self.table_energy)
        self.dataframe_to_table(self.rr_result.node_records if self.rr_result is not None else pd.DataFrame(),self.table_nodes)

    def export_csv(self):
        out=QFileDialog.getExistingDirectory(self,"Select output directory")
        if not out: return
        if self.conv_result is not None: self.conv_result.energy_records.to_csv(os.path.join(out,"conventional_nmf_energy.csv"),index=False)
        if self.rr_result is not None:
            self.rr_result.energy_records.to_csv(os.path.join(out,"rr_nmf_energy.csv"),index=False)
            self.rr_result.node_records.to_csv(os.path.join(out,"rr_nmf_nodes.csv"),index=False)
        if self.eds_hits: pd.DataFrame(self.eds_hits).to_csv(os.path.join(out,"eds_line_matches.csv"),index=False)
        if self.eels_hits: pd.DataFrame(self.eels_hits).to_csv(os.path.join(out,"eels_edge_matches.csv"),index=False)
        self.append_log(f"CSV exported to {out}")


def main():
    app=QApplication(sys.argv)
    w=RR2NMFGui()
    w.show()
    sys.exit(app.exec_())


if __name__ == "__main__":
    main()
