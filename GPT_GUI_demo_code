def _draw_edge_analysis_windows(ax, edge_windows, ymin, span, fontsize=9):
    """Draw EELS edge-analysis windows on a spectrum axis.

    pre-edge windows are blue; integration windows are orange; selected edge
    onsets are red.  These overlays are intentionally limited to user-selected
    edges, not all database candidates.
    """
    if not edge_windows:
        return
    y_text = ymin + 0.96 * span
    for win in edge_windows:
        try:
            edge = str(win.get("edge", "edge"))
            edge_e = float(win.get("edge_eV", float("nan")))
            pre0, pre1 = float(win.get("pre0")), float(win.get("pre1"))
            int0, int1 = float(win.get("int0")), float(win.get("int1"))
        except Exception:
            continue
        if pre1 > pre0:
            ax.axvspan(pre0, pre1, color="#1f77b4", alpha=0.10, lw=0)
            ax.text((pre0 + pre1) / 2.0, ymin + 0.10 * span, f"{edge} pre", ha="center", va="bottom", fontsize=max(6, fontsize-2), color="#1f77b4")
        if int1 > int0:
            ax.axvspan(int0, int1, color="#ff7f0e", alpha=0.13, lw=0)
            ax.text((int0 + int1) / 2.0, ymin + 0.18 * span, f"{edge} int", ha="center", va="bottom", fontsize=max(6, fontsize-2), color="#b85c00")
        if edge_e == edge_e:
            ax.axvline(edge_e, lw=1.9, alpha=0.90, color="#d62728")
            ax.text(edge_e, y_text, edge, rotation=90, fontsize=fontsize, color="#d62728", va="top", ha="center")

