class MplCanvas(FigureCanvas):
    def __init__(self, width=8, height=6, dpi=100):
        self.fig = Figure(figsize=(width, height), dpi=dpi)
        super().__init__(self.fig)

    def clear(self):
        self.fig.clear()
        self.draw()


def plot_w_h_gallery(fig: Figure, W_images: List[np.ndarray], H_spectra: List[np.ndarray], title: str = "Gallery", max_items: int = 40):
    fig.clear()
    n = min(len(W_images), len(H_spectra), max_items)
    if n == 0:
        ax = fig.add_subplot(111)
        ax.text(0.5, 0.5, "No data", ha="center", va="center")
        ax.axis("off")
        fig.tight_layout()
        return

    rows = n
    cols = 2
    for i in range(n):
        ax_w = fig.add_subplot(rows, cols, i * 2 + 1)
        ax_h = fig.add_subplot(rows, cols, i * 2 + 2)
        ax_w.imshow(W_images[i], aspect="auto")
        ax_w.set_title("C%d W" % i, fontsize=8)
        ax_w.axis("off")
        ax_h.plot(H_spectra[i])
        ax_h.set_title("C%d H" % i, fontsize=8)
        ax_h.set_xticks([])
        ax_h.set_yticks([])
    fig.suptitle(title)
    fig.tight_layout()


def plot_tree_with_H_and_edges(fig: Figure, rr: RRNMFResult, max_depth: Optional[int] = None, max_width_nodes: int = 64):
    fig.clear()
    W_images_by_depth = rr.W_images_by_depth
    H_spectra_by_depth = rr.H_spectra_by_depth
    errors_by_depth = rr.errors_by_depth

    num_depths = len(W_images_by_depth)
    if max_depth is not None:
        num_depths = min(num_depths, max_depth + 1)
    if num_depths <= 0:
        ax = fig.add_subplot(111)
        ax.text(0.5, 0.5, "No recursive result", ha="center", va="center")
        ax.axis("off")
        fig.tight_layout()
        return

    last_count = max(1, min(len(W_images_by_depth[num_depths - 1]), max_width_nodes))
    total_cols = max(2, last_count * 2)

    axes = np.empty((num_depths, total_cols), dtype=object)
    for d in range(num_depths):
        for c in range(total_cols):
            axes[d, c] = fig.add_subplot(num_depths, total_cols, d * total_cols + c + 1)
            axes[d, c].axis("off")

    node_positions: Dict[Tuple[int, int], int] = {}
    for d in range(num_depths):
        n = min(len(W_images_by_depth[d]), len(H_spectra_by_depth[d]), max_width_nodes)
        if n <= 0:
            continue
        interval = max(1, total_cols // n)
        for i in range(n):
            center = i * interval + interval // 2
            w_col = max(0, min(total_cols - 2, center - 1))
            h_col = w_col + 1
            node_positions[(d, i)] = w_col

            ax_w = axes[d, w_col]
            ax_h = axes[d, h_col]
            ax_w.clear()
            ax_h.clear()
            ax_w.imshow(W_images_by_depth[d][i], aspect="auto")
            err_txt = ""
            if d < len(errors_by_depth) and i < len(errors_by_depth[d]):
                err_txt = "\nErr=%.3g" % errors_by_depth[d][i]
            ax_w.set_title("D%d-C%d%s" % (d, i, err_txt), fontsize=7)
            ax_w.axis("off")
            ax_h.plot(H_spectra_by_depth[d][i])
            ax_h.set_title("H", fontsize=7)
            ax_h.set_xticks([])
            ax_h.set_yticks([])

    for d in range(1, num_depths):
        n = min(len(W_images_by_depth[d]), max_width_nodes)
        parent_n = max(1, len(W_images_by_depth[d - 1]))
        branch_factor = max(1, int(round(float(n) / float(parent_n)))) if parent_n > 0 else 1
        for i in range(n):
            parent_i = i // max(1, branch_factor)
            if (d - 1, parent_i) in node_positions and (d, i) in node_positions:
                pcol = node_positions[(d - 1, parent_i)]
                ccol = node_positions[(d, i)]
                con = ConnectionPatch(
                    xyA=(0.5, 1.0), coordsA=axes[d, ccol].transAxes,
                    xyB=(0.5, 0.0), coordsB=axes[d - 1, pcol].transAxes,
                    arrowstyle="-", color="gray", linewidth=0.8,
                )
                fig.add_artist(con)

    fig.suptitle("Recursive NMF Tree: W image + H spectrum", fontsize=12)
    fig.tight_layout()


def plot_energy_summary(fig: Figure, conv: Optional[ConventionalNMFResult], rr: Optional[RRNMFResult]):
    fig.clear()
    ax1 = fig.add_subplot(221)
    ax2 = fig.add_subplot(222)
    ax3 = fig.add_subplot(223)
    ax4 = fig.add_subplot(224)

    if conv is not None:
        df = conv.energy_records
        comp = df[df["type"] == "component"].copy()
        ax1.bar(range(len(comp)), comp["global_ratio"].values)
        ax1.set_title("Conventional NMF component global ratio")
        ax1.set_xlabel("Component")
        ax1.set_ylabel("Energy / E(X)")

        ax2.imshow(conv.h_corr, aspect="auto", vmin=-1, vmax=1)
        ax2.set_title("Conventional NMF H correlation")

    if rr is not None and not rr.energy_records.empty:
        df = rr.energy_records
        comp = df[df["type"] == "component"].copy()
        if not comp.empty:
            grouped = comp.groupby("depth")["global_ratio"].sum()
            ax3.bar(grouped.index.astype(int), grouped.values)
            ax3.set_title("rr-NMF component energy by depth")
            ax3.set_xlabel("Depth")
            ax3.set_ylabel("Sum global ratio")

        res = df[df["type"] == "residual"].copy()
        if not res.empty:
            grouped_r = res.groupby("depth")["node_ratio"].mean()
            ax4.plot(grouped_r.index.astype(int), grouped_r.values, marker="o")
            ax4.set_title("Mean residual ratio by depth")
            ax4.set_xlabel("Depth")
            ax4.set_ylabel("Mean E(R)/E(node)")

    fig.tight_layout()


