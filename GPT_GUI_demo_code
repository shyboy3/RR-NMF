def safe_pearson_1d(a, b, eps=1e-12):
    """Bias/intensity-insensitive Pearson correlation for shape comparison."""
    a = np.asarray(a, dtype=np.float64).reshape(-1)
    b = np.asarray(b, dtype=np.float64).reshape(-1)
    m = np.isfinite(a) & np.isfinite(b)
    if np.count_nonzero(m) < 3:
        return np.nan
    aa = a[m] - np.nanmean(a[m])
    bb = b[m] - np.nanmean(b[m])
    den = float(np.sqrt(np.sum(aa * aa) * np.sum(bb * bb)))
    return float(np.sum(aa * bb) / den) if den > eps else np.nan


def compute_w_morphology_corr_for_depth(nodes, nonnegative_display=True):
    """Return labels and a morphology-only W-map correlation matrix for all components in a depth.

    Internally this is Pearson correlation after mean-centering W maps, so the raw
    signed value can be negative when two nonnegative maps are spatially anti-correlated.
    For the Tree display, nonnegative_display=True clips negative values to zero because
    the diagnostic is intended as a co-localization/similarity map rather than a signed
    anti-correlation map.
    """
    labels, maps = [], []
    for ni, ns in enumerate(nodes or []):
        for ci, wm in enumerate(getattr(ns, "component_maps", []) or []):
            labels.append(f"N{ni}C{ci}")
            maps.append(np.asarray(wm, dtype=np.float64).reshape(-1))
    n = len(maps)
    if n == 0:
        return labels, np.zeros((0, 0), dtype=np.float64)
    C = np.eye(n, dtype=np.float64)
    for i in range(n):
        for j in range(i + 1, n):
            c = safe_pearson_1d(maps[i], maps[j])
            C[i, j] = C[j, i] = c if np.isfinite(c) else 0.0
    if nonnegative_display:
        C = np.clip(C, 0.0, 1.0)
    return labels, C





def ssim_similarity_from_maps(a, b, eps=1e-12):
    """Global SSIM-like morphology similarity for W maps, returned as 0..1.

    The maps are min-max normalized before SSIM so absolute intensity scale is suppressed,
    while spatial structure, contrast and local/background occupancy still contribute.
    This is a compact dependency-free SSIM score for merge guidance.
    """
    aa = np.asarray(a, dtype=np.float64)
    bb = np.asarray(b, dtype=np.float64)
    if aa.shape != bb.shape:
        aa = aa.reshape(-1)
        bb = bb.reshape(-1)
    m = np.isfinite(aa) & np.isfinite(bb)
    if np.count_nonzero(m) < 3:
        return 0.0
    x = aa[m].astype(np.float64)
    y = bb[m].astype(np.float64)
    xr = float(np.nanmax(x) - np.nanmin(x))
    yr = float(np.nanmax(y) - np.nanmin(y))
    if xr > eps:
        x = (x - np.nanmin(x)) / xr
    else:
        x = np.zeros_like(x)
    if yr > eps:
        y = (y - np.nanmin(y)) / yr
    else:
        y = np.zeros_like(y)
    mux, muy = float(np.mean(x)), float(np.mean(y))
    vx = float(np.mean((x - mux) ** 2))
    vy = float(np.mean((y - muy) ** 2))
    cov = float(np.mean((x - mux) * (y - muy)))
    C1 = 0.01 ** 2
    C2 = 0.03 ** 2
    den = (mux * mux + muy * muy + C1) * (vx + vy + C2)
    if abs(den) <= eps:
        return 0.0
    val = ((2.0 * mux * muy + C1) * (2.0 * cov + C2)) / den
    return float(np.clip(val, 0.0, 1.0))


def compute_w_morphology_ssim_for_depth(nodes):
    """Return labels and a W-map SSIM similarity matrix in 0..1 for all components in a depth."""
    labels, maps = [], []
    for ni, ns in enumerate(nodes or []):
        for ci, wm in enumerate(getattr(ns, "component_maps", []) or []):
            labels.append(f"N{ni}C{ci}")
            maps.append(np.asarray(wm, dtype=np.float64))
    n = len(maps)
    if n == 0:
        return labels, np.zeros((0, 0), dtype=np.float64)
    S = np.eye(n, dtype=np.float64)
    for i in range(n):
        for j in range(i + 1, n):
            v = ssim_similarity_from_maps(maps[i], maps[j])
            S[i, j] = S[j, i] = v
    return labels, np.clip(S, 0.0, 1.0)


