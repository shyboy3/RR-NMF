class AnalysisWorker(QThread):
    finished_ok = pyqtSignal(object, object, str)
    failed = pyqtSignal(str)

    def __init__(self, X: np.ndarray, image_shape: Tuple[int, int], params: Dict[str, Any]):
        super().__init__()
        self.X = X
        self.image_shape = image_shape
        self.params = params

    def run(self):
        try:
            conv_result = None
            rr_result = None
            logs = []
            if self.params.get("run_conventional", True):
                logs.append("Running conventional NMF...")
                conv_result = run_conventional_nmf(
                    self.X, self.image_shape,
                    n_components=int(self.params["conv_components"]),
                    max_iter=int(self.params["max_iter"]),
                    init=self.params["init"], solver=self.params["solver"],
                    random_state=int(self.params["random_state"]),
                    chunk_size=int(self.params["chunk_size"]),
                )
                logs.append("Conventional NMF recon ratio: %.6f" % conv_result.recon_ratio)
            if self.params.get("run_rr", True):
                logs.append("Running recursive NMF...")
                rr_result = run_rr_nmf(
                    self.X, self.image_shape,
                    rank=int(self.params["rr_rank"]),
                    max_depth=int(self.params["rr_depth"]),
                    residual_mode=self.params["residual_mode"],
                    residual_nonnegative=self.params["residual_nonnegative"],
                    decompose_residual_branch=bool(self.params["decompose_residual_branch"]),
                    max_iter=int(self.params["max_iter"]),
                    init=self.params["init"], solver=self.params["solver"],
                    random_state=int(self.params["random_state"]),
                    chunk_size=int(self.params["chunk_size"]),
                )
                logs.append("rr-NMF energy rows: %d" % len(rr_result.energy_records))
            self.finished_ok.emit(conv_result, rr_result, "\n".join(logs))
        except Exception:
            self.failed.emit(traceback.format_exc())


