def collect_rr_component_entries(rr):
    entries = []
    if rr is None: return entries
    for d, depth_nodes in enumerate(rr.node_summaries_by_depth):
        for n, ns in enumerate(depth_nodes):
            for c, (wmap, hspec) in enumerate(zip(ns.component_maps, ns.component_spectra)):
                entries.append({"label": "D%d N%d C%d" % (d, n, c), "depth": d, "node": n, "component": c, "W_map": wmap, "H_spec": hspec})
    return entries


def build_combined_dataset(component_entries, name=""):
    if not component_entries: raise ValueError("No rr-NMF components selected.")
    h, w = component_entries[0]["W_map"].shape; L = len(component_entries[0]["H_spec"]); Xsum = np.zeros((h * w, L), dtype=np.float32); labels = []
    for ent in component_entries:
        wmap, hspec = ent["W_map"], ent["H_spec"]
        if wmap.shape != (h, w) or len(hspec) != L: raise ValueError("Selected components have inconsistent W/H shapes.")
        Xsum += np.outer(wmap.reshape(-1).astype(np.float32, copy=False), hspec.astype(np.float32, copy=False)); labels.append(ent["label"])
    return {"name": name or "Combined %d component(s)" % len(component_entries), "members": labels, "matrix": Xsum, "image": np.sum(Xsum, axis=1, dtype=np.float64).reshape(h, w), "spectrum": np.sum(Xsum, axis=0, dtype=np.float64)}


