            grid.addWidget(btn, row, col - 1)

        root.addLayout(grid)

        bottom = QHBoxLayout()
        self.lbl_selected = QLabel("")
        bottom.addWidget(self.lbl_selected, 1)

        btn_apply = QPushButton("Apply selected elements")
