        bottom.addWidget(btn_apply)

        btn_cancel = QPushButton("Cancel")
        btn_cancel.clicked.connect(self.reject)
        bottom.addWidget(btn_cancel)
        root.addLayout(bottom)

        self.refresh_buttons()

    def toggle_element(self, elem: str):
        if elem in self.selected:
            self.selected.remove(elem)
        else:
            self.selected.add(elem)
        self.refresh_buttons()

    def preselect_candidates(self):
        name = self.combo_preset.currentText()
        self.selected = set(self.preset_groups.get(name, []))
        self.refresh_buttons()

    def clear_selection(self):
        self.selected = set()
        self.refresh_buttons()

    def refresh_buttons(self):
        for elem, btn in self.buttons.items():
            is_selected = elem in self.selected
            is_available = (not self.available_elements) or (elem in self.available_elements)
            btn.blockSignals(True)
            btn.setChecked(is_selected)
            btn.blockSignals(False)
            if is_selected:
                btn.setStyleSheet("QPushButton { background-color: #66c2a5; font-weight: bold; border: 2px solid #1b7f5a; }")
            elif is_available:
                btn.setStyleSheet("QPushButton { background-color: #f5f5f5; color: #111; }")
            else:
                btn.setStyleSheet("QPushButton { background-color: #e6e6e6; color: #777; }")
        shown = ", ".join(sorted(self.selected))
        self.lbl_selected.setText("Selected: " + (shown if shown else "(none)"))

    def selected_elements(self) -> List[str]:
        return sorted(self.selected)

class AnalysisWorker(QThread):
    finished_ok=pyqtSignal(object,object,str); failed=pyqtSignal(str)
    def __init__(self,X,shape,params):
