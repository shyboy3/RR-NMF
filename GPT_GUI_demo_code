def _safe_var_name(name: str, maxlen: int = 96) -> str:
    """Return a compact variable-safe key for NPZ export."""
    import re
    name = str(name).strip()
    name = re.sub(r"[^0-9A-Za-z_]+", "_", name)
    name = re.sub(r"_+", "_", name).strip("_")
    if not name:
        name = "item"
    if name[0].isdigit():
        name = "v_" + name
    return name[:maxlen]


def plot_multi_source_interpretation(fig, sources, candidate_markers, matched_markers, title, xlabel, norm="none", cmap="viridis", detected_by_source=None, edge_windows=None, show_detected=False):
    """Stack multiple source W/images and spectra for EDS/EELS comparison."""
    fig.clear()
    sources = list(sources or [])
    n = max(1, len(sources))
    fig.set_size_inches(18, max(6.5, 2.45 * n), forward=True)
    gs = fig.add_gridspec(n, 2, width_ratios=[1.0, 3.2], hspace=0.62, wspace=0.22)
    for i, src in enumerate(sources):
        ax_img = fig.add_subplot(gs[i, 0])
        ax_sp = fig.add_subplot(gs[i, 1])
        img = src.get("image", None)
        if img is not None:
            try:
                im = ax_img.imshow(img, cmap=cmap, origin="upper", aspect="equal")
                add_colorbar(fig, ax_img, im)
            except Exception:
                ax_img.text(0.5, 0.5, "image unavailable", ha="center", va="center")
        else:
            ax_img.text(0.5, 0.5, "no image", ha="center", va="center")
        ax_img.set_title(str(src.get("label", f"source {i+1}"))[:70], fontsize=10)
        ax_img.set_xticks([]); ax_img.set_yticks([])
        y = normalize_1d(np.asarray(src.get("spectrum", []), dtype=np.float64), norm)
        x = np.asarray(src.get("energy", []), dtype=np.float64)
        if x.size != y.size:
            x = np.arange(y.size, dtype=np.float64)
        ax_sp.plot(x, y, lw=1.6)
        ymin = float(np.nanmin(y)) if y.size else 0.0
        ymax = float(np.nanmax(y)) if y.size else 1.0
        span = max(1e-12, ymax-ymin)
        _draw_edge_analysis_windows(ax_sp, edge_windows, ymin, span, fontsize=8)
        for xv, lab in (candidate_markers or [])[:60]:
            if x.size and (xv < np.nanmin(x) or xv > np.nanmax(x)): continue
            ax_sp.axvline(xv, lw=0.8, color="0.65", alpha=0.30)
        for xv, lab in (matched_markers or [])[:80]:
            if x.size and (xv < np.nanmin(x) or xv > np.nanmax(x)): continue
            ax_sp.axvline(xv, lw=1.4, color="#d62728", alpha=0.80)
            ax_sp.text(xv, ymin+0.94*span, lab, rotation=90, fontsize=7, color="#d62728", va="top", ha="center")
        if show_detected:
            for xv in (detected_by_source or {}).get(i, [])[:80]:
                if x.size and (xv < np.nanmin(x) or xv > np.nanmax(x)): continue
                ax_sp.axvline(xv, lw=0.9, color="0.15", linestyle="--", alpha=0.35)
        ax_sp.grid(True, alpha=0.25)
        ax_sp.set_ylabel("I", fontsize=9)
        if i == n-1:
            ax_sp.set_xlabel(xlabel, fontsize=11)
    fig.suptitle(title, fontsize=14)
    fig.subplots_adjust(left=0.045, right=0.985, top=0.93, bottom=0.07)



