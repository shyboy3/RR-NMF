        y,x,l=self.cube.shape; y0,y1=max(0,min(self.spin_y0.value(),y)),max(0,min(self.spin_y1.value(),y)); x0,x1=max(0,min(self.spin_x0.value(),x)),max(0,min(self.spin_x1.value(),x)); l0,l1=max(0,min(self.spin_l0.value(),l)),max(0,min(self.spin_l1.value(),l))
        self.lbl_roi.setText("Invalid ROI" if y1<=y0 or x1<=x0 or l1<=l0 else f"({y1-y0}, {x1-x0}, {l1-l0}) -> X={(y1-y0)*(x1-x0)}")

    def get_roi_cube_and_X(self):
        if self.cube is None: raise ValueError("No cube loaded")
        y,x,l=self.cube.shape; y0,y1=max(0,min(self.spin_y0.value(),y)),max(0,min(self.spin_y1.value(),y)); x0,x1=max(0,min(self.spin_x0.value(),x)),max(0,min(self.spin_x1.value(),x)); l0,l1=max(0,min(self.spin_l0.value(),l)),max(0,min(self.spin_l1.value(),l))
        if y1<=y0 or x1<=x0 or l1<=l0: raise ValueError("Invalid ROI")
        roi=self.cube[y0:y1,x0:x1,l0:l1].astype(np.float32,copy=False); hh,ww,ll=roi.shape
        X=nonnegative(normalize_spectra(roi.reshape(hh*ww,ll),self.combo_norm.currentText()),"clip")
        axis=AxisInfo(energy_axis=self.axis_info.energy_axis[l0:l1].copy() if len(self.axis_info.energy_axis)==l else np.arange(ll,dtype=np.float32), energy_unit=self.axis_info.energy_unit, energy_label=self.axis_info.energy_label)
        return roi,X,(hh,ww),axis

