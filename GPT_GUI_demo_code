    def energy_range_to_channel_bounds(self, e0, e1, axis_info=None, L=None):
        """Convert an energy-axis interval to half-open channel bounds [lo, hi).

        For EELS/EDS with a real energy axis this means eV/keV values; for arrays
        without calibration the energy axis is the channel index, so the behavior
        remains backward compatible.
        """
        if self.cube is None and L is None:
            raise ValueError("No cube loaded")
        if L is None:
            L = int(self.cube.shape[2])
        axis_info = axis_info or self.axis_info
        e = np.asarray(axis_info.energy_axis, dtype=np.float64)
        if len(e) == L and L > 0:
            i0 = nearest_channel_from_energy(e, float(e0))
            i1 = nearest_channel_from_energy(e, float(e1))
            lo = max(0, min(i0, i1))
            hi = min(L, max(i0, i1) + 1)
        else:
            lo = max(0, min(int(round(float(e0))), L - 1))
            hi = min(L, max(lo + 1, int(round(float(e1)))))
        return lo, hi

    def energy_width_to_window_channels(self, width_energy, axis_info=None, L=None, min_odd=5):
        """Convert an energy-axis width to an odd channel window for local shape matching."""
        if L is None:
            if self.roi_axis_info is not None and len(self.roi_axis_info.energy_axis) > 0:
                L = len(self.roi_axis_info.energy_axis)
            elif self.cube is not None:
                L = int(self.cube.shape[2])
            else:
                L = 1
        axis_info = axis_info or self.roi_axis_info or self.axis_info
        e = np.asarray(axis_info.energy_axis, dtype=np.float64)
        width = abs(float(width_energy))
        if width <= 0:
            return int(min(max(min_odd, 5), max(1, L)))
        if len(e) == L and L > 1:
            de = np.diff(np.sort(e[np.isfinite(e)]))
            de = de[de > 0]
            step = float(np.nanmedian(de)) if de.size else 1.0
            n = int(round(width / max(step, 1e-12)))
        else:
            n = int(round(width))
        n = max(int(min_odd), min(int(L), n))
        if n % 2 == 0:
            n = n + 1 if n < L else n - 1
        return max(1, int(n))

    def background_channel_range(self):
        if self.cube is None: raise ValueError("No cube loaded")
        return self.energy_range_to_channel_bounds(self.bg_e0.value(), self.bg_e1.value(), self.axis_info, self.cube.shape[2])

    def apply_background_correction(self):
        if self.cube is None:
            return
        try:
            y, x, L = self.cube.shape
            y0, y1 = max(0, min(self.bg_y0.value(), y)), max(0, min(self.bg_y1.value(), y))
            x0, x1 = max(0, min(self.bg_x0.value(), x)), max(0, min(self.bg_x1.value(), x))
            if y1 <= y0 or x1 <= x0:
                raise ValueError("Invalid background spatial ROI.")

            mode = self.combo_bg_mode.currentText()
            if mode.startswith("Reference BG"):
                s0, s1 = self.energy_range_to_channel_bounds(self.bg_ref_ch0.value(), self.bg_ref_ch1.value(), self.axis_info, L)
                l0, l1 = self.background_channel_range()
                corrected, meta = apply_reference_bg_low_energy_scaling(
                    self.cube,
                    self.axis_info,
                    spatial_roi=(y0, y1, x0, x1),
                    fit_channel_roi=(l0, l1),
                    scale_channel_roi=(s0, s1),
                    after_mode=self.combo_bg_after.currentText(),
                    chunk_pixels=max(512, self.spin_chunk.value()),
                )
                self.cube = corrected
                self.lbl_bg.setText(
                    "Applied: fitted reference BG × low-energy scale "
                    f"fit_energy[{self.bg_e0.value():.6g}:{self.bg_e1.value():.6g}] -> ch[{l0}:{l1}], scale_energy[{self.bg_ref_ch0.value():.6g}:{self.bg_ref_ch1.value():.6g}] -> ch[{s0}:{s1}], "
                    f"r={meta['r_ref']:.4g}, after={self.combo_bg_after.currentText()}, "
                    f"alpha mean={meta['alpha_mean']:.4g}"
                )
            else:
                l0, l1 = self.background_channel_range()
                fit = fit_powerlaw_exponent_from_roi(self.cube, self.axis_info, (y0, y1, x0, x1), (l0, l1))
                self.cube = apply_powerlaw_background_correction(
                    self.cube, self.axis_info, (l0, l1), fit["r"],
                    self.chk_bg_clip.isChecked(), max(512, self.spin_chunk.value())
                )
                self.lbl_bg.setText(
                    f'Applied: global r={fit["r"]:.4g}, pixelwise A, RMSE={fit["rmse"]:.4g}'
                )

            self.bg_applied = True
            self.conv_result = None
            self.rr_result = None
            self.refresh_views()
            self.refresh_spectrum_sources()
        except Exception as e:
            QMessageBox.critical(self, "Background failed", str(e))
            self.append_log(traceback.format_exc())


