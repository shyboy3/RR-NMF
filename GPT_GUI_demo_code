def estimate_cube_from_array(arr: np.ndarray) -> Tuple[np.ndarray, Tuple[int, int, int]]:
    arr = np.asarray(arr)
    if arr.ndim == 3:
        return arr.astype(np.float32), arr.shape
    if arr.ndim == 2:
        N, L = arr.shape
        return arr.reshape(N, 1, L).astype(np.float32), (N, 1, L)
    raise ValueError("Unsupported array ndim=%s. Expected 2D or 3D." % (arr.ndim,))


def make_default_axis_info(cube_shape: Tuple[int, int, int]) -> AxisInfo:
    _, _, L = cube_shape
    return AxisInfo(energy_axis=np.arange(L, dtype=np.float32))


def try_extract_axis_info_from_signal(signal: Any, cube_shape: Tuple[int, int, int]) -> AxisInfo:
    axis_info = make_default_axis_info(cube_shape)
    try:
        am = signal.axes_manager
        axes = list(am._axes)
        if len(axes) >= 3:
            sizes = [int(getattr(ax, "size", 1)) for ax in axes]
            spec_idx = int(np.argmax(sizes)) if max(sizes) >= 128 else len(axes) - 1
            spec_ax = axes[spec_idx]
            L = cube_shape[2]
            scale = float(getattr(spec_ax, "scale", 1.0))
            offset = float(getattr(spec_ax, "offset", 0.0))
            unit = str(getattr(spec_ax, "units", "channel"))
            axis_info.energy_axis = np.arange(L, dtype=np.float32) * scale + offset
            axis_info.energy_unit = unit if unit not in ["", "None"] else "channel"
            axis_info.energy_label = "Energy (%s)" % axis_info.energy_unit if axis_info.energy_unit != "channel" else "Channel"
            spatial_axes = [ax for j, ax in enumerate(axes) if j != spec_idx]
            if len(spatial_axes) >= 2:
                ay, axx = spatial_axes[0], spatial_axes[1]
                axis_info.y_scale = float(getattr(ay, "scale", 1.0))
                axis_info.x_scale = float(getattr(axx, "scale", 1.0))
                unitx = str(getattr(axx, "units", "px"))
                unity = str(getattr(ay, "units", "px"))
                axis_info.spatial_unit = unitx if unitx not in ["", "None"] else (unity if unity not in ["", "None"] else "px")
                axis_info.x_label = str(getattr(axx, "name", "X")) or "X"
                axis_info.y_label = str(getattr(ay, "name", "Y")) or "Y"
    except Exception:
        pass
    return axis_info


def load_hyperspectral_file(path: str) -> Tuple[np.ndarray, Dict[str, Any], AxisInfo]:
    ext = os.path.splitext(path)[1].lower()
    meta: Dict[str, Any] = {"path": path, "extension": ext, "loader": None}

    if ext == ".npy":
        arr = np.load(path)
        cube, shape = estimate_cube_from_array(arr)
        meta.update({"loader": "numpy", "shape": shape})
        return cube, meta, make_default_axis_info(cube.shape)

    if ext == ".npz":
        z = np.load(path)
        keys = list(z.keys())
        if not keys:
            raise ValueError("NPZ file has no arrays.")
        key = keys[0]
        cube, shape = estimate_cube_from_array(z[key])
        meta.update({"loader": "numpy_npz", "npz_key": key, "shape": shape})
        return cube, meta, make_default_axis_info(cube.shape)

    try:
        import hyperspy.api as hs  # type: ignore
    except Exception as e:
        raise RuntimeError(
            "This file format requires HyperSpy/RosettaSciIO. Install: pip install hyperspy exspy rosettasciio. "
            "Original error: %s" % str(e)
        )

    try:
        sigs = hs.load(path, lazy=False)
    except TypeError:
        sigs = hs.load(path)
    if not isinstance(sigs, list):
        sigs = [sigs]

    candidates = []
    for idx, s in enumerate(sigs):
        try:
            candidates.append((idx, s, np.asarray(s.data)))
        except Exception:
            continue
    if not candidates:
        raise ValueError("No readable dataset found in file.")

    for idx, s, data in candidates:
        if data.ndim == 3:
            shape = data.shape
            spec_axis = int(np.argmax(shape)) if max(shape) >= 128 else 2
            cube = np.moveaxis(data, spec_axis, -1).astype(np.float32)
            axis_info = try_extract_axis_info_from_signal(s, cube.shape)
            meta.update({
                "loader": "hyperspy",
                "signal_index": idx,
                "original_shape": shape,
                "converted_shape": cube.shape,
                "spec_axis_guess": spec_axis,
                "signal_class": s.__class__.__name__,
            })
            return cube, meta, axis_info

    for idx, s, data in candidates:
        if data.ndim == 2:
            cube, shape = estimate_cube_from_array(data)
            meta.update({
                "loader": "hyperspy",
                "signal_index": idx,
                "original_shape": data.shape,
                "converted_shape": cube.shape,
                "signal_class": s.__class__.__name__,
            })
            return cube, meta, make_default_axis_info(cube.shape)

    raise ValueError("No supported 2D/3D spectral dataset found in file.")


def nearest_channel_from_energy(energy_axis: np.ndarray, value: float) -> int:
    energy_axis = np.asarray(energy_axis, dtype=np.float64)
    if energy_axis.size == 0:
        return 0
    return int(np.argmin(np.abs(energy_axis - float(value))))


