def safe_float(x: Any, default: float = np.nan) -> float:
    try:
        return float(x)
    except Exception:
        return default


def fro_energy(A: np.ndarray) -> float:
    """Squared Frobenius norm."""
    A = np.asarray(A)
    return float(np.linalg.norm(A, "fro") ** 2)


def nonnegative(X: np.ndarray, mode: str = "clip") -> np.ndarray:
    """Convert array to nonnegative values for NMF."""
    X = np.asarray(X, dtype=np.float32)
    if mode == "clip":
        return np.clip(X, 0, None)
    if mode == "abs":
        return np.abs(X)
    if mode == "shift":
        mn = np.nanmin(X)
        return X - mn if mn < 0 else X
    return X


def normalize_spectra(X: np.ndarray, mode: str = "none", eps: float = 1e-12) -> np.ndarray:
    """Normalize each spectrum row-wise."""
    X = np.asarray(X, dtype=np.float32)
    if mode == "none":
        return X
    if mode == "max":
        denom = np.max(X, axis=1, keepdims=True) + eps
        return X / denom
    if mode == "area":
        denom = np.sum(X, axis=1, keepdims=True) + eps
        return X / denom
    if mode == "global_max":
        return X / (np.max(X) + eps)
    return X


def component_matrix(W: np.ndarray, H: np.ndarray, i: int) -> np.ndarray:
    return np.outer(W[:, i], H[i, :])


def pairwise_corr_matrix(A: np.ndarray) -> np.ndarray:
    """
    Pairwise Pearson correlation matrix for rows of A.
    A: (num_components, num_features)
    """
    if A.shape[0] <= 1:
        return np.ones((A.shape[0], A.shape[0]), dtype=np.float32)
    return np.corrcoef(A)


def estimate_cube_from_array(arr: np.ndarray) -> Tuple[np.ndarray, Tuple[int, int, int]]:
    """
    Return cube as (H,W,L). If arr is 2D, infer H,W as (N,1).
    """
    arr = np.asarray(arr)
    if arr.ndim == 3:
        return arr.astype(np.float32), arr.shape
    if arr.ndim == 2:
        N, L = arr.shape
        return arr.reshape(N, 1, L).astype(np.float32), (N, 1, L)
    raise ValueError(f"Unsupported array ndim={arr.ndim}. Expected 2D or 3D.")


def load_hyperspectral_file(path: str) -> Tuple[np.ndarray, Dict[str, Any]]:
    """Load EELS/EDS-like data. Returns cube (H,W,L) and metadata."""
    ext = os.path.splitext(path)[1].lower()
    meta: Dict[str, Any] = {"path": path, "loader": None}

    if ext == ".npy":
        arr = np.load(path)
        cube, shape = estimate_cube_from_array(arr)
        meta.update({"loader": "numpy", "shape": shape})
        return cube, meta

    if ext == ".npz":
        z = np.load(path)
        keys = list(z.keys())
        if not keys:
            raise ValueError("NPZ file has no arrays.")
        key = keys[0]
        arr = z[key]
        cube, shape = estimate_cube_from_array(arr)
        meta.update({"loader": "numpy_npz", "npz_key": key, "shape": shape})
        return cube, meta

    # Optional HyperSpy loader
    try:
        import hyperspy.api as hs  # type: ignore
    except Exception as e:
        raise RuntimeError(
            f"File extension {ext} requires HyperSpy/exspy or a custom loader. "
            f"Install hyperspy/exspy or convert to .npy/.npz. Original error: {e}"
        )

    sigs = hs.load(path)
    if not isinstance(sigs, list):
        sigs = [sigs]

    candidates = []
    for idx, s in enumerate(sigs):
        data = np.asarray(s.data)
        candidates.append((idx, s, data))

    # Prefer 3D data. Need convert to (H,W,L). HyperSpy axes ordering can vary,
    # so this is conservative: if 3D, assume spectral axis is the largest or last.
    for idx, s, data in candidates:
        if data.ndim == 3:
            shape = data.shape
            # Heuristic: spectral dimension usually largest; otherwise last.
            spec_axis = int(np.argmax(shape)) if max(shape) > 128 else 2
            cube = np.moveaxis(data, spec_axis, -1).astype(np.float32)
            meta.update({
                "loader": "hyperspy",
                "signal_index": idx,
                "original_shape": shape,
                "converted_shape": cube.shape,
                "spec_axis_guess": spec_axis,
                "title": getattr(s.metadata.General, "title", "") if hasattr(s.metadata, "General") else "",
            })
            return cube, meta

    # Fallback: first 2D spectral matrix
    for idx, s, data in candidates:
        if data.ndim == 2:
            cube, shape = estimate_cube_from_array(data)
            meta.update({
                "loader": "hyperspy",
                "signal_index": idx,
                "original_shape": data.shape,
                "converted_shape": cube.shape,
            })
            return cube, meta

    raise ValueError("No supported 2D/3D spectral dataset found in file.")


# =============================================================================
# NMF result containers
# =============================================================================

@dataclass
class ConventionalNMFResult:
    W: np.ndarray
    H: np.ndarray
    WH: np.ndarray
    R: np.ndarray
    W_images: List[np.ndarray]
    H_spectra: List[np.ndarray]
    energy_records: pd.DataFrame
    recon_ratio: float
    h_corr: np.ndarray
    w_corr: np.ndarray


@dataclass
class RRNMFResult:
    W_images_by_depth: List[List[np.ndarray]]
    H_spectra_by_depth: List[List[np.ndarray]]
    errors_by_depth: List[List[float]]
    energy_records: pd.DataFrame
    node_records: pd.DataFrame
    targets_by_depth: List[List[np.ndarray]]
    residuals_by_depth: List[List[np.ndarray]]
    inputs_by_depth: List[List[np.ndarray]]
    tree_positions: Dict[Tuple[int, int], int]


# =============================================================================
# Conventional NMF
# =============================================================================

def run_conventional_nmf(
    X: np.ndarray,
    image_shape: Tuple[int, int],
    n_components: int = 20,
    max_iter: int = 300,
    init: str = "nndsvda",
    solver: str = "mu",
    random_state: int = 0,
) -> ConventionalNMFResult:
    X = nonnegative(X, "clip").astype(np.float32)
    img_h, img_w = image_shape
    global_energy = fro_energy(X)

    model = NMF(
        n_components=n_components,
        init=init,
        solver=solver,
        max_iter=max_iter,
        random_state=random_state,
    )
    W = model.fit_transform(X)
    H = model.components_
    WH = W @ H
    R = X - WH
    residual_energy = fro_energy(R)
    recon_ratio = 1.0 - residual_energy / global_energy if global_energy > 0 else np.nan

    records = []
    W_images, H_spectra = [], []
    for i in range(n_components):
        S_i = component_matrix(W, H, i)
        E_i = fro_energy(S_i)
        W_map = W[:, i].reshape(img_h, img_w)
        W_images.append(W_map)
        H_spectra.append(H[i].copy())
        records.append({
            "method": "conventional_nmf",
            "depth": 0,
            "node_id": 0,
            "parent_id": -1,
            "component_id": i,
            "type": "component",
            "energy": E_i,
            "node_energy": global_energy,
            "global_energy": global_energy,
            "node_ratio": E_i / global_energy if global_energy > 0 else np.nan,
            "global_ratio": E_i / global_energy if global_energy > 0 else np.nan,
            "recon_ratio_total": recon_ratio,
            "residual_energy_total": residual_energy,
        })

    records.append({
        "method": "conventional_nmf",
        "depth": 0,
        "node_id": 0,
        "parent_id": -1,
        "component_id": "R",
        "type": "residual",
        "energy": residual_energy,
        "node_energy": global_energy,
        "global_energy": global_energy,
        "node_ratio": residual_energy / global_energy if global_energy > 0 else np.nan,
        "global_ratio": residual_energy / global_energy if global_energy > 0 else np.nan,
        "recon_ratio_total": recon_ratio,
        "residual_energy_total": residual_energy,
    })

    energy_records = pd.DataFrame(records)
    h_corr = pairwise_corr_matrix(H)
    w_corr = pairwise_corr_matrix(W.T)

    return ConventionalNMFResult(
        W=W,
        H=H,
        WH=WH,
        R=R,
        W_images=W_images,
        H_spectra=H_spectra,
        energy_records=energy_records,
        recon_ratio=recon_ratio,
        h_corr=h_corr,
        w_corr=w_corr,
    )


# =============================================================================
# Recursive residual-redistributed NMF
# =============================================================================

def run_rr_nmf(
    X: np.ndarray,
    image_shape: Tuple[int, int],
    rank: int = 2,
    max_depth: int = 3,
    residual_mode: str = "redistribute_equal",  # discard, redistribute_equal, explicit_branch
    residual_nonnegative: str = "clip",          # clip, abs, shift
    decompose_residual_branch: bool = False,
    max_iter: int = 300,
    init: str = "nndsvda",
    solver: str = "mu",
    random_state: int = 0,
) -> RRNMFResult:
    """
    Recursive NMF modes:
        discard:
            next child input = S_i only
        redistribute_equal:
            next child input = S_i + R/rank
            This is energy-preserving before nonnegative conversion.
        explicit_branch:
            children include S_0..S_{rank-1} and residual R branch.
            If decompose_residual_branch is False, residual branch is recorded but not decomposed further.
    """
    X = nonnegative(X, "clip").astype(np.float32)
    img_h, img_w = image_shape
    N, L = X.shape
    assert N == img_h * img_w

    global_energy = fro_energy(X)

    W_images_by_depth: List[List[np.ndarray]] = []
    H_spectra_by_depth: List[List[np.ndarray]] = []
    errors_by_depth: List[List[float]] = []
    targets_by_depth: List[List[np.ndarray]] = []
    residuals_by_depth: List[List[np.ndarray]] = []
    inputs_by_depth: List[List[np.ndarray]] = []

    energy_records: List[Dict[str, Any]] = []
    node_records: List[Dict[str, Any]] = []

    # Node is dict with X, node_id, parent_id, path, type
    next_node_id = 0
    current_nodes: List[Dict[str, Any]] = [{
        "X": X,
        "node_id": next_node_id,
        "parent_id": -1,
        "path": "root",
        "node_type": "root",
    }]
    next_node_id += 1

    for d in range(max_depth + 1):
        inputs_by_depth.append([n["X"] for n in current_nodes])
        Wimgs_d: List[np.ndarray] = []
        Hspecs_d: List[np.ndarray] = []
        errors_d: List[float] = []
        targets_d: List[np.ndarray] = []
        residuals_d: List[np.ndarray] = []

        next_nodes: List[Dict[str, Any]] = []

        for local_node_idx, node in enumerate(current_nodes):
            Xd = nonnegative(node["X"], "clip").astype(np.float32)
            node_id = node["node_id"]
            parent_id = node["parent_id"]
            node_energy = fro_energy(Xd)

            node_records.append({
                "depth": d,
                "node_local_index": local_node_idx,
                "node_id": node_id,
                "parent_id": parent_id,
                "path": node["path"],
                "node_type": node["node_type"],
                "node_energy": node_energy,
                "global_ratio": node_energy / global_energy if global_energy > 0 else np.nan,
            })

            if node_energy <= 0 or Xd.shape[0] < rank:
                continue

            # If this is residual branch and not decomposed, skip NMF but keep record.
            if node["node_type"] == "residual" and not decompose_residual_branch:
                energy_records.append({
                    "method": "rr_nmf",
                    "depth": d,
                    "node_id": node_id,
                    "parent_id": parent_id,
                    "component_id": "R_branch",
                    "type": "residual_branch_input",
                    "energy": node_energy,
                    "node_energy": node_energy,
                    "global_energy": global_energy,
                    "node_ratio": 1.0,
                    "global_ratio": node_energy / global_energy if global_energy > 0 else np.nan,
                    "path": node["path"],
                })
                continue

            model = NMF(
                n_components=rank,
                init=init,
                solver=solver,
                max_iter=max_iter,
                random_state=random_state,
            )
            W = model.fit_transform(Xd)
            H = model.components_
            WH = W @ H
            R = Xd - WH
            R_energy = fro_energy(R)
            residuals_d.append(R)
            recon_ratio_node = 1.0 - R_energy / node_energy if node_energy > 0 else np.nan

            # Component branches
            for i in range(rank):
                S_i = component_matrix(W, H, i)
                E_i = fro_energy(S_i)
                err_i = float(np.linalg.norm(Xd - S_i, "fro"))

                W_map = W[:, i].reshape(img_h, img_w)
                Wimgs_d.append(W_map)
                Hspecs_d.append(H[i].copy())
                errors_d.append(err_i)
                targets_d.append(S_i)

                energy_records.append({
                    "method": "rr_nmf",
                    "depth": d,
                    "node_local_index": local_node_idx,
                    "node_id": node_id,
                    "parent_id": parent_id,
                    "component_id": i,
                    "type": "component",
                    "energy": E_i,
                    "node_energy": node_energy,
                    "global_energy": global_energy,
                    "node_ratio": E_i / node_energy if node_energy > 0 else np.nan,
                    "global_ratio": E_i / global_energy if global_energy > 0 else np.nan,
                    "node_residual_energy": R_energy,
                    "node_residual_ratio": R_energy / node_energy if node_energy > 0 else np.nan,
                    "node_recon_ratio": recon_ratio_node,
                    "path": f"{node['path']}/C{i}",
                })

                # Prepare next input
                if d < max_depth:
                    if residual_mode == "discard":
                        child_X = S_i
                    elif residual_mode == "redistribute_equal":
                        child_X = S_i + (R / rank)
                    elif residual_mode == "explicit_branch":
                        child_X = S_i
                    else:
                        raise ValueError(f"Unknown residual_mode={residual_mode}")
                    child_X = nonnegative(child_X, residual_nonnegative)
                    next_nodes.append({
                        "X": child_X,
                        "node_id": next_node_id,
                        "parent_id": node_id,
                        "path": f"{node['path']}/C{i}",
                        "node_type": "component",
                    })
                    next_node_id += 1

            # Residual record for this decomposed node
            energy_records.append({
                "method": "rr_nmf",
                "depth": d,
                "node_local_index": local_node_idx,
                "node_id": node_id,
                "parent_id": parent_id,
                "component_id": "R",
                "type": "residual",
                "energy": R_energy,
                "node_energy": node_energy,
                "global_energy": global_energy,
                "node_ratio": R_energy / node_energy if node_energy > 0 else np.nan,
                "global_ratio": R_energy / global_energy if global_energy > 0 else np.nan,
                "node_residual_energy": R_energy,
                "node_residual_ratio": R_energy / node_energy if node_energy > 0 else np.nan,
                "node_recon_ratio": recon_ratio_node,
                "path": f"{node['path']}/R",
            })

            # Explicit residual branch
            if residual_mode == "explicit_branch" and d < max_depth:
                R_branch = nonnegative(R, residual_nonnegative)
                next_nodes.append({
                    "X": R_branch,
                    "node_id": next_node_id,
                    "parent_id": node_id,
                    "path": f"{node['path']}/R",
                    "node_type": "residual",
                })
                next_node_id += 1

        W_images_by_depth.append(Wimgs_d)
        H_spectra_by_depth.append(Hspecs_d)
        errors_by_depth.append(errors_d)
        targets_by_depth.append(targets_d)
        residuals_by_depth.append(residuals_d)

        if d < max_depth:
            current_nodes = next_nodes

    energy_df = pd.DataFrame(energy_records)
    node_df = pd.DataFrame(node_records)

    return RRNMFResult(
        W_images_by_depth=W_images_by_depth,
        H_spectra_by_depth=H_spectra_by_depth,
        errors_by_depth=errors_by_depth,
        energy_records=energy_df,
        node_records=node_df,
        targets_by_depth=targets_by_depth,
        residuals_by_depth=residuals_by_depth,
        inputs_by_depth=inputs_by_depth,
        tree_positions={},
    )


