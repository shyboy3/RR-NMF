    def load_saved_decomposition_results(self):
        """Load an NPZ created by Save All Decomposition Results and expose it as analysis-only sources."""
        path, _ = QFileDialog.getOpenFileName(self, "Load saved decomposition results", "", "NPZ Files (*.npz);;All Files (*.*)")
        if not path:
            return
        try:
            z = np.load(path, allow_pickle=True)
            files = list(z.files)
            energy = np.asarray(z["energy_axis"], dtype=np.float64) if "energy_axis" in files else None
            if energy is None:
                # Pick a spectrum length fallback.
                spec_keys = [k for k in files if any(t in k.lower() for t in ["spectrum", "loading", "h_"])]
                L = len(np.asarray(z[spec_keys[0]]).reshape(-1)) if spec_keys else 0
                energy = np.arange(L, dtype=np.float64)
            axis = AxisInfo(energy_axis=energy.astype(np.float32), energy_unit="loaded", energy_label="Energy / axis")
            meta = []
            if "metadata_json" in files:
                try:
                    meta = json.loads(str(np.asarray(z["metadata_json"]).item()))
                except Exception:
                    meta = []
            meta_by_key = {r.get("key", ""): r for r in meta if isinstance(r, dict)}
            sources = []
            used_spectrum_keys = []
            # Helper to find paired image by same metadata label or nearby key prefix.
            image_keys = [k for k in files if np.asarray(z[k]).ndim == 2]
            def paired_image_for(k, label):
                for ik in image_keys:
                    if meta_by_key.get(ik, {}).get("label", None) == label:
                        return np.asarray(z[ik])
                base = k.replace("_H_spectrum", "_W_image").replace("_spectrum", "_W_image").replace("loading_spectrum", "score_image")
                if base in files and np.asarray(z[base]).ndim == 2:
                    return np.asarray(z[base])
                return None
            for k in files:
                if k in {"metadata_json", "energy_axis"}:
                    continue
                arr = np.asarray(z[k])
                if arr.ndim != 1:
                    continue
                lk = k.lower()
                row = meta_by_key.get(k, {})
                kind = str(row.get("kind", ""))
                label = str(row.get("label", k))
                if not any(tok in lk for tok in ["spectrum", "loading", "h_"]) and not kind.endswith("_H") and "spectrum" not in kind and "loading" not in kind:
                    continue
                group = "Loaded Saved Results"
                if kind.startswith("conv") or lk.startswith("conv"):
                    group = "Loaded Conventional NMF"
                elif kind.startswith("pca") or lk.startswith("pca"):
                    group = "Loaded PCA"
                elif "mergepass" in kind or "mergepass" in lk:
                    group = "Loaded rr-NMF Merge/Pass no-R"
                elif kind.startswith("rr") or lk.startswith("rr"):
                    group = "Loaded rr-NMF Depth Results"
                sources.append({
                    "label": f"[Loaded] {label}",
                    "spectrum": arr.astype(np.float64),
                    "axis": axis,
                    "image": paired_image_for(k, label),
                    "kind": "loaded",
                    "pair_key": None,
                    "source_group": group,
                })
                used_spectrum_keys.append(k)
            self.loaded_decomp_sources = sources
            self.refresh_spectrum_sources()
            self.append_log(f"Loaded saved decomposition results: {os.path.basename(path)} | sources={len(sources)}")
            if not sources:
                QMessageBox.information(self, "Loaded", "File loaded, but no 1D spectrum-like arrays were found.")
        except Exception as e:
            QMessageBox.critical(self, "Load saved results failed", str(e))
            self.append_log(traceback.format_exc())

    def export_all_decomposition_results(self):
        """Save Conventional NMF, PCA, rr-NMF, and merge/pass no-R outputs to NPZ.

        Keys are variable-style names so they can be loaded directly with np.load(...).files.
        """
        if self.conv_result is None and self.pca_result is None and self.rr_result is None:
            QMessageBox.warning(self, "No results", "Run NMF/PCA/rr-NMF before exporting decomposition results.")
            return
        path, _ = QFileDialog.getSaveFileName(self, "Save all decomposition results", "decomposition_results.npz", "NPZ Files (*.npz)")
        if not path:
            return
        if not path.lower().endswith(".npz"):
            path += ".npz"
        arrays = {}
        meta_rows = []
        def put(name, value, kind="", label=""):
            key = _safe_var_name(name)
            base = key
            n = 2
            while key in arrays:
                key = f"{base}_{n}"; n += 1
            arrays[key] = np.asarray(value)
            meta_rows.append({"key": key, "kind": kind, "label": label})
        try:
            put("energy_axis", self.roi_axis_info.energy_axis, "axis", "energy axis")
            if self.conv_result is not None:
                for i, (w, h) in enumerate(zip(self.conv_result.W_images, self.conv_result.H_spectra)):
                    put(f"conv_nmf_W_image_C{i}", w, "conv_W", f"Conventional NMF W image C{i}")
                    put(f"conv_nmf_H_spectrum_C{i}", h, "conv_H", f"Conventional NMF H spectrum C{i}")
            if self.pca_result is not None:
                for i, (w, h) in enumerate(zip(getattr(self.pca_result, "W_images", []) or [], getattr(self.pca_result, "H_spectra", []) or [])):
                    put(f"pca_score_image_PC{i+1}", w, "pca_score", f"PCA score image PC{i+1}")
                    put(f"pca_loading_spectrum_PC{i+1}", h, "pca_loading", f"PCA loading spectrum PC{i+1}")
                evr = getattr(self.pca_result, "explained_variance_ratio", None)
                if evr is not None:
                    put("pca_explained_variance_ratio", evr, "pca", "PCA explained variance ratio")
            if self.rr_result is not None:
                for d, nodes in enumerate(self.rr_result.node_summaries_by_depth):
                    for n, ns in enumerate(nodes):
                        for c, (w, h) in enumerate(zip(ns.component_maps, ns.component_spectra)):
                            put(f"rr_depth{d}_node{n}_W_image_C{c}", w, "rr_W", f"rr D{d} N{n} W C{c}")
                            put(f"rr_depth{d}_node{n}_H_spectrum_C{c}", h, "rr_H", f"rr D{d} N{n} H C{c}")
                # residual-free merge/pass outputs for interpretation/final comparison.
                for src in self.collect_residual_free_mergepass_sources():
                    label = src.get("label", "rr_mergepass_noR")
                    if src.get("image", None) is not None:
                        put(label + "_W_image_noR", src["image"], "rr_mergepass_W_noR", label)
                    put(label + "_spectrum_noR", src["spectrum"], "rr_mergepass_H_noR", label)
            arrays["metadata_json"] = np.array(json.dumps(meta_rows, ensure_ascii=False, indent=2), dtype=object)
            np.savez_compressed(path, **arrays)
            self.append_log(f"Saved all decomposition results: {path} | arrays={len(arrays)}")
        except Exception as e:
            QMessageBox.critical(self, "Export failed", str(e))
            self.append_log(traceback.format_exc())

    def export_csv(self):
        out=QFileDialog.getExistingDirectory(self,"Select output directory")
        if not out: return
        if self.conv_result is not None: self.conv_result.energy_records.to_csv(os.path.join(out,"conventional_nmf_energy.csv"),index=False)
        if self.rr_result is not None:
            self.rr_result.energy_records.to_csv(os.path.join(out,"rr_nmf_energy.csv"),index=False)
            self.rr_result.node_records.to_csv(os.path.join(out,"rr_nmf_nodes.csv"),index=False)
        if self.eds_hits: pd.DataFrame(self.eds_hits).to_csv(os.path.join(out,"eds_line_matches.csv"),index=False)
        if self.eels_hits: pd.DataFrame(self.eels_hits).to_csv(os.path.join(out,"eels_edge_matches.csv"),index=False)
        self.append_log(f"CSV exported to {out}")


