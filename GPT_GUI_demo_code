    def background_channel_range(self):
        if self.cube is None: raise ValueError("No cube loaded")
        L=self.cube.shape[2]; e=self.axis_info.energy_axis
        if len(e)==L:
            i0=nearest_channel_from_energy(e,self.bg_e0.value()); i1=nearest_channel_from_energy(e,self.bg_e1.value()); return max(0,min(i0,i1)), min(L,max(i0,i1)+1)
        return max(0,min(int(round(self.bg_e0.value())),L-1)), min(L,max(1,int(round(self.bg_e1.value()))))

