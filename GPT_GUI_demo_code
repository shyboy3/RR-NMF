def collect_rr_component_entries(rr: RRNMFResult) -> List[Dict[str, Any]]:
    """Collect all non-residual rr-NMF component W/H pairs for user-defined recombination."""
    entries: List[Dict[str, Any]] = []
    if rr is None:
        return entries
    for d, depth_nodes in enumerate(rr.node_summaries_by_depth):
        for n, ns in enumerate(depth_nodes):
            for c, (wmap, hspec) in enumerate(zip(ns.component_maps, ns.component_spectra)):
                entries.append({
                    "label": "D%d N%d C%d" % (d, n, c),
                    "depth": d,
                    "node": n,
                    "component": c,
                    "W_map": wmap,
                    "H_spec": hspec,
                })
    return entries


def build_combined_dataset(component_entries: List[Dict[str, Any]], name: str = "") -> Dict[str, Any]:
    """Build a new synthetic dataset by summing selected W_i H_i component matrices."""
    if not component_entries:
        raise ValueError("No rr-NMF components selected.")

    h, w = component_entries[0]["W_map"].shape
    L = len(component_entries[0]["H_spec"])
    Xsum = np.zeros((h * w, L), dtype=np.float32)

    labels = []
    for ent in component_entries:
        wmap = ent["W_map"]
        hspec = ent["H_spec"]
        if wmap.shape != (h, w):
            raise ValueError("Selected components have inconsistent W image shapes.")
        if len(hspec) != L:
            raise ValueError("Selected components have inconsistent H spectrum lengths.")
        wvec = wmap.reshape(-1).astype(np.float32, copy=False)
        hvec = hspec.astype(np.float32, copy=False)
        Xsum += np.outer(wvec, hvec)
        labels.append(ent["label"])

    combined_img = np.sum(Xsum, axis=1, dtype=np.float64).reshape(h, w)
    combined_spec = np.sum(Xsum, axis=0, dtype=np.float64)
    if not name:
        name = "Combined %d component(s)" % len(component_entries)
    return {
        "name": name,
        "members": labels,
        "matrix": Xsum,
        "image": combined_img,
        "spectrum": combined_spec,
    }


