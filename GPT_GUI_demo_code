def plot_rr_tree_enhanced(fig: Figure, rr: RRNMFResult, axis_info: AxisInfo, cmap: str = "viridis", max_depth: Optional[int] = None):
    """
    Wrapped rr-NMF tree view.

    Rank-2 node layout:
        [ C0 image ] [ C1 image ]
        [ H0 spec  ] [ H1 spec  ]
        [      Residual map      ]
        [   Residual spectrum    ]

    Component and residual image rows are enlarged, while spectrum rows stay compact.
    Residual map/spectrum are centered below C0/C1 by spanning the two component columns.
    """
    fig.clear()
    node_summaries_by_depth = rr.node_summaries_by_depth
    rank = rr.rank
    num_depths = len(node_summaries_by_depth)
    if max_depth is not None:
        num_depths = min(num_depths, max_depth + 1)
    if num_depths == 0:
        ax = fig.add_subplot(111)
        ax.text(0.5, 0.5, "No rr-NMF result", ha="center", va="center")
        ax.axis("off")
        return

    max_nodes_per_row = 3 if rank == 2 else 2
    cols_per_node = 2 if rank == 2 else max(2, rank)
    rows_per_node = 4

    depth_label_weight = 0.55
    image_row_weight = 3.0
    spectrum_row_weight = 1.0
    gap_weight = 0.35

    depth_row_offsets: List[int] = []
    height_ratios: List[float] = []
    row_cursor = 0
    for d in range(num_depths):
        n_nodes = len(node_summaries_by_depth[d])
        n_wrap_rows = max(1, int(np.ceil(float(max(1, n_nodes)) / float(max_nodes_per_row))))
        depth_row_offsets.append(row_cursor)
        height_ratios.append(depth_label_weight)
        row_cursor += 1
        for _ in range(n_wrap_rows):
            height_ratios.extend([image_row_weight, spectrum_row_weight, image_row_weight, spectrum_row_weight])
            row_cursor += rows_per_node
        height_ratios.append(gap_weight)
        row_cursor += 1

    total_rows = max(1, row_cursor)
    total_cols = max(2, max_nodes_per_row * cols_per_node)

    # Keep spectrum rows compact. Image rows are enlarged through height ratios only.
    fig_width = max(14.0, total_cols * 3.0)
    fig_height = max(8.0, float(sum(height_ratios)) * 1.65)
    fig.set_size_inches(fig_width, fig_height, forward=True)
    gs = fig.add_gridspec(total_rows, total_cols, height_ratios=height_ratios)
    x_energy = axis_info.energy_axis

    for d in range(num_depths):
        nodes = node_summaries_by_depth[d]
        row_offset = depth_row_offsets[d]

        ax_depth = fig.add_subplot(gs[row_offset, :])
        ax_depth.axis("off")
        ax_depth.text(0.0, 0.5, "Depth %d" % d, fontsize=12, fontweight="bold", ha="left", va="center")

        for i, ns in enumerate(nodes):
            wrap_r = i // max_nodes_per_row
            wrap_c = i % max_nodes_per_row
            base_r = row_offset + 1 + wrap_r * rows_per_node
            base_c = wrap_c * cols_per_node

            if rank == 2:
                comp_cols = [base_c, base_c + 1]
                span_start = base_c
                span_end = base_c + 2
                n_comp = min(2, len(ns.component_maps))
            else:
                comp_cols = [base_c + ci for ci in range(min(rank, len(ns.component_maps), cols_per_node))]
                span_start = base_c
                span_end = min(base_c + cols_per_node, total_cols)
                n_comp = len(comp_cols)

            # Component maps and spectra.
            for ci in range(n_comp):
                c = comp_cols[ci]
                img = ns.component_maps[ci]
                spec = ns.component_spectra[ci]
                x = x_energy if len(x_energy) == len(spec) else np.arange(len(spec), dtype=np.float32)

                ax_img = fig.add_subplot(gs[base_r + 0, c])
                im = ax_img.imshow(img, cmap=cmap, origin="upper", aspect="equal")
                ax_img.set_title("D%d N%d C%d" % (d, i, ci), fontsize=10)
                ax_img.set_xticks([])
                ax_img.set_yticks([])
                try:
                    ih, iw = img.shape
                    ax_img.set_box_aspect(float(ih) / float(iw))
                except Exception:
                    pass
                add_colorbar(fig, ax_img, im)

                ax_sp = fig.add_subplot(gs[base_r + 1, c])
                ax_sp.plot(x, spec, linewidth=1.0)
                ax_sp.set_title("D%d N%d H%d" % (d, i, ci), fontsize=9)
                ax_sp.set_xlabel(axis_info.energy_label, fontsize=8)
                ax_sp.set_ylabel("")
                ax_sp.tick_params(labelsize=7)
                ax_sp.grid(True, alpha=0.25)

            # Residual map: centered below C0/C1 by spanning the component columns.
            if ns.residual_image is not None:
                res_img = ns.residual_image
                ax_rimg = fig.add_subplot(gs[base_r + 2, span_start:span_end])
                im = ax_rimg.imshow(res_img, cmap=cmap, origin="upper", aspect="equal")
                ax_rimg.set_title("D%d N%d Residual" % (d, i), fontsize=10)
                ax_rimg.set_xticks([])
                ax_rimg.set_yticks([])
                try:
                    ih, iw = res_img.shape
                    ax_rimg.set_box_aspect(float(ih) / float(iw))
                except Exception:
                    pass
                add_colorbar(fig, ax_rimg, im)
            else:
                ax_blank = fig.add_subplot(gs[base_r + 2, span_start:span_end])
                ax_blank.axis("off")

            # Residual spectrum: centered below residual map by spanning the component columns.
            if ns.residual_spectrum is not None:
                res_spec = ns.residual_spectrum
                x = x_energy if len(x_energy) == len(res_spec) else np.arange(len(res_spec), dtype=np.float32)
                ax_rsp = fig.add_subplot(gs[base_r + 3, span_start:span_end])
                ax_rsp.plot(x, res_spec, linewidth=1.0)
                ax_rsp.set_title("D%d N%d Residual Spectrum" % (d, i), fontsize=9)
                ax_rsp.set_xlabel(axis_info.energy_label, fontsize=8)
                ax_rsp.set_ylabel("")
                ax_rsp.tick_params(labelsize=7)
                ax_rsp.grid(True, alpha=0.25)
            else:
                ax_blank = fig.add_subplot(gs[base_r + 3, span_start:span_end])
                ax_blank.axis("off")

    fig.suptitle("rr-NMF Tree", fontsize=14)
    fig.subplots_adjust(left=0.03, right=0.985, top=0.965, bottom=0.035, hspace=0.40, wspace=0.22)


