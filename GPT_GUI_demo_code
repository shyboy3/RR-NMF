        self.base = tuple(self.fig.get_size_inches())
        self.zoom = 1.0
    def zoom_in(self): self.zoom *= 1.25; self.apply_zoom()
    def zoom_out(self): self.zoom /= 1.25; self.apply_zoom()
    def reset_zoom(self): self.zoom = 1.0; self.apply_zoom()
