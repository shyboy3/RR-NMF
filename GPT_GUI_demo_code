    def refresh_diag_matrix_table(self):
        """Exact numeric W-corr, W-downCorr and H-corr matrices in a table.

        Heatmaps stay visually compact in the summary tab; this table preserves exact
        values when there are too many components to annotate legibly inside cells.
        """
        if not hasattr(self, "table_diag_matrix"):
            return
        tbl = self.table_diag_matrix
        rows = []
        if self.rr_result is not None:
            for d, nodes in enumerate(self.rr_result.node_summaries_by_depth):
                for metric, func in [
                    ("W Corr", compute_w_morphology_corr_for_depth),
                    ("W DownCorr", lambda n: compute_w_morphology_downcorr_for_depth(n, factor=self.spin_auto_w_downsample.value() if hasattr(self, "spin_auto_w_downsample") else 4)),
                    ("H Corr", compute_h_basis_corr_for_depth),
                ]:
                    try:
                        labels, M = func(nodes)
                    except Exception:
                        labels, M = [], np.zeros((0, 0), dtype=np.float64)
                    for i, li in enumerate(labels):
                        for j, lj in enumerate(labels):
                            if j < i:
                                continue
                            val = float(M[i, j]) if M.size else np.nan
                            rows.append([d, metric, li, lj, val])
        # Add residual-free merge/pass output matrix values.  Key K means output made from D(K-1).
        if self.rr_result is not None:
            for key, sets in sorted((getattr(self, "manual_depth_groups", {}) or {}).items()):
                if not sets:
                    continue
                try:
                    labels_mp, Wmp, Hmp = compute_residual_free_mergepass_corr(
                        self.rr_result,
                        getattr(self, "manual_depth_groups", {}),
                        int(key),
                        w_downsample_factor=self.spin_auto_w_downsample.value() if hasattr(self, "spin_auto_w_downsample") else 4,
                    )
                except Exception:
                    labels_mp, Wmp, Hmp = [], np.zeros((0, 0), dtype=np.float64), np.zeros((0, 0), dtype=np.float64)
                source_depth = int(key) - 1
                for metric, M in [("MergePass W DownCorr no-R", Wmp), ("MergePass H Corr no-R", Hmp)]:
                    for i, li in enumerate(labels_mp):
                        for j, lj in enumerate(labels_mp):
                            if j < i:
                                continue
                            val = float(M[i, j]) if M.size else np.nan
                            rows.append([f"D{source_depth}->D{int(key)}", metric, li, lj, val])
        tbl.setRowCount(len(rows)); tbl.setColumnCount(5)
        tbl.setHorizontalHeaderLabels(["depth", "metric", "item_i", "item_j", "value"]);
        for r, row in enumerate(rows):
            for c, val in enumerate(row):
