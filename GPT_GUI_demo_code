def downsample_map_mean(arr, factor=4):
    """Mean-pool a 2D W map before morphology correlation.

    Downsampling suppresses pixel-scale noise and small registration differences, so the
    correlation emphasizes coarse scientific morphology rather than visual SSIM.
    """
    a = np.asarray(arr, dtype=np.float64)
    if a.ndim != 2:
        return a.reshape(-1)
    f = max(1, int(factor))
    if f <= 1:
        return a
    h, w = a.shape
    hh = max(1, h // f) * f
    ww = max(1, w // f) * f
    aa = a[:hh, :ww]
    try:
        return aa.reshape(hh // f, f, ww // f, f).mean(axis=(1, 3))
    except Exception:
        return a


def compute_w_morphology_downcorr_for_depth(nodes, factor=4, nonnegative_display=True):
    """Return labels and downsampled W-map correlation matrix in 0..1."""
    labels, maps = [], []
