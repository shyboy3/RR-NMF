@dataclass
class AxisInfo:
    energy_axis: np.ndarray
    energy_unit: str = "channel"
    energy_label: str = "Channel"
    x_label: str = "X"
    y_label: str = "Y"


@dataclass
class RRNodeSummary:
    depth: int
    node_id: int
    parent_id: int
    path: str
    component_maps: List[np.ndarray] = field(default_factory=list)
    component_spectra: List[np.ndarray] = field(default_factory=list)
    child_matrices: List[Optional[np.ndarray]] = field(default_factory=list)  # exact next-depth inputs including residual redistribution
    residual_image: Optional[np.ndarray] = None
    residual_spectrum: Optional[np.ndarray] = None
    residual_energy: float = np.nan


@dataclass
class ConventionalNMFResult:
    W: np.ndarray
    H: np.ndarray
    W_images: List[np.ndarray]
    H_spectra: List[np.ndarray]
    residual_image: np.ndarray
    residual_spectrum: np.ndarray
    energy_records: pd.DataFrame
    h_corr: np.ndarray
    w_corr: np.ndarray




@dataclass
class PCAResult:
    scores: np.ndarray
    components: np.ndarray
    W_images: List[np.ndarray]
    H_spectra: List[np.ndarray]
    explained_variance_ratio: np.ndarray
    mean_spectrum: np.ndarray


@dataclass
class RRNMFResult:
    node_summaries_by_depth: List[List[RRNodeSummary]]
    energy_records: pd.DataFrame
    node_records: pd.DataFrame
    rank: int


