def collect_rr_component_entries(rr):
    out=[]
    if rr is None: return out
    for d,nodes in enumerate(rr.node_summaries_by_depth):
        for n,ns in enumerate(nodes):
            for c,(wm,hs) in enumerate(zip(ns.component_maps,ns.component_spectra)):
                out.append({"label":f"D{d} N{n} C{c}","W_map":wm,"H_spec":hs})
    return out


def build_combined_dataset(entries, name=""):
    if not entries: raise ValueError("No components selected")
    h,w=entries[0]["W_map"].shape; L=len(entries[0]["H_spec"])
    X=np.zeros((h*w,L),dtype=np.float32); labels=[]
    for e in entries:
        X += np.outer(e["W_map"].reshape(-1).astype(np.float32), e["H_spec"].astype(np.float32))
        labels.append(e["label"])
    return {"name":name or f"Combined {len(entries)} component(s)", "members":labels, "matrix":X, "image":np.sum(X,axis=1).reshape(h,w), "spectrum":np.sum(X,axis=0)}


