def run_conventional_nmf(X, image_shape, n_components=20, max_iter=300, init="random", solver="mu", random_state=0, chunk_size=4096):
    X = nonnegative(X, "clip").astype(np.float32)
    img_h, img_w = image_shape
    global_energy = fro_energy(X)
    model = NMF(n_components=n_components, init=init, solver=solver, max_iter=max_iter, random_state=random_state)
    W = model.fit_transform(X)
    H = model.components_
    residual_image, residual_spectrum, R_energy = compute_residual_summary(X, W, H, image_shape, chunk_size)
    recon_ratio = 1.0 - R_energy / global_energy if global_energy > 0 else np.nan
    records, W_images, H_spectra = [], [], []
    for i in range(n_components):
        Wi, Hi = W[:, i], H[i]
        E_i = component_energy_no_outer(Wi, Hi)
        err_i = component_error_no_outer(X, Wi, Hi, x_energy=global_energy, chunk_size=chunk_size)
        W_images.append(Wi.reshape(img_h, img_w))
        H_spectra.append(Hi.copy())
        records.append({"method": "conventional_nmf", "depth": 0, "node_id": 0, "parent_id": -1, "component_id": i, "type": "component", "energy": E_i, "node_energy": global_energy, "global_energy": global_energy, "node_ratio": E_i / global_energy if global_energy > 0 else np.nan, "global_ratio": E_i / global_energy if global_energy > 0 else np.nan, "component_error_vs_X": err_i, "recon_ratio_total": recon_ratio, "residual_energy_total": R_energy})
    records.append({"method": "conventional_nmf", "depth": 0, "node_id": 0, "parent_id": -1, "component_id": "R", "type": "residual", "energy": R_energy, "node_energy": global_energy, "global_energy": global_energy, "node_ratio": R_energy / global_energy if global_energy > 0 else np.nan, "global_ratio": R_energy / global_energy if global_energy > 0 else np.nan, "component_error_vs_X": np.nan, "recon_ratio_total": recon_ratio, "residual_energy_total": R_energy})
    return ConventionalNMFResult(W, H, R_energy, W_images, H_spectra, residual_image, residual_spectrum, pd.DataFrame(records), recon_ratio, pairwise_corr_matrix(H), pairwise_corr_matrix(W.T))


def run_rr_nmf(X, image_shape, rank=2, max_depth=3, residual_mode="redistribute_equal", residual_nonnegative="clip", decompose_residual_branch=False, max_iter=300, init="random", solver="mu", random_state=0, chunk_size=2048):
    X = nonnegative(X, "clip").astype(np.float32)
    img_h, img_w = image_shape
    global_energy = fro_energy(X)
    W_images_by_depth, H_spectra_by_depth, errors_by_depth = [], [], []
    energy_records, node_records, node_summaries_by_depth = [], [], []
    node_id_counter = 1
    current_nodes = [{"X": X, "node_id": 0, "parent_id": -1, "path": "root", "node_type": "root"}]
    for d in range(max_depth + 1):
        Wimgs_d, Hspecs_d, errs_d, summary_d, next_nodes = [], [], [], [], []
        for local_idx, node in enumerate(current_nodes):
            Xd = nonnegative(node["X"], "clip").astype(np.float32)
            node_id, parent_id = int(node["node_id"]), int(node["parent_id"])
            node_energy = fro_energy(Xd)
            node_records.append({"depth": d, "node_local_index": local_idx, "node_id": node_id, "parent_id": parent_id, "path": node["path"], "node_type": node["node_type"], "node_shape": str(Xd.shape), "node_energy": node_energy, "global_ratio": node_energy / global_energy if global_energy > 0 else np.nan})
            if node_energy <= 0 or Xd.shape[0] < rank:
                continue
            if node["node_type"] == "residual" and not decompose_residual_branch:
                continue
            model = NMF(n_components=rank, init=init, solver=solver, max_iter=max_iter, random_state=random_state)
            W = model.fit_transform(Xd)
            H = model.components_
            residual_image, residual_spectrum, R_energy = compute_residual_summary(Xd, W, H, image_shape, chunk_size)
            recon_ratio_node = 1.0 - R_energy / node_energy if node_energy > 0 else np.nan
            ns = RRNodeSummary(depth=d, node_id=node_id, parent_id=parent_id, path=node["path"], residual_image=residual_image, residual_spectrum=residual_spectrum, residual_energy=R_energy, recon_ratio=recon_ratio_node)
            for i in range(rank):
                Wi, Hi = W[:, i], H[i]
                E_i = component_energy_no_outer(Wi, Hi)
                err_i = component_error_no_outer(Xd, Wi, Hi, x_energy=node_energy, chunk_size=chunk_size)
                W_map = Wi.reshape(img_h, img_w)
                Wimgs_d.append(W_map); Hspecs_d.append(Hi.copy()); errs_d.append(err_i)
                ns.component_maps.append(W_map); ns.component_spectra.append(Hi.copy()); ns.component_errors.append(err_i); ns.component_energies.append(E_i)
                energy_records.append({"method": "rr_nmf", "depth": d, "node_local_index": local_idx, "node_id": node_id, "parent_id": parent_id, "component_id": i, "type": "component", "energy": E_i, "node_energy": node_energy, "global_energy": global_energy, "node_ratio": E_i / node_energy if node_energy > 0 else np.nan, "global_ratio": E_i / global_energy if global_energy > 0 else np.nan, "component_error_vs_node": err_i, "node_residual_energy": R_energy, "node_residual_ratio": R_energy / node_energy if node_energy > 0 else np.nan, "node_recon_ratio": recon_ratio_node, "path": "%s/C%d" % (node["path"], i)})
                if d < max_depth:
                    child_X = make_child_matrix_chunked(Xd, W, H, i, rank, residual_mode, residual_nonnegative, chunk_size)
                    next_nodes.append({"X": child_X, "node_id": node_id_counter, "parent_id": node_id, "path": "%s/C%d" % (node["path"], i), "node_type": "component"})
                    node_id_counter += 1
            energy_records.append({"method": "rr_nmf", "depth": d, "node_local_index": local_idx, "node_id": node_id, "parent_id": parent_id, "component_id": "R", "type": "residual", "energy": R_energy, "node_energy": node_energy, "global_energy": global_energy, "node_ratio": R_energy / node_energy if node_energy > 0 else np.nan, "global_ratio": R_energy / global_energy if global_energy > 0 else np.nan, "node_residual_energy": R_energy, "node_residual_ratio": R_energy / node_energy if node_energy > 0 else np.nan, "node_recon_ratio": recon_ratio_node, "path": "%s/R" % node["path"]})
            if residual_mode == "explicit_branch" and d < max_depth:
                R_branch = make_residual_branch_chunked(Xd, W, H, residual_nonnegative, chunk_size)
                next_nodes.append({"X": R_branch, "node_id": node_id_counter, "parent_id": node_id, "path": "%s/R" % node["path"], "node_type": "residual"})
                node_id_counter += 1
            summary_d.append(ns)
        W_images_by_depth.append(Wimgs_d); H_spectra_by_depth.append(Hspecs_d); errors_by_depth.append(errs_d); node_summaries_by_depth.append(summary_d)
        if d < max_depth:
            current_nodes = next_nodes
    return RRNMFResult(W_images_by_depth, H_spectra_by_depth, errors_by_depth, pd.DataFrame(energy_records), pd.DataFrame(node_records), node_summaries_by_depth, rank)


