def plot_rr_tree_enhanced(fig: Figure, rr: RRNMFResult, axis_info: AxisInfo, cmap: str = "viridis", max_depth: Optional[int] = None):
    """
    Wrapped tree view.
    Per node for rank=2:
        row 0: C0 image | C1 image
        row 1: C0 H     | C1 H
        row 2: Residual image
        row 3: Residual spectrum
    """
    fig.clear()
    node_summaries_by_depth = rr.node_summaries_by_depth
    rank = rr.rank
    num_depths = len(node_summaries_by_depth)
    if max_depth is not None:
        num_depths = min(num_depths, max_depth + 1)
    if num_depths == 0:
        ax = fig.add_subplot(111)
        ax.text(0.5, 0.5, "No rr-NMF result", ha="center", va="center")
        ax.axis("off")
        return

    max_nodes_per_row = 4
    cols_per_node = max(2, rank)
    rows_per_node = 4
    gap_rows_per_depth = 1

    depth_row_offsets = []
    total_rows = 0
    total_cols = max(2, max_nodes_per_row * cols_per_node)
    for d in range(num_depths):
        n_nodes = len(node_summaries_by_depth[d])
        n_wrap_rows = max(1, int(np.ceil(float(max(1, n_nodes)) / float(max_nodes_per_row))))
        depth_row_offsets.append(total_rows)
        total_rows += n_wrap_rows * rows_per_node + gap_rows_per_depth
    total_rows = max(1, total_rows)

    fig_width = max(14.0, total_cols * 3.0)
    fig_height = max(8.0, total_rows * 1.65)
    fig.set_size_inches(fig_width, fig_height, forward=True)
    gs = fig.add_gridspec(total_rows, total_cols)
    x_energy = axis_info.energy_axis

    for d in range(num_depths):
        nodes = node_summaries_by_depth[d]
        row_offset = depth_row_offsets[d]

        ax_depth = fig.add_subplot(gs[row_offset, :])
        ax_depth.axis("off")
        ax_depth.text(0.0, 0.6, "Depth %d" % d, fontsize=12, fontweight="bold", ha="left", va="center")

        for i, ns in enumerate(nodes):
            wrap_r = i // max_nodes_per_row
            wrap_c = i % max_nodes_per_row
            base_r = row_offset + wrap_r * rows_per_node
            base_c = wrap_c * cols_per_node
            n_comp = min(rank, len(ns.component_maps))

            for ci in range(n_comp):
                c = base_c + ci
                img = ns.component_maps[ci]
                spec = ns.component_spectra[ci]
                err = ns.component_errors[ci]
                x = x_energy if len(x_energy) == len(spec) else np.arange(len(spec), dtype=np.float32)

                ax_img = fig.add_subplot(gs[base_r + 0, c])
                im = ax_img.imshow(img, aspect="equal", cmap=cmap, origin="upper")
                ax_img.set_title("N%d C%d\nErr=%.3g" % (i, ci, err), fontsize=7)
                ax_img.set_xticks([])
                ax_img.set_yticks([])
                add_colorbar(fig, ax_img, im)

                ax_sp = fig.add_subplot(gs[base_r + 1, c])
                ax_sp.plot(x, spec)
                ax_sp.set_title("H%d" % ci, fontsize=7)
                ax_sp.set_xlabel(axis_info.energy_label, fontsize=7)
                ax_sp.set_ylabel("", fontsize=7)
                ax_sp.tick_params(labelsize=6)
                ax_sp.grid(True, alpha=0.25)

            if ns.residual_image is not None and ns.residual_spectrum is not None:
                res_img = ns.residual_image
                res_spec = ns.residual_spectrum
                x = x_energy if len(x_energy) == len(res_spec) else np.arange(len(res_spec), dtype=np.float32)

                ax_rimg = fig.add_subplot(gs[base_r + 2, base_c])
                im = ax_rimg.imshow(res_img, aspect="equal", cmap=cmap, origin="upper")
                ax_rimg.set_title("N%d Residual" % i, fontsize=7)
                ax_rimg.set_xticks([])
                ax_rimg.set_yticks([])
                add_colorbar(fig, ax_rimg, im)

                ax_rsp = fig.add_subplot(gs[base_r + 3, base_c])
                ax_rsp.plot(x, res_spec)
                ax_rsp.set_title("Residual Spectrum", fontsize=7)
                ax_rsp.set_xlabel(axis_info.energy_label, fontsize=7)
                ax_rsp.set_ylabel("", fontsize=7)
                ax_rsp.tick_params(labelsize=6)
                ax_rsp.grid(True, alpha=0.25)

            for cc in range(base_c + n_comp, base_c + cols_per_node):
                if cc < total_cols:
                    ax_blank = fig.add_subplot(gs[base_r:base_r + rows_per_node, cc])
                    ax_blank.axis("off")

    fig.suptitle("rr-NMF Tree (wrapped nodes; residual below components)", fontsize=12)
    fig.subplots_adjust(left=0.035, right=0.975, top=0.965, bottom=0.035, hspace=0.95, wspace=0.55)


