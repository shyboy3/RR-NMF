# Numeric utilities
# =============================================================================

def fro_energy(A: np.ndarray) -> float:
    A = np.asarray(A)
    return float(np.sum(A * A, dtype=np.float64))


def nonnegative(X: np.ndarray, mode: str = "clip") -> np.ndarray:
    X = np.asarray(X, dtype=np.float32)
    if mode == "clip":
        return np.clip(X, 0, None)
    if mode == "abs":
        return np.abs(X)
    if mode == "shift":
        mn = float(np.nanmin(X))
        return X - mn if mn < 0 else X
    return X


def normalize_spectra(X: np.ndarray, mode: str = "none", eps: float = 1e-12) -> np.ndarray:
    X = np.asarray(X, dtype=np.float32)
    if mode == "none":
        return X
    if mode == "global_max":
        return X / (float(np.nanmax(X)) + eps)
    if mode == "max":
        return X / (np.nanmax(X, axis=1, keepdims=True) + eps)
    if mode == "area":
        return X / (np.nansum(X, axis=1, keepdims=True) + eps)
    return X


def normalize_1d_spectrum(y: np.ndarray, mode: str = "none") -> np.ndarray:
    y = np.asarray(y, dtype=np.float64)
    if mode == "max":
        m = float(np.nanmax(np.abs(y))) if y.size else 0.0
        return y / m if m > 0 else y
    if mode == "area":
        s = float(np.nansum(np.abs(y))) if y.size else 0.0
        return y / s if s > 0 else y
    return y


def pairwise_corr_matrix(A: np.ndarray) -> np.ndarray:
    A = np.asarray(A)
    if A.ndim != 2 or A.shape[0] <= 1:
        n = max(1, A.shape[0] if A.ndim >= 1 else 1)
        return np.ones((n, n), dtype=np.float32)
    return np.corrcoef(A)


def component_energy_no_outer(w: np.ndarray, h: np.ndarray) -> float:
    return float(np.sum(w * w, dtype=np.float64) * np.sum(h * h, dtype=np.float64))


def component_error_no_outer(X: np.ndarray, w: np.ndarray, h: np.ndarray, x_energy: Optional[float] = None, chunk_size: int = 4096) -> float:
    if x_energy is None:
        x_energy = fro_energy(X)
    s_energy = component_energy_no_outer(w, h)
    dot_xs = 0.0
    h64 = h.astype(np.float64, copy=False)
    for st in range(0, X.shape[0], chunk_size):
        en = min(st + chunk_size, X.shape[0])
        dot_xs += float(np.dot(w[st:en].astype(np.float64, copy=False), X[st:en].astype(np.float64, copy=False) @ h64))
    err2 = float(x_energy + s_energy - 2.0 * dot_xs)
    if err2 < 0 and abs(err2) < 1e-6 * max(1.0, x_energy):
        err2 = 0.0
    return float(np.sqrt(max(err2, 0.0)))


def compute_residual_summary(X: np.ndarray, W: np.ndarray, H: np.ndarray, image_shape: Tuple[int, int], chunk_size: int = 2048):
    N, L = X.shape
    img_h, img_w = image_shape
    residual_img_sum = np.zeros(N, dtype=np.float64)
    residual_spec_sum = np.zeros(L, dtype=np.float64)
    residual_energy = 0.0
    H32 = H.astype(np.float32, copy=False)
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        Rc = X[st:en].astype(np.float32, copy=False) - (W[st:en].astype(np.float32, copy=False) @ H32)
        residual_img_sum[st:en] = np.sum(Rc, axis=1, dtype=np.float64)
        residual_spec_sum += np.sum(Rc, axis=0, dtype=np.float64)
        residual_energy += float(np.sum(Rc * Rc, dtype=np.float64))
    return residual_img_sum.reshape(img_h, img_w), residual_spec_sum, residual_energy


def make_child_matrix_chunked(X, W, H, comp_i, rank, residual_mode, residual_nonnegative, chunk_size=2048):
    N, L = X.shape
    child = np.empty((N, L), dtype=np.float32)
    H32 = H.astype(np.float32, copy=False)
    hi = H32[comp_i]
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        Xc = X[st:en].astype(np.float32, copy=False)
        Wc = W[st:en].astype(np.float32, copy=False)
        Sic = np.outer(Wc[:, comp_i], hi)
        if residual_mode == "redistribute_equal":
            child_c = Sic + (Xc - Wc @ H32) / float(rank)
        else:
            child_c = Sic
        child[st:en] = nonnegative(child_c, residual_nonnegative)
    return child


def make_residual_branch_chunked(X, W, H, residual_nonnegative, chunk_size=2048):
    N, L = X.shape
    R_out = np.empty((N, L), dtype=np.float32)
    H32 = H.astype(np.float32, copy=False)
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        Rc = X[st:en].astype(np.float32, copy=False) - W[st:en].astype(np.float32, copy=False) @ H32
        R_out[st:en] = nonnegative(Rc, residual_nonnegative)
    return R_out


