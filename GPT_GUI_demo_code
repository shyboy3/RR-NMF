    def run_eds_analysis(self):
        srcs = self._selected_spectrum_sources(self.list_eds_src)
        if not srcs:
            QMessageBox.warning(self, "No spectrum", "Select one or more spectrum sources.")
            return
        if not self.eds_elements:
            QMessageBox.warning(self, "No elements", "Select elements first.")
            return

        all_rows = []
        plot_srcs = []
        candidate_markers = [
            (float(r["energy_keV"]), f"{el} {r['line']}")
            for el in self.eds_elements
            for r in EDS_XRAY_LINE_DB.get(el, [])
        ]
        matched_for_plot = []
        detected_by_source = {}
        for si, src in enumerate(srcs):
            spec = np.asarray(src["spectrum"], dtype=np.float64)
            x = energy_axis_as_keV(src["axis"], len(spec))
            peaks = detect_simple_peaks(x, spec, self.spin_eds_prom.value(), self.spin_eds_dist.value())
            hits = match_eds_lines_to_peaks(peaks, self.eds_elements, self.spin_eds_tol.value(), self.combo_eds_line.currentText())
            for row in hits:
                rr = dict(row)
                rr["source"] = src.get("label", f"source {si+1}")
                all_rows.append(rr)
            matched_for_plot.extend([(float(r["line_keV"]), f"{r['element']} {r['line']}") for r in hits])
            detected_by_source[si] = [float(pk["energy"]) for pk in peaks]
            ss = dict(src); ss["energy"] = x; plot_srcs.append(ss)

        # Deduplicate marker labels for plotting.
        seen = set(); matched_markers = []
        for xv, lab in matched_for_plot:
            key = (round(float(xv), 6), lab)
            if key not in seen:
                seen.add(key); matched_markers.append((xv, lab))

        if len(plot_srcs) > 1:
            plot_multi_source_interpretation(
                self.canvas_eds.fig, plot_srcs, candidate_markers, matched_markers,
                f"EDS Analysis: {len(plot_srcs)} selected sources", "Energy (keV)",
                self.combo_eds_norm.currentText(), self.combo_cmap.currentText(), detected_by_source,
            )
        else:
            src = srcs[0]
            spec = np.asarray(src["spectrum"], dtype=np.float64)
            x = energy_axis_as_keV(src["axis"], len(spec))
            plot_interpretation(
                self.canvas_eds.fig, x, spec, candidate_markers,
                "EDS Analysis: " + src["label"], "Energy (keV)",
                self.combo_eds_norm.currentText(),
                source_image=src.get("image", None),
                cmap=self.combo_cmap.currentText(),
                matched_markers=matched_markers,
                detected_features=detected_by_source.get(0, []),
            )
        self.canvas_eds.set_base(); self.canvas_eds.draw()
        self.eds_hits = all_rows
        self.dataframe_to_table(pd.DataFrame(all_rows), self.table_eds)

