    def run(self):
        try:
            conv=rr=None; logs=[]
            if self.params["run_conventional"]:
                logs.append("Running conventional NMF...")
                conv=run_conventional_nmf(self.X,self.shape,self.params["conv_components"],self.params["max_iter"],self.params["init"],self.params["solver"],self.params["random_state"],self.params["chunk_size"])
            if self.params["run_rr"]:
                logs.append("Running recursive NMF...")
                rr=run_rr_nmf(self.X,self.shape,self.params["rr_rank"],self.params["rr_depth"],self.params["residual_mode"],self.params["residual_nonnegative"],self.params["decompose_residual_branch"],self.params["max_iter"],self.params["init"],self.params["solver"],self.params["random_state"],self.params["chunk_size"])
            self.finished_ok.emit(conv,rr,"\n".join(logs))
        except Exception:
            self.failed.emit(traceback.format_exc())


