def fro_energy(A: np.ndarray) -> float:
    return float(np.sum(np.asarray(A) * np.asarray(A), dtype=np.float64))


def nonnegative(X: np.ndarray, mode: str = "clip") -> np.ndarray:
    X = np.asarray(X, dtype=np.float32)
    if mode == "clip":
        return np.clip(X, 0, None)
    if mode == "abs":
        return np.abs(X)
    if mode == "shift":
        mn = float(np.nanmin(X))
        return X - mn if mn < 0 else X
    return X


def normalize_spectra(X: np.ndarray, mode: str = "none", eps: float = 1e-12) -> np.ndarray:
    X = np.asarray(X, dtype=np.float32)
    if mode == "none":
        return X
    if mode == "global_max":
        return X / (float(np.max(X)) + eps)
    if mode == "max":
        return X / (np.max(X, axis=1, keepdims=True) + eps)
    if mode == "area":
        return X / (np.sum(X, axis=1, keepdims=True) + eps)
    return X


def pairwise_corr_matrix(A: np.ndarray) -> np.ndarray:
    A = np.asarray(A)
    if A.ndim != 2 or A.shape[0] <= 1:
        return np.ones((max(1, A.shape[0]), max(1, A.shape[0])), dtype=np.float32)
    return np.corrcoef(A)


def component_energy_no_outer(w: np.ndarray, h: np.ndarray) -> float:
    return float(np.sum(w * w, dtype=np.float64) * np.sum(h * h, dtype=np.float64))


def component_error_no_outer(X: np.ndarray, w: np.ndarray, h: np.ndarray, x_energy: Optional[float] = None, chunk_size: int = 4096) -> float:
    """
    Compute ||X - outer(w,h)||_F without constructing outer(w,h).
    ||X-S||^2 = ||X||^2 + ||S||^2 - 2<w h^T, X>
              = ||X||^2 + ||w||^2||h||^2 - 2 w^T X h
    """
    if x_energy is None:
        x_energy = fro_energy(X)
    s_energy = component_energy_no_outer(w, h)
    dot_xs = 0.0
    N = X.shape[0]
    h64 = h.astype(np.float64, copy=False)
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        Xc = X[st:en].astype(np.float64, copy=False)
        wc = w[st:en].astype(np.float64, copy=False)
        dot_xs += float(np.dot(wc, Xc @ h64))
    err2 = float(x_energy + s_energy - 2.0 * dot_xs)
    if err2 < 0 and abs(err2) < 1e-6 * max(1.0, x_energy):
        err2 = 0.0
    return float(np.sqrt(max(err2, 0.0)))


def residual_energy_no_full_R(X: np.ndarray, W: np.ndarray, H: np.ndarray, x_energy: Optional[float] = None, chunk_size: int = 4096) -> float:
    """Compute ||X - W@H||_F^2 chunk-wise without storing residual."""
    if x_energy is None:
        x_energy = fro_energy(X)
    total = 0.0
    N = X.shape[0]
    H32 = H.astype(np.float32, copy=False)
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        Xc = X[st:en].astype(np.float32, copy=False)
        Wc = W[st:en].astype(np.float32, copy=False)
        Rc = Xc - (Wc @ H32)
        total += float(np.sum(Rc * Rc, dtype=np.float64))
    return total


def make_child_matrix_chunked(
    X: np.ndarray,
    W: np.ndarray,
    H: np.ndarray,
    comp_i: int,
    rank: int,
    residual_mode: str,
    residual_nonnegative: str,
    chunk_size: int = 2048,
) -> np.ndarray:
    """
    Build child matrix for recursion using chunks.
    Still returns a full child matrix, so ROI is recommended for large data.

    discard:
        child = S_i
    redistribute_equal:
        child = S_i + (X - W@H)/rank
    explicit_branch component child:
        child = S_i
    """
    N, L = X.shape
    child = np.empty((N, L), dtype=np.float32)
    H32 = H.astype(np.float32, copy=False)
    hi = H32[comp_i]

    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        Xc = X[st:en].astype(np.float32, copy=False)
        Wc = W[st:en].astype(np.float32, copy=False)
        Sic = np.outer(Wc[:, comp_i], hi)
        if residual_mode == "redistribute_equal":
            WHc = Wc @ H32
            child_c = Sic + (Xc - WHc) / float(rank)
        else:
            child_c = Sic
        child[st:en] = nonnegative(child_c, residual_nonnegative)
    return child


def make_residual_branch_chunked(X: np.ndarray, W: np.ndarray, H: np.ndarray, residual_nonnegative: str, chunk_size: int = 2048) -> np.ndarray:
    """Build residual branch matrix R = X - W@H chunk-wise."""
    N, L = X.shape
    R_out = np.empty((N, L), dtype=np.float32)
    H32 = H.astype(np.float32, copy=False)
    for st in range(0, N, chunk_size):
        en = min(st + chunk_size, N)
        Xc = X[st:en].astype(np.float32, copy=False)
        Wc = W[st:en].astype(np.float32, copy=False)
        Rc = Xc - (Wc @ H32)
        R_out[st:en] = nonnegative(Rc, residual_nonnegative)
    return R_out


def estimate_cube_from_array(arr: np.ndarray) -> Tuple[np.ndarray, Tuple[int, int, int]]:
    arr = np.asarray(arr)
    if arr.ndim == 3:
        return arr.astype(np.float32), arr.shape
    if arr.ndim == 2:
        N, L = arr.shape
        return arr.reshape(N, 1, L).astype(np.float32), (N, 1, L)
    raise ValueError("Unsupported array ndim=%s. Expected 2D or 3D." % (arr.ndim,))


def load_hyperspectral_file(path: str) -> Tuple[np.ndarray, Dict[str, Any]]:
    """Load EELS/EDS data into cube (Y, X, Spectrum). Includes BCF attempt through HyperSpy/RosettaSciIO."""
    ext = os.path.splitext(path)[1].lower()
    meta: Dict[str, Any] = {"path": path, "extension": ext, "loader": None}

    if ext == ".npy":
        arr = np.load(path)
        cube, shape = estimate_cube_from_array(arr)
        meta.update({"loader": "numpy", "shape": shape})
        return cube, meta

    if ext == ".npz":
        z = np.load(path)
        keys = list(z.keys())
        if not keys:
            raise ValueError("NPZ file has no arrays.")
        key = keys[0]
        cube, shape = estimate_cube_from_array(z[key])
        meta.update({"loader": "numpy_npz", "npz_key": key, "shape": shape})
        return cube, meta

    # Microscopy formats: dm3/dm4/emd/hspy/h5/msa/bcf via HyperSpy if available.
    try:
        import hyperspy.api as hs  # type: ignore
    except Exception as e:
        raise RuntimeError(
            "This file format requires HyperSpy/RosettaSciIO support. "
            "Install optional packages with: pip install hyperspy exspy rosettasciio. "
            "Original import error: %s" % str(e)
        )

    # Some BCF readers require lazy=False. Keep simple here.
    try:
        sigs = hs.load(path, lazy=False)
    except TypeError:
        sigs = hs.load(path)

    if not isinstance(sigs, list):
        sigs = [sigs]

    candidates = []
    for idx, s in enumerate(sigs):
        try:
            data = np.asarray(s.data)
            candidates.append((idx, s, data))
        except Exception:
            continue

    if not candidates:
        raise ValueError("No readable dataset found in file.")

    # Prefer 3D datasets. Convert guessed spectral axis to last.
    for idx, s, data in candidates:
        if data.ndim == 3:
            shape = data.shape
            # Heuristic: spectrum axis is often largest; otherwise use last.
            spec_axis = int(np.argmax(shape)) if max(shape) >= 128 else 2
            cube = np.moveaxis(data, spec_axis, -1).astype(np.float32)
            meta.update({
                "loader": "hyperspy",
                "signal_index": idx,
                "original_shape": shape,
                "converted_shape": cube.shape,
                "spec_axis_guess": spec_axis,
                "signal_class": s.__class__.__name__,
            })
            return cube, meta

    # Fallback 2D matrix
    for idx, s, data in candidates:
        if data.ndim == 2:
            cube, shape = estimate_cube_from_array(data)
            meta.update({
                "loader": "hyperspy",
                "signal_index": idx,
                "original_shape": data.shape,
                "converted_shape": cube.shape,
                "signal_class": s.__class__.__name__,
            })
            return cube, meta

    raise ValueError("No supported 2D/3D spectral dataset found in file.")


