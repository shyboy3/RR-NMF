def plot_rr(fig, rr, axis, cmap="viridis", X_for_weight=None, overlay_mode="max", match_threshold_pct=80.0, match_window=21, w_downsample_factor=4, manual_depth_groups=None):
    fig.clear()
    depths = rr.node_summaries_by_depth
    manual_depth_groups = manual_depth_groups or {}

    # Generalized layout for recursive rank >= 2.
    # Each node occupies "rank" columns:
    #   row 1: C0 ... C{rank-1} images
    #   row 2: H0 ... H{rank-1} spectra
    #   row 3: spacer
    #   row 4: residual image spanning rank columns
    #   row 5: residual spectrum spanning rank columns
    #   row 6: inter-wrap spacer to prevent labels/titles from overlapping
    rank = max(1, int(getattr(rr, "rank", 2)))
    cols_node = rank
    rows_node = 6  # W, H, spacer, residual image, residual spectrum, inter-wrap spacer

    # Keep the display reasonably wide without forcing too many nodes per row.
    # Examples:
    #   rank=2 -> 4 nodes/row => 8 component columns
    #   rank=3 -> 3 nodes/row => 9 component columns
    #   rank=4 -> 2 nodes/row => 8 component columns
    max_nodes = max(1, min(4, 10 // max(1, rank)))

    node_cols = max_nodes * cols_node
    ratios = []
    starts = []
    cur = 0
    for d, nodes in enumerate(depths):
        wraps = max(1, int(np.ceil(max(1, len(nodes)) / max_nodes)))
        starts.append(cur)
        ratios.append(0.45)
        cur += 1
        for _ in range(wraps):
            # rows: W image, H spectrum, spacer, residual image, residual spectrum, inter-wrap spacer
            ratios.extend([3.0, 1.0, 0.85, 3.0, 1.0, 1.05])
            cur += rows_node
        # Optional merge/pass output rows from this depth to the next-depth input.
        out_sets = manual_depth_groups.get(d + 1, []) if isinstance(manual_depth_groups, dict) else []
        if out_sets:
            out_wraps = max(1, int(np.ceil(len(out_sets) / max(1, node_cols))))
            ratios.append(0.48)
            cur += 1
            for _ow in range(out_wraps):
                ratios.extend([2.10, 0.22])
                cur += 2
        else:
            ratios.append(0.50)
            cur += 1

    total_cols = node_cols
    fig.set_size_inches(max(26.0, node_cols * 4.1), max(8, sum(ratios) * 1.50), forward=True)
    gs = fig.add_gridspec(cur, total_cols, height_ratios=ratios)

    def _short_text(txt, max_len=70):
        txt = str(txt).replace("\n", " ").strip()
        return txt if len(txt) <= max_len else txt[:max(0, max_len - 3)] + "..."

    def _combined_title(ns, base, max_name=42, max_members=78):
        """Return a title string. Combined-data nodes are always rendered as exactly 2 lines."""
        if not str(getattr(ns, "path", "")).startswith("manualD"):
            return base
        name = _short_text(str(getattr(ns, "combined_name", "") or "Combined"), max_name)
        members = list(getattr(ns, "combined_members", []) or [])
        if members:
            mtxt = ", ".join(map(str, members))
        else:
            mtxt = "selected previous-depth components"
        mtxt = _short_text(mtxt, max_members)
        return f"COMBINED DATA: {name} | {base}\nMerged: {mtxt}"

    for d, nodes in enumerate(depths):
        # Recompute the number of wrapped node rows for THIS depth.
        # Do not reuse the `wraps` value from the layout-construction loop;
        # Auto-Step can produce different node counts at different depths, and
        # using a stale value places the W-corr matrix in the wrong GridSpec row.
        wraps_d = max(1, int(np.ceil(max(1, len(nodes)) / max_nodes)))
        axd = fig.add_subplot(gs[starts[d], :])
        axd.axis("off")
        combined_count = sum(1 for _ns in nodes if str(getattr(_ns, "path", "")).startswith("manualD"))
        header = f"Depth {d}" + (f"   |   {combined_count} combined-data node(s)" if combined_count else "")
        axd.text(0, 0.84, header, fontweight="bold", fontsize=13, va="center")
        for i, ns in enumerate(nodes):
            wr = i // max_nodes
            wc = i % max_nodes
            br = starts[d] + 1 + wr * rows_node
            bc = wc * cols_node

            n_comp = len(ns.component_maps)
            for ci in range(n_comp):
                ax = fig.add_subplot(gs[br, bc + ci])
                sp = fig.add_subplot(gs[br + 1, bc + ci])
                wmap = ns.component_maps[ci]
                hspec = np.asarray(ns.component_spectra[ci])

                im = ax.imshow(wmap, cmap=cmap, origin="upper", aspect="equal")
                ax.set_title(_combined_title(ns, f"D{d} N{i} C{ci}"), fontsize=9)
                ax.set_xticks([])
                ax.set_yticks([])
                add_colorbar(fig, ax, im)

                x = axis.energy_axis if len(axis.energy_axis) == len(hspec) else np.arange(len(hspec))
                corr_txt = ""
                if X_for_weight is not None:
                    try:
                        wspec = weighted_raw_spectrum_by_map(X_for_weight, wmap)
                        corr = safe_shape_correlation(hspec, wspec, overlay_mode)
                        corr_txt = f", corr({overlay_mode})={corr:.3f}" if np.isfinite(corr) else ", corr=nan"
                        mask, local_corr, intervals = local_shape_match_mask(hspec, wspec, match_threshold_pct, window=match_window)
                        match_ratio = 100.0 * float(np.count_nonzero(mask)) / max(1, len(mask))
                        line1, = sp.plot(x, hspec, linewidth=1.0, label="H basis (left)")
                        _shade_match_intervals(sp, x, intervals)
                        sp2 = sp.twinx()
                        line2, = sp2.plot(x, wspec, linewidth=1.2, linestyle="-", color="red", label="weighted raw (right)")
                        # Keep the right axis attached to the spectrum axes; avoid outward offset.
                        sp.set_ylabel("H basis", fontsize=7)
                        sp2.set_ylabel("weighted raw", fontsize=7, labelpad=2)
                        sp2.tick_params(axis="y", labelsize=7, pad=2)
                        sp.legend([line1, line2], [line1.get_label(), line2.get_label()], fontsize=6, loc="best")
                        corr_txt += f", match≥{match_threshold_pct:.0f}%/{int(match_window)}ch:{match_ratio:.0f}%"
                    except Exception:
                        sp.plot(x, hspec, linewidth=1.0, label="H basis")
                        sp.legend(fontsize=6, loc="best")
                else:
                    sp.plot(x, hspec, linewidth=1.0, label="H basis")
                    sp.legend(fontsize=6, loc="best")

                sp.set_title(f"H{ci}{corr_txt}", fontsize=9)
                sp.set_xlabel(axis.energy_label, fontsize=8)
                sp.grid(True, alpha=0.25)
                sp.tick_params(labelsize=7)

            # If n_comp < rank for a degenerate node, leave the remaining slots blank.
            for ci in range(n_comp, rank):
                ax_blank = fig.add_subplot(gs[br, bc + ci])
                ax_blank.axis("off")
                sp_blank = fig.add_subplot(gs[br + 1, bc + ci])
                sp_blank.axis("off")

            if ns.residual_image is not None:
                # Display residual image as mean residual per spectral channel.
                L_res = len(ns.residual_spectrum) if ns.residual_spectrum is not None else 1
                rimg_mean = np.asarray(ns.residual_image, dtype=np.float64) / max(1, int(L_res))
                ax = fig.add_subplot(gs[br + 3, bc:bc + rank])
                im = ax.imshow(rimg_mean, cmap=cmap, origin="upper", aspect="equal")
                ax.set_title(_combined_title(ns, f"D{d} N{i} Residual mean"), fontsize=9)
                ax.set_xticks([])
                ax.set_yticks([])
                add_colorbar(fig, ax, im)

            if ns.residual_spectrum is not None:
                # Display residual spectrum as mean residual per spatial pixel.
                Npix = int(np.prod(ns.residual_image.shape)) if ns.residual_image is not None else 1
                rspec_mean = np.asarray(ns.residual_spectrum, dtype=np.float64) / max(1, Npix)
                x = axis.energy_axis if len(axis.energy_axis) == len(rspec_mean) else np.arange(len(rspec_mean))

                # Keep the residual spectrum half-width, centered under the residual image.
                # Use a GridSpec-hosted inset instead of absolute add_axes coordinates so
                # the alignment remains stable in both full-auto and manual partial trees.
                holder = fig.add_subplot(gs[br + 4, bc:bc + rank])
                holder.axis("off")
                sp = inset_axes(holder, width="50%", height="100%", loc="center", borderpad=0.0)
                sp.plot(x, rspec_mean, linewidth=1.0)
                sp.set_title("Residual spectrum mean", fontsize=9)
                sp.set_xlabel(axis.energy_label, fontsize=8)
                sp.grid(True, alpha=0.25)
                sp.tick_params(labelsize=7)

        # Optional merged/pass-through output produced from this depth.
        out_sets = manual_depth_groups.get(d + 1, []) if isinstance(manual_depth_groups, dict) else []
        if out_sets:
            try:
                out_title_row = starts[d] + 1 + wraps_d * rows_node
                out_img_start = out_title_row + 1
                axm = fig.add_subplot(gs[out_title_row, :])
                axm.axis("off")
                label_next = f"D{d} merge/pass outputs → D{d+1} input"
                if d + 1 > len(depths) - 1:
                    label_next = f"D{d} FINAL RESULT merge/pass outputs (no residual/r)"
                axm.text(0.0, 0.65, label_next, fontsize=10, fontweight="bold", va="center")
                for oi, c in enumerate(out_sets):
                    out_row = out_img_start + 2 * (oi // max(1, total_cols))
                    out_col = oi % max(1, total_cols)
                    axo = fig.add_subplot(gs[out_row, out_col])
                    img = c.get("provenance_image", None)
                    if img is None:
                        maps = list(c.get("member_maps", []) or [])
                        if maps:
                            img = maps[0] if (c.get("pass_through", False) or len(maps) <= 1) else np.nanmean(np.stack([normalize_map_for_display(m) for m in maps], axis=0), axis=0)
                        else:
                            img = c.get("image", None)
                    if img is not None:
                        im = axo.imshow(img, cmap=cmap, origin="upper", aspect="equal")
                        add_colorbar(fig, axo, im)
                    kind = "PASS" if c.get("pass_through", False) else "MERGE"
                    members = ", ".join(map(str, c.get("members", []) or c.get("member_labels", []) or []))
                    members = _short_text(members, 55)
                    axo.set_title(f"{kind} {oi+1}\n{members}", fontsize=7)
                    axo.set_xticks([]); axo.set_yticks([])
            except Exception:
                pass

    fig.suptitle(f"rr-NMF Tree rank={rank}: H basis with weighted raw overlay", fontsize=14)
    fig.subplots_adjust(left=0.012, right=0.988, top=0.965, bottom=0.025, hspace=0.58, wspace=0.70)



def plot_pca_result(fig, pca, axis, cmap="viridis", maxn=20):
    fig.clear()
    if pca is None:
        fig.set_size_inches(12, 5, forward=True)
        ax = fig.add_subplot(111); ax.axis("off")
        ax.text(0.5, 0.5, "Run PCA first", ha="center", va="center", fontsize=14)
        return
    n = min(maxn, len(pca.W_images))
    comp_rows = int(np.ceil(max(1, n) / 2.0))
    rows = comp_rows + 2
    fig.set_size_inches(18, max(8, rows * 3.0), forward=True)
    gs = fig.add_gridspec(rows, 4, width_ratios=[1.0, 1.4, 1.0, 1.4])
    for i in range(n):
        r = i // 2
        c = (i % 2) * 2
        ax = fig.add_subplot(gs[r, c])
        sp = fig.add_subplot(gs[r, c + 1])
        im = ax.imshow(pca.W_images[i], cmap=cmap, origin="upper", aspect="equal")
        evr = float(pca.explained_variance_ratio[i]) * 100 if i < len(pca.explained_variance_ratio) else np.nan
        ax.set_title(f"PC{i+1} score map\nEVR={evr:.2f}%", fontsize=9)
        ax.set_xticks([]); ax.set_yticks([])
        add_colorbar(fig, ax, im)
        spec = np.asarray(pca.H_spectra[i])
        x = axis.energy_axis if len(axis.energy_axis) == len(spec) else np.arange(len(spec))
        sp.plot(x, spec, linewidth=1.1)
        sp.axhline(0, color="0.35", lw=0.7, alpha=0.6)
        sp.set_title(f"PC{i+1} loading", fontsize=9)
        sp.set_xlabel(axis.energy_label, fontsize=8)
        sp.grid(True, alpha=0.25)
        sp.tick_params(labelsize=7)

    vals = np.asarray(pca.explained_variance_ratio, dtype=float) * 100.0
    xcomp = np.arange(1, len(vals) + 1)
    axv = fig.add_subplot(gs[rows - 2, 0:2])
    axv.bar(xcomp, vals)
    axv.set_title("PCA explained variance ratio")
    axv.set_xlabel("Principal component")
    axv.set_ylabel("EVR (%)")
    axv.grid(True, axis="y", alpha=0.25)

    axc = fig.add_subplot(gs[rows - 2, 2:4])
    axc.plot(xcomp, np.cumsum(vals), marker="o")
    axc.set_ylim(0, min(100.0, max(5.0, float(np.nanmax(np.cumsum(vals))) * 1.05 if vals.size else 100.0)))
    axc.set_title("Cumulative explained variance")
    axc.set_xlabel("Principal component")
    axc.set_ylabel("Cumulative EVR (%)")
    axc.grid(True, alpha=0.25)

    # PC magnitude diagnostics.  Score RMS reflects how strongly each PC is expressed spatially;
    # loading L2 norm should be near 1 for sklearn PCA but is shown for completeness.
    axm = fig.add_subplot(gs[rows - 1, 0:2])
    try:
        score_rms = np.sqrt(np.nanmean(np.asarray(pca.scores, dtype=float) ** 2, axis=0))
    except Exception:
        score_rms = np.zeros_like(vals)
    axm.plot(np.arange(1, len(score_rms) + 1), score_rms, marker="o")
    axm.set_title("PC score magnitude (RMS of scores)")
    axm.set_xlabel("Principal component")
    axm.set_ylabel("Score RMS")
    axm.grid(True, alpha=0.25)

    axl = fig.add_subplot(gs[rows - 1, 2:4])
    try:
        loading_amp = np.nanmax(np.abs(np.asarray(pca.components, dtype=float)), axis=1)
    except Exception:
        loading_amp = np.zeros_like(vals)
    axl.plot(np.arange(1, len(loading_amp) + 1), loading_amp, marker="o")
    axl.set_title("PC loading amplitude (max |loading|)")
    axl.set_xlabel("Principal component")
    axl.set_ylabel("max |loading|")
    axl.grid(True, alpha=0.25)

    fig.suptitle("PCA baseline decomposition", fontsize=14)
    fig.subplots_adjust(left=0.04, right=0.985, top=0.94, bottom=0.06, hspace=0.85, wspace=0.28)


def _plot_result_column(fig, gs, col0, title, images, spectra, axis, cmap, maxn=12, image_vmin=None, image_vmax=None):
