def detect_eds_peaks(energy_keV: np.ndarray, spectrum: np.ndarray, min_prom_rel: float = 0.03, min_distance_channels: int = 3) -> List[Dict[str, float]]:
    e = np.asarray(energy_keV, dtype=np.float64)
    y = np.nan_to_num(np.asarray(spectrum, dtype=np.float64), nan=0.0, posinf=0.0, neginf=0.0)
    if y.size < 3:
        return []
    ymax, ymin = float(np.nanmax(y)), float(np.nanmin(y))
    threshold = ymin + max(0.0, float(min_prom_rel)) * max(1e-12, ymax - ymin)
    candidates = []
    last_idx = -10**9
    for idx in range(1, len(y) - 1):
        if y[idx] >= threshold and y[idx] >= y[idx - 1] and y[idx] >= y[idx + 1]:
            if idx - last_idx < int(min_distance_channels):
                if candidates and y[idx] > candidates[-1]["intensity"]:
                    candidates[-1] = {"index": int(idx), "energy_keV": float(e[idx]), "intensity": float(y[idx])}
                    last_idx = idx
            else:
                candidates.append({"index": int(idx), "energy_keV": float(e[idx]), "intensity": float(y[idx])})
                last_idx = idx
    candidates.sort(key=lambda r: r["intensity"], reverse=True)
    return candidates


def match_eds_lines_to_peaks(peaks, selected_elements, tolerance_keV=0.05, line_filter="Major + minor"):
    hits = []
    include_minor = line_filter != "Major only"
    for pk in peaks:
        pk_e = float(pk["energy_keV"])
        for elem in selected_elements:
            for row in EDS_XRAY_LINE_DB.get(elem, []):
                if row.get("type") == "minor" and not include_minor:
                    continue
                delta = pk_e - float(row["energy_keV"])
                if abs(delta) <= float(tolerance_keV):
                    hits.append({"peak_keV": pk_e, "peak_intensity": float(pk["intensity"]), "element": elem, "line": row["line"], "line_type": row["type"], "line_keV": float(row["energy_keV"]), "delta_keV": float(delta)})
    hits.sort(key=lambda r: (r["peak_keV"], abs(r["delta_keV"])))
    return hits


def energy_axis_as_keV(axis_info: AxisInfo, L: int) -> np.ndarray:
    e = np.asarray(axis_info.energy_axis, dtype=np.float64)
    if len(e) != L:
        return np.arange(L, dtype=np.float64)
    label = (axis_info.energy_label + " " + axis_info.energy_unit).lower()
    if "kev" in label:
        return e
    if "ev" in label:
        return e / 1000.0
    # Heuristic: EDS data often has channel axes already in keV when max < 50.
    if np.nanmax(e) > 200:
        return e / 1000.0
    return e


