            sp.blockSignals(True); sp.setRange(0,mx); sp.setValue(val); sp.blockSignals(False)
        e=self.axis_info.energy_axis; self.spin_e0.blockSignals(True); self.spin_e1.blockSignals(True)
        if len(e)>0:
            mn,mx=float(np.nanmin(e)),float(np.nanmax(e)); pad=abs(mx-mn)*.1+1; self.spin_e0.setRange(mn-pad,mx+pad); self.spin_e1.setRange(mn-pad,mx+pad); self.spin_e0.setValue(float(e[0])); self.spin_e1.setValue(float(e[-1]))
        self.spin_e0.blockSignals(False); self.spin_e1.blockSignals(False); self._syncing=False; self.update_roi_label()

