        e=self.axis_info.energy_axis; L=len(e)
        if L==0: return
        l0=max(0,min(self.spin_l0.value(),L-1)); l1=max(0,min(max(1,self.spin_l1.value())-1,L-1)); self.spin_e0.blockSignals(True); self.spin_e1.blockSignals(True); self.spin_e0.setValue(float(e[l0])); self.spin_e1.setValue(float(e[l1])); self.spin_e0.blockSignals(False); self.spin_e1.blockSignals(False)

    def sync_channel_from_energy_roi(self):
        if self.cube is None: return
        e=self.axis_info.energy_axis; L=len(e)
        if L==0: return
        i0=nearest_channel_from_energy(e,self.spin_e0.value()); i1=nearest_channel_from_energy(e,self.spin_e1.value()); lo=max(0,min(i0,i1)); hi=min(L,max(i0,i1)+1); self.spin_l0.blockSignals(True); self.spin_l1.blockSignals(True); self.spin_l0.setValue(lo); self.spin_l1.setValue(hi); self.spin_l0.blockSignals(False); self.spin_l1.blockSignals(False)

