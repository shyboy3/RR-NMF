    def apply_processing_settings(self, cfg):
        """Apply ROI, background, NMF and basic view settings from a dict."""
        roi = cfg.get("roi", {})
        bg = cfg.get("background", {})
        nmf = cfg.get("nmf", {})
        view = cfg.get("view", {})

        # Block ROI energy/channel cross-update signals while restoring values.
        widgets_to_block = [self.spin_y0,self.spin_y1,self.spin_x0,self.spin_x1,self.spin_l0,self.spin_l1,self.spin_e0,self.spin_e1]
        old_states = [w.blockSignals(True) for w in widgets_to_block]
        try:
            for key, widget in [("y0",self.spin_y0),("y1",self.spin_y1),("x0",self.spin_x0),("x1",self.spin_x1),("l0",self.spin_l0),("l1",self.spin_l1)]:
                if key in roi: widget.setValue(int(roi[key]))
            for key, widget in [("e0",self.spin_e0),("e1",self.spin_e1)]:
                if key in roi: widget.setValue(float(roi[key]))
        finally:
            for w, old in zip(widgets_to_block, old_states):
                w.blockSignals(old)
        self._set_combo_text_safe(self.combo_norm, roi.get("normalize", self.combo_norm.currentText()))

        self._set_combo_text_safe(self.combo_bg_mode, bg.get("mode", self.combo_bg_mode.currentText()))
        for key, widget in [("y0",self.bg_y0),("y1",self.bg_y1),("x0",self.bg_x0),("x1",self.bg_x1)]:
            if key in bg: widget.setValue(int(bg[key]))
        for key, widget in [("e0",self.bg_e0),("e1",self.bg_e1),("ref_energy0",self.bg_ref_ch0),("ref_energy1",self.bg_ref_ch1)]:
            if key in bg: widget.setValue(float(bg[key]))
        # Backward-compatible loading of older channel-index reference settings.
        if "ref_ch0" in bg or "ref_ch1" in bg:
            e = np.asarray(self.axis_info.energy_axis, dtype=np.float64)
            L = self.cube.shape[2] if self.cube is not None else len(e)
            if len(e) == L and L > 0:
                if "ref_ch0" in bg: self.bg_ref_ch0.setValue(float(e[max(0,min(int(bg["ref_ch0"]),L-1))]))
                if "ref_ch1" in bg: self.bg_ref_ch1.setValue(float(e[max(0,min(int(bg["ref_ch1"]),L-1))]))
            else:
                if "ref_ch0" in bg: self.bg_ref_ch0.setValue(float(bg["ref_ch0"]))
                if "ref_ch1" in bg: self.bg_ref_ch1.setValue(float(bg["ref_ch1"]))
        self._set_combo_text_safe(self.combo_bg_after, bg.get("after", self.combo_bg_after.currentText()))
        if "clip_negative" in bg: self.chk_bg_clip.setChecked(bool(bg["clip_negative"]))

        if "run_conventional" in nmf: self.chk_conv.setChecked(bool(nmf["run_conventional"]))
        if "conventional_k" in nmf: self.spin_k.setValue(int(nmf["conventional_k"]))
        if "run_rr" in nmf: self.chk_rr.setChecked(bool(nmf["run_rr"]))
        if "recursive_rank" in nmf: self.spin_rank.setValue(int(nmf["recursive_rank"]))
        if "recursive_depth" in nmf: self.spin_depth.setValue(int(nmf["recursive_depth"]))
        if "manual_depth_workflow" in nmf: self.chk_manual_depth.setChecked(bool(nmf["manual_depth_workflow"]))
        if "manual_start_depth" in nmf: self.spin_manual_depth.setValue(int(nmf["manual_start_depth"]))
        self._set_combo_text_safe(self.combo_res_mode, nmf.get("residual_mode", self.combo_res_mode.currentText()))
        self._set_combo_text_safe(self.combo_res_nn, nmf.get("residual_nonnegative", self.combo_res_nn.currentText()))
        if "decompose_residual_branch" in nmf: self.chk_decomp_res.setChecked(bool(nmf["decompose_residual_branch"]))
        if "max_iter" in nmf: self.spin_iter.setValue(int(nmf["max_iter"]))
        self._set_combo_text_safe(self.combo_init, nmf.get("init", self.combo_init.currentText()))
        self._set_combo_text_safe(self.combo_solver, nmf.get("solver", self.combo_solver.currentText()))
        if "random_seed" in nmf: self.spin_seed.setValue(int(nmf["random_seed"]))
        if "chunk_size" in nmf: self.spin_chunk.setValue(int(nmf["chunk_size"]))
        self._set_combo_text_safe(self.combo_cmap, view.get("cmap", self.combo_cmap.currentText()))
        if hasattr(self, "spin_shape_match_pct") and "shape_match_threshold_pct" in view: self.spin_shape_match_pct.setValue(float(view["shape_match_threshold_pct"]))
        if hasattr(self, "spin_shape_match_window"):
            if "shape_match_window_energy" in view:
                self.spin_shape_match_window.setValue(float(view["shape_match_window_energy"]))
            elif "shape_match_window" in view:
                # Legacy value was channels. Convert to current energy width when possible.
                ch = int(view["shape_match_window"])
                e = np.asarray((self.roi_axis_info or self.axis_info).energy_axis, dtype=np.float64)
                if len(e) > 1:
                    de = np.diff(np.sort(e[np.isfinite(e)])); de = de[de > 0]
                    step = float(np.nanmedian(de)) if de.size else 1.0
                    self.spin_shape_match_window.setValue(float(ch * step))
                else:
                    self.spin_shape_match_window.setValue(float(ch))

        if hasattr(self, "spin_auto_corr_weight") and "auto_corr_weight" in view: self.spin_auto_corr_weight.setValue(float(view["auto_corr_weight"]))
        if hasattr(self, "spin_auto_score_thresh") and "auto_score_threshold_pct" in view: self.spin_auto_score_thresh.setValue(float(view["auto_score_threshold_pct"]))
        if hasattr(self, "spin_auto_patience") and "auto_unchanged_patience" in view: self.spin_auto_patience.setValue(int(view["auto_unchanged_patience"]))
        if hasattr(self, "spin_auto_w_downsample") and "auto_w_downsample_factor" in view: self.spin_auto_w_downsample.setValue(int(view["auto_w_downsample_factor"]))

        self.update_roi_label()
        if hasattr(self, "refresh_rr_component_list"):
            self.refresh_rr_component_list()
        self.refresh_views()

    def save_processing_settings(self):
        path, _ = QFileDialog.getSaveFileName(self, "Save ROI/BG/NMF settings", "rr_nmf_settings.json", "JSON Files (*.json)")
        if not path:
            return
        if not path.lower().endswith(".json"):
