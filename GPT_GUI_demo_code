    def load_file(self):
        path, _ = QFileDialog.getOpenFileName(
            self, "Load EELS/EDS Data", "",
            "Data Files (*.npy *.npz *.bcf *.hspy *.hdf5 *.h5 *.emd *.dm3 *.dm4 *.msa);;All Files (*.*)",
        )
        if not path:
            return
        try:
            self.append_log("Loading: %s" % path)
            cube, meta, axis_info = load_hyperspectral_file(path)
            cube = nonnegative(cube, "clip")
            self.cube = cube.copy()
            self.original_cube = cube.copy()
            self.metadata = meta
            self.axis_info = axis_info
            self.roi_axis_info = axis_info
            self.conv_result = None
            self.rr_result = None
            self.rr_component_entries = []
            self.rr_combined_sets = []
            self.lbl_file.setText(os.path.basename(path))
            self.lbl_shape.setText(str(cube.shape))
            self.lbl_energy_axis.setText(axis_info.energy_label)
            self.lbl_bg_status.setText("Not applied")
            self.set_roi_full()
            self.set_background_roi_full()
            self.append_log("Loaded cube shape: %s" % (cube.shape,))
            self.append_log("Metadata: %s" % meta)
            if len(axis_info.energy_axis) > 0:
                self.append_log("Energy axis: %.6g to %.6g %s" % (float(axis_info.energy_axis[0]), float(axis_info.energy_axis[-1]), axis_info.energy_unit))
            self.refresh_rr_component_list()
            self.refresh_raw_view()
        except Exception as e:
            QMessageBox.critical(self, "Load failed", str(e))
            self.append_log(traceback.format_exc())

    def set_roi_full(self):
        if self.cube is None:
            return
        y, x, l = self.cube.shape
        self._syncing_energy_channel = True
        for sp, mx, val in [(self.spin_y0, y, 0), (self.spin_y1, y, y), (self.spin_x0, x, 0),
                            (self.spin_x1, x, x), (self.spin_l0, l, 0), (self.spin_l1, l, l)]:
            sp.blockSignals(True)
            sp.setRange(0, mx)
            sp.setValue(val)
            sp.blockSignals(False)
        e_axis = self.axis_info.energy_axis
        self.spin_e0.blockSignals(True)
        self.spin_e1.blockSignals(True)
        if len(e_axis) > 0:
            mn = float(np.nanmin(e_axis)); mx = float(np.nanmax(e_axis)); margin = abs(mx - mn) * 0.1 + 1.0
            self.spin_e0.setRange(mn - margin, mx + margin)
            self.spin_e1.setRange(mn - margin, mx + margin)
            self.spin_e0.setValue(float(e_axis[0]))
            self.spin_e1.setValue(float(e_axis[-1]))
        self.spin_e0.blockSignals(False)
        self.spin_e1.blockSignals(False)
        self._syncing_energy_channel = False
        self.update_roi_label()

    def set_background_roi_full(self):
        if self.cube is None:
            return
        y, x, l = self.cube.shape
        for sp, mx, val in [(self.spin_bg_y0, y, 0), (self.spin_bg_y1, y, y), (self.spin_bg_x0, x, 0), (self.spin_bg_x1, x, x)]:
            sp.setRange(0, mx)
            sp.setValue(val)
        e_axis = self.axis_info.energy_axis
        if len(e_axis) == l:
            mn = float(np.nanmin(e_axis)); mx = float(np.nanmax(e_axis)); margin = abs(mx - mn) * 0.1 + 1.0
            self.spin_bg_e0.setRange(mn - margin, mx + margin)
            self.spin_bg_e1.setRange(mn - margin, mx + margin)
            l1 = max(3, int(round(l * 0.15)))
            self.spin_bg_e0.setValue(float(e_axis[0]))
            self.spin_bg_e1.setValue(float(e_axis[min(l1, l) - 1]))
        else:
            self.spin_bg_e0.setRange(0, l)
            self.spin_bg_e1.setRange(0, l)
            self.spin_bg_e0.setValue(0)
            self.spin_bg_e1.setValue(max(3, int(round(l * 0.15))))

    def use_current_roi_for_background(self):
        if self.cube is None:
            return
        y, x, _ = self.cube.shape
        self.spin_bg_y0.setValue(max(0, min(self.spin_y0.value(), y)))
        self.spin_bg_y1.setValue(max(0, min(self.spin_y1.value(), y)))
        self.spin_bg_x0.setValue(max(0, min(self.spin_x0.value(), x)))
        self.spin_bg_x1.setValue(max(0, min(self.spin_x1.value(), x)))

    def _background_channel_range_from_energy(self) -> Tuple[int, int]:
        if self.cube is None:
            raise ValueError("No cube loaded")
        L = self.cube.shape[2]
        e_axis = self.axis_info.energy_axis
        if len(e_axis) == L:
            i0 = nearest_channel_from_energy(e_axis, self.spin_bg_e0.value())
            i1 = nearest_channel_from_energy(e_axis, self.spin_bg_e1.value())
            l0 = max(0, min(i0, i1))
            l1 = min(L, max(i0, i1) + 1)
        else:
            l0 = max(0, min(int(round(self.spin_bg_e0.value())), L - 1))
            l1 = min(L, max(l0 + 1, int(round(self.spin_bg_e1.value()))))
        if l1 <= l0:
            raise ValueError("Invalid background energy/channel range")
        return l0, l1

    def apply_background_correction(self):
        if self.cube is None:
            QMessageBox.warning(self, "No data", "Load data first.")
            return
        try:
            y, x, _ = self.cube.shape
            y0 = max(0, min(self.spin_bg_y0.value(), y))
            y1 = max(0, min(self.spin_bg_y1.value(), y))
            x0 = max(0, min(self.spin_bg_x0.value(), x))
            x1 = max(0, min(self.spin_bg_x1.value(), x))
            if y1 <= y0 or x1 <= x0:
                raise ValueError("Invalid background spatial ROI.")
            l0, l1 = self._background_channel_range_from_energy()
            fit = fit_powerlaw_exponent_from_roi(self.cube, self.axis_info, (y0, y1, x0, x1), (l0, l1))
            corrected = apply_powerlaw_background_correction(
                self.cube,
                self.axis_info,
                (l0, l1),
                exponent_r=fit["r"],
                clip_negative=self.chk_bg_clip.isChecked(),
                chunk_pixels=max(512, self.spin_chunk.value()),
            )
            self.cube = corrected.astype(np.float32, copy=False)
            self.conv_result = None
            self.rr_result = None
            self.rr_combined_sets = []
            self.lbl_bg_status.setText("Applied: r=%.4g, A(mean)=%.4g, RMSE=%.4g, n=%d" % (fit["r"], fit["A_mean"], fit["rmse"], fit["n_points"]))
            self.append_log("Background correction applied. r=%.6g, A_mean=%.6g, RMSE=%.6g, fit channels=%d:%d" % (fit["r"], fit["A_mean"], fit["rmse"], l0, l1))
            self.refresh_rr_component_list()
            self.refresh_raw_view()
        except Exception as e:
            QMessageBox.critical(self, "Background correction failed", str(e))
            self.append_log(traceback.format_exc())

    def reset_background_correction(self):
        if self.original_cube is None:
            QMessageBox.warning(self, "No original data", "Load data first.")
            return
        self.cube = self.original_cube.copy()
        self.conv_result = None
        self.rr_result = None
        self.rr_combined_sets = []
        self.lbl_bg_status.setText("Reset to original")
        self.append_log("Background correction reset to original loaded data.")
        self.refresh_rr_component_list()
        self.refresh_raw_view()

    def on_channel_roi_changed(self):
        if self._syncing_energy_channel:
            return
        self._syncing_energy_channel = True
        try:
            self.sync_energy_from_channel_roi()
            self.update_roi_label()
        finally:
            self._syncing_energy_channel = False

    def on_energy_roi_changed(self):
        if self._syncing_energy_channel:
            return
        self._syncing_energy_channel = True
        try:
            self.sync_channel_from_energy_roi()
            self.update_roi_label()
        finally:
            self._syncing_energy_channel = False

    def sync_energy_from_channel_roi(self):
        if self.cube is None:
            return
        e_axis = self.axis_info.energy_axis
        L = len(e_axis)
        if L == 0:
            return
        l0 = max(0, min(self.spin_l0.value(), L - 1))
        l1_exclusive = max(1, min(self.spin_l1.value(), L))
        l1_idx = max(0, min(l1_exclusive - 1, L - 1))
        self.spin_e0.blockSignals(True)
        self.spin_e1.blockSignals(True)
        self.spin_e0.setValue(float(e_axis[l0]))
        self.spin_e1.setValue(float(e_axis[l1_idx]))
        self.spin_e0.blockSignals(False)
        self.spin_e1.blockSignals(False)

    def sync_channel_from_energy_roi(self):
        if self.cube is None:
            return
        e_axis = self.axis_info.energy_axis
        L = len(e_axis)
        if L == 0:
            return
        idx0 = nearest_channel_from_energy(e_axis, self.spin_e0.value())
        idx1 = nearest_channel_from_energy(e_axis, self.spin_e1.value())
        lo = max(0, min(min(idx0, idx1), L - 1))
        hi = max(1, min(max(idx0, idx1) + 1, L))
        self.spin_l0.blockSignals(True)
        self.spin_l1.blockSignals(True)
        self.spin_l0.setValue(lo)
        self.spin_l1.setValue(hi)
        self.spin_l0.blockSignals(False)
        self.spin_l1.blockSignals(False)

    def update_roi_label(self):
        if self.cube is None:
            self.lbl_roi_shape.setText("ROI: -")
            return
        y, x, l = self.cube.shape
        y0, y1 = self.spin_y0.value(), self.spin_y1.value()
        x0, x1 = self.spin_x0.value(), self.spin_x1.value()
        l0, l1 = self.spin_l0.value(), self.spin_l1.value()
        y0, y1 = max(0, min(y0, y)), max(0, min(y1, y))
        x0, x1 = max(0, min(x0, x)), max(0, min(x1, x))
        l0, l1 = max(0, min(l0, l)), max(0, min(l1, l))
        if y1 <= y0 or x1 <= x0 or l1 <= l0:
            self.lbl_roi_shape.setText("Invalid ROI")
            return
        e_axis = self.axis_info.energy_axis
        if len(e_axis) == l:
            e_text = "%.4g ~ %.4g %s" % (float(e_axis[l0]), float(e_axis[l1 - 1]), self.axis_info.energy_unit)
        else:
            e_text = "channels %d ~ %d" % (l0, l1 - 1)
        self.lbl_roi_shape.setText("(%d, %d, %d) -> X=(%d, %d), E=%s" % (y1-y0, x1-x0, l1-l0, (y1-y0)*(x1-x0), l1-l0, e_text))

    def get_roi_cube_and_X(self) -> Tuple[np.ndarray, np.ndarray, Tuple[int, int], AxisInfo]:
        if self.cube is None:
            raise ValueError("No cube loaded")
        y, x, l = self.cube.shape
        y0, y1 = max(0, min(self.spin_y0.value(), y)), max(0, min(self.spin_y1.value(), y))
        x0, x1 = max(0, min(self.spin_x0.value(), x)), max(0, min(self.spin_x1.value(), x))
        l0, l1 = max(0, min(self.spin_l0.value(), l)), max(0, min(self.spin_l1.value(), l))
        if y1 <= y0 or x1 <= x0 or l1 <= l0:
            raise ValueError("Invalid ROI")
        roi = self.cube[y0:y1, x0:x1, l0:l1].astype(np.float32, copy=False)
        hh, ww, ll = roi.shape
        X = roi.reshape(hh * ww, ll)
        X = normalize_spectra(X, self.combo_norm.currentText())
        X = nonnegative(X, "clip")
        roi_axis = AxisInfo(
            energy_axis=self.axis_info.energy_axis[l0:l1].copy() if len(self.axis_info.energy_axis) == l else np.arange(ll, dtype=np.float32),
            energy_unit=self.axis_info.energy_unit,
            energy_label=self.axis_info.energy_label,
            x_scale=self.axis_info.x_scale,
            y_scale=self.axis_info.y_scale,
            spatial_unit=self.axis_info.spatial_unit,
            x_label=self.axis_info.x_label,
            y_label=self.axis_info.y_label,
        )
        return roi, X, (hh, ww), roi_axis

    def refresh_raw_view(self):
        if self.cube is None:
            self.canvas_raw.clear()
            return
        try:
            roi_cube, _, _, roi_axis = self.get_roi_cube_and_X()
            self.roi_cube = roi_cube
            self.roi_axis_info = roi_axis
            plot_raw_data(self.canvas_raw.fig, roi_cube, roi_axis, cmap=self.combo_cmap.currentText())
            self.canvas_raw.draw()
        except Exception:
            self.canvas_raw.clear()

    def collect_params(self) -> Dict[str, Any]:
        return {
            "run_conventional": self.chk_conv.isChecked(),
            "conv_components": self.spin_conv_k.value(),
            "run_rr": self.chk_rr.isChecked(),
            "rr_rank": self.spin_rr_rank.value(),
            "rr_depth": self.spin_rr_depth.value(),
            "residual_mode": self.combo_residual_mode.currentText(),
            "residual_nonnegative": self.combo_residual_nonnegative.currentText(),
            "decompose_residual_branch": self.chk_decompose_residual.isChecked(),
            "max_iter": self.spin_iter.value(),
            "init": self.combo_init.currentText(),
            "solver": self.combo_solver.currentText(),
            "random_state": self.spin_seed.value(),
            "chunk_size": self.spin_chunk.value(),
        }

    def run_analysis(self):
        try:
            roi_cube, X, shape, roi_axis = self.get_roi_cube_and_X()
        except Exception as e:
            QMessageBox.warning(self, "ROI/Data error", str(e))
            return
        self.roi_cube = roi_cube
        self.X = X
        self.image_shape = shape
        self.roi_axis_info = roi_axis
        self.rr_combined_sets = []
        self.btn_run.setEnabled(False)
        self.append_log("Starting analysis on ROI cube=%s, X=%s, image_shape=%s" % (roi_cube.shape, X.shape, shape))
        self.worker = AnalysisWorker(X, shape, self.collect_params())
        self.worker.finished_ok.connect(self.on_analysis_finished)
        self.worker.failed.connect(self.on_analysis_failed)
        self.worker.start()

    def on_analysis_finished(self, conv_result: Optional[ConventionalNMFResult], rr_result: Optional[RRNMFResult], logs: str):
        self.conv_result = conv_result
        self.rr_result = rr_result
        self.append_log(logs)
        self.btn_run.setEnabled(True)
        self.refresh_views()

    def on_analysis_failed(self, err: str):
        self.btn_run.setEnabled(True)
        QMessageBox.critical(self, "Analysis failed", err)
        self.append_log(err)

    def refresh_views(self):
        cmap = self.combo_cmap.currentText() if hasattr(self, "combo_cmap") else "viridis"
        if self.cube is not None:
            self.refresh_raw_view()
        else:
            self.canvas_raw.clear()
        if self.rr_result is not None:
            plot_rr_tree_enhanced(self.canvas_tree.fig, self.rr_result, self.roi_axis_info, cmap=cmap)
            self.canvas_tree.set_base_size(*self.canvas_tree.fig.get_size_inches())
            self.canvas_tree.draw()
        else:
            self.canvas_tree.clear()
        if self.conv_result is not None:
            plot_conventional_nmf_enhanced(self.canvas_conv.fig, self.conv_result, self.roi_axis_info, cmap=cmap, max_items=20)
            self.canvas_conv.set_base_size(*self.canvas_conv.fig.get_size_inches())
            self.canvas_conv.draw()
        else:
            self.canvas_conv.clear()
        plot_energy_summary(self.canvas_energy.fig, self.conv_result, self.rr_result)
        self.canvas_energy.set_base_size(*self.canvas_energy.fig.get_size_inches())
        self.canvas_energy.draw()
        self.refresh_tables()
        self.refresh_rr_component_list()

    def refresh_rr_component_list(self):
        if not hasattr(self, "list_rr_components"):
            return
        self.list_rr_components.clear()
        self.list_rr_combined.clear()
        self.rr_component_entries = collect_rr_component_entries(self.rr_result) if self.rr_result is not None else []
        for ent in self.rr_component_entries:
            self.list_rr_components.addItem(QListWidgetItem(ent["label"]))
        for i, combined in enumerate(self.rr_combined_sets):
            members = ", ".join(combined.get("members", []))
            self.list_rr_combined.addItem("%d: %s [%s]" % (i + 1, combined.get("name", "Combined"), members))

    def _selected_rr_entries(self) -> List[Dict[str, Any]]:
        selected_labels = [item.text() for item in self.list_rr_components.selectedItems()]
        return [ent for ent in self.rr_component_entries if ent["label"] in selected_labels]

    def preview_selected_rr_components(self):
        selected = self._selected_rr_entries()
        if not selected:
            QMessageBox.warning(self, "No selection", "Select one or more rr-NMF components first.")
            return
        try:
            name = self.edit_combined_name.text().strip() or "Preview %d component(s)" % len(selected)
            combined = build_combined_dataset(selected, name=name)
            plot_combined_dataset(self.canvas_rr_combined.fig, combined, self.roi_axis_info, cmap=self.combo_cmap.currentText())
            self.canvas_rr_combined.set_base_size(*self.canvas_rr_combined.fig.get_size_inches())
            self.canvas_rr_combined.draw()
        except Exception as e:
            QMessageBox.critical(self, "Preview failed", str(e))

    def create_combined_rr_set(self):
        selected = self._selected_rr_entries()
        if not selected:
            QMessageBox.warning(self, "No selection", "Select one or more rr-NMF components first.")
            return
        try:
            name = self.edit_combined_name.text().strip() or "Combined %d" % (len(self.rr_combined_sets) + 1)
            combined = build_combined_dataset(selected, name=name)
            self.rr_combined_sets.append(combined)
            self.refresh_rr_component_list()
            self.list_rr_combined.setCurrentRow(len(self.rr_combined_sets) - 1)
            self.append_log("Created combined set: %s from %s" % (name, ", ".join(combined["members"])))
        except Exception as e:
            QMessageBox.critical(self, "Create combined set failed", str(e))

    def preview_combined_rr_set(self, silent: bool = False):
        if not hasattr(self, "list_rr_combined"):
            return
        row = self.list_rr_combined.currentRow()
        if row < 0 or row >= len(self.rr_combined_sets):
            if not silent:
                QMessageBox.warning(self, "No selection", "Select a saved combined set first.")
            return
        combined = self.rr_combined_sets[row]
        plot_combined_dataset(self.canvas_rr_combined.fig, combined, self.roi_axis_info, cmap=self.combo_cmap.currentText())
        self.canvas_rr_combined.set_base_size(*self.canvas_rr_combined.fig.get_size_inches())
        self.canvas_rr_combined.draw()

    def remove_combined_rr_set(self):
        row = self.list_rr_combined.currentRow()
        if row < 0 or row >= len(self.rr_combined_sets):
            QMessageBox.warning(self, "No selection", "Select a saved combined set first.")
            return
        removed = self.rr_combined_sets.pop(row)
        self.refresh_rr_component_list()
        self.canvas_rr_combined.clear()
        self.append_log("Removed combined set: %s" % removed.get("name", "Combined"))

    def export_combined_rr_set(self):
        row = self.list_rr_combined.currentRow()
        if row < 0 or row >= len(self.rr_combined_sets):
            QMessageBox.warning(self, "No selection", "Select a saved combined set first.")
            return
        combined = self.rr_combined_sets[row]
        path, _ = QFileDialog.getSaveFileName(self, "Save combined dataset", "combined_rr_component_set.npz", "NPZ Files (*.npz);;All Files (*.*)")
        if not path:
            return
        try:
            if not path.lower().endswith(".npz"):
                path += ".npz"
            np.savez_compressed(
                path,
                matrix=combined["matrix"],
                image=combined["image"],
                spectrum=combined["spectrum"],
                members=np.array(combined["members"], dtype=object),
                name=np.array(combined["name"], dtype=object),
                energy_axis=self.roi_axis_info.energy_axis,
            )
            self.append_log("Exported combined dataset: %s" % path)
        except Exception as e:
            QMessageBox.critical(self, "Export failed", str(e))

    def dataframe_to_table(self, df: pd.DataFrame, table: QTableWidget, max_rows: int = 2000):
        if df is None or df.empty:
            table.clear(); table.setRowCount(0); table.setColumnCount(0); return
        df_show = df.head(max_rows).copy()
        table.setRowCount(len(df_show)); table.setColumnCount(len(df_show.columns))
        table.setHorizontalHeaderLabels([str(c) for c in df_show.columns])
        for r in range(len(df_show)):
            for c, col in enumerate(df_show.columns):
                val = df_show.iloc[r, c]
                txt = "%.6g" % val if isinstance(val, float) else str(val)
                table.setItem(r, c, QTableWidgetItem(txt))
        table.resizeColumnsToContents()

    def refresh_tables(self):
        dfs = []
        if self.conv_result is not None:
            dfs.append(self.conv_result.energy_records)
        if self.rr_result is not None:
            dfs.append(self.rr_result.energy_records)
        self.dataframe_to_table(pd.concat(dfs, ignore_index=True) if dfs else pd.DataFrame(), self.table_energy)
        self.dataframe_to_table(self.rr_result.node_records if self.rr_result is not None else pd.DataFrame(), self.table_nodes)

    def export_csv(self):
        if self.conv_result is None and self.rr_result is None:
            QMessageBox.warning(self, "No result", "Run analysis first.")
            return
        out_dir = QFileDialog.getExistingDirectory(self, "Select output directory")
        if not out_dir:
            return
        try:
            if self.conv_result is not None:
                self.conv_result.energy_records.to_csv(os.path.join(out_dir, "conventional_nmf_energy.csv"), index=False)
                pd.DataFrame(self.conv_result.h_corr).to_csv(os.path.join(out_dir, "conventional_H_corr.csv"), index=False)
                pd.DataFrame(self.conv_result.w_corr).to_csv(os.path.join(out_dir, "conventional_W_corr.csv"), index=False)
            if self.rr_result is not None:
                self.rr_result.energy_records.to_csv(os.path.join(out_dir, "rr_nmf_energy.csv"), index=False)
                self.rr_result.node_records.to_csv(os.path.join(out_dir, "rr_nmf_nodes.csv"), index=False)
            self.append_log("CSV exported to %s" % out_dir)
        except Exception as e:
            QMessageBox.critical(self, "Export failed", str(e))
            self.append_log(traceback.format_exc())


def main():
    app = QApplication(sys.argv)
    win = RR2NMFGui()
    win.show()
    sys.exit(app.exec_())


if __name__ == "__main__":
    main()
