def estimate_cube_from_array(arr: np.ndarray) -> Tuple[np.ndarray, Tuple[int, int, int]]:
    arr = np.asarray(arr)
    if arr.ndim == 3:
        return arr.astype(np.float32), arr.shape
    if arr.ndim == 2:
        N, L = arr.shape
        return arr.reshape(N, 1, L).astype(np.float32), (N, 1, L)
    raise ValueError("Unsupported array ndim=%s. Expected 2D or 3D." % (arr.ndim,))


def make_default_axis_info(cube_shape: Tuple[int, int, int]) -> AxisInfo:
    _, _, L = cube_shape
    return AxisInfo(energy_axis=np.arange(L, dtype=np.float32))


def try_extract_axis_info_from_signal(signal: Any, cube_shape: Tuple[int, int, int]) -> AxisInfo:
    axis_info = make_default_axis_info(cube_shape)
    try:
        am = signal.axes_manager
        axes = list(am._axes)
        if len(axes) >= 3:
            sizes = [int(getattr(ax, "size", 1)) for ax in axes]
            spec_idx = int(np.argmax(sizes)) if max(sizes) >= 128 else len(axes) - 1
            spec_ax = axes[spec_idx]
            L = cube_shape[2]
            scale = float(getattr(spec_ax, "scale", 1.0))
            offset = float(getattr(spec_ax, "offset", 0.0))
            unit = str(getattr(spec_ax, "units", "channel"))
            axis_info.energy_axis = np.arange(L, dtype=np.float32) * scale + offset
            axis_info.energy_unit = unit if unit not in ["", "None"] else "channel"
            axis_info.energy_label = "Energy (%s)" % axis_info.energy_unit if axis_info.energy_unit != "channel" else "Channel"
            spatial_axes = [ax for j, ax in enumerate(axes) if j != spec_idx]
            if len(spatial_axes) >= 2:
                ay, axx = spatial_axes[0], spatial_axes[1]
                axis_info.y_scale = float(getattr(ay, "scale", 1.0))
                axis_info.x_scale = float(getattr(axx, "scale", 1.0))
                unitx = str(getattr(axx, "units", "px"))
                unity = str(getattr(ay, "units", "px"))
                axis_info.spatial_unit = unitx if unitx not in ["", "None"] else (unity if unity not in ["", "None"] else "px")
                axis_info.x_label = str(getattr(axx, "name", "X")) or "X"
                axis_info.y_label = str(getattr(ay, "name", "Y")) or "Y"
    except Exception:
        pass
    return axis_info


def load_hyperspectral_file(path: str) -> Tuple[np.ndarray, Dict[str, Any], AxisInfo]:
    ext = os.path.splitext(path)[1].lower()
    meta: Dict[str, Any] = {"path": path, "extension": ext, "loader": None}

    if ext == ".npy":
        arr = np.load(path)
        cube, shape = estimate_cube_from_array(arr)
        meta.update({"loader": "numpy", "shape": shape})
        return cube, meta, make_default_axis_info(cube.shape)

    if ext == ".npz":
        z = np.load(path)
        keys = list(z.keys())
        if not keys:
            raise ValueError("NPZ file has no arrays.")
        key = keys[0]
        cube, shape = estimate_cube_from_array(z[key])
        meta.update({"loader": "numpy_npz", "npz_key": key, "shape": shape})
        return cube, meta, make_default_axis_info(cube.shape)

    try:
        import hyperspy.api as hs  # type: ignore
    except Exception as e:
        raise RuntimeError(
            "This file format requires HyperSpy/RosettaSciIO. Install: pip install hyperspy exspy rosettasciio. "
            "Original error: %s" % str(e)
        )

    try:
        sigs = hs.load(path, lazy=False)
    except TypeError:
        sigs = hs.load(path)
    if not isinstance(sigs, list):
        sigs = [sigs]

    candidates = []
    for idx, s in enumerate(sigs):
        try:
            candidates.append((idx, s, np.asarray(s.data)))
        except Exception:
            continue
    if not candidates:
        raise ValueError("No readable dataset found in file.")

    for idx, s, data in candidates:
        if data.ndim == 3:
            shape = data.shape
            spec_axis = int(np.argmax(shape)) if max(shape) >= 128 else 2
            cube = np.moveaxis(data, spec_axis, -1).astype(np.float32)
            axis_info = try_extract_axis_info_from_signal(s, cube.shape)
            meta.update({
                "loader": "hyperspy",
                "signal_index": idx,
                "original_shape": shape,
                "converted_shape": cube.shape,
                "spec_axis_guess": spec_axis,
                "signal_class": s.__class__.__name__,
            })
            return cube, meta, axis_info

    for idx, s, data in candidates:
        if data.ndim == 2:
            cube, shape = estimate_cube_from_array(data)
            meta.update({
                "loader": "hyperspy",
                "signal_index": idx,
                "original_shape": data.shape,
                "converted_shape": cube.shape,
                "signal_class": s.__class__.__name__,
            })
            return cube, meta, make_default_axis_info(cube.shape)

    raise ValueError("No supported 2D/3D spectral dataset found in file.")


def nearest_channel_from_energy(energy_axis: np.ndarray, value: float) -> int:
    energy_axis = np.asarray(energy_axis, dtype=np.float64)
    if energy_axis.size == 0:
        return 0
    return int(np.argmin(np.abs(energy_axis - float(value))))


# =============================================================================
# Background correction utilities
# =============================================================================

def safe_powerlaw_energy_axis(energy_axis: np.ndarray) -> np.ndarray:
    """Return a strictly positive energy axis for log-log power-law fitting."""
    e = np.asarray(energy_axis, dtype=np.float64).copy()
    if e.size == 0:
        return e
    finite = np.isfinite(e)
    if not np.any(finite):
        return np.arange(len(e), dtype=np.float64) + 1.0
    min_e = float(np.nanmin(e[finite]))
    if min_e <= 0:
        e = e - min_e + 1e-6
    e[e <= 0] = 1e-6
    return e


def fit_powerlaw_exponent_from_roi(
    cube: np.ndarray,
    axis_info: AxisInfo,
    spatial_roi: Tuple[int, int, int, int],
    channel_roi: Tuple[int, int],
) -> Dict[str, float]:
    """
    Fit a power-law background I(E)=A*E^(-r) from the mean spectrum in a selected ROI.
    The exponent r is estimated from the selected spatial ROI and fitting energy window.
    Later, each pixel gets its own amplitude A_p using the same r.
    """
    y0, y1, x0, x1 = spatial_roi
    l0, l1 = channel_roi
    sub = cube[y0:y1, x0:x1, l0:l1].astype(np.float64, copy=False)
    if sub.size == 0:
        raise ValueError("Background fitting ROI is empty.")

    spec = np.nanmean(sub.reshape(-1, sub.shape[-1]), axis=0)
    e_full = safe_powerlaw_energy_axis(axis_info.energy_axis)
    e = e_full[l0:l1]
    if len(e) != len(spec):
        e = np.arange(len(spec), dtype=np.float64) + 1.0

    mask = np.isfinite(e) & np.isfinite(spec) & (e > 0) & (spec > 0)
    if np.count_nonzero(mask) < 3:
        raise ValueError("Not enough positive finite points for power-law background fitting.")

    loge = np.log(e[mask])
    logy = np.log(spec[mask])
    slope, intercept = np.polyfit(loge, logy, 1)
    r = -float(slope)
    A = float(np.exp(intercept))
    fit = A * np.power(e[mask], -r)
    rmse = float(np.sqrt(np.mean((spec[mask] - fit) ** 2)))
    return {"A_mean": A, "r": r, "rmse": rmse, "n_points": int(np.count_nonzero(mask))}


def apply_powerlaw_background_correction(
    cube: np.ndarray,
    axis_info: AxisInfo,
    fit_channel_roi: Tuple[int, int],
    exponent_r: float,
    clip_negative: bool = True,
    chunk_pixels: int = 8192,
) -> np.ndarray:
    """
    Apply pixel-wise amplitude power-law background subtraction using fixed exponent r.

    For each pixel spectrum y_p(E), estimate A_p over the selected fit window:
        A_p = mean( y_p(E) * E^r )
    then subtract:
        B_p(E) = A_p * E^(-r)
    """
    h, w, L = cube.shape
    l0, l1 = fit_channel_roi
    if l1 <= l0:
        raise ValueError("Invalid background fit channel range.")

    e = safe_powerlaw_energy_axis(axis_info.energy_axis)
    if len(e) != L:
        e = np.arange(L, dtype=np.float64) + 1.0
    e = np.maximum(e, 1e-6)
    e_fit = e[l0:l1]
    basis_full = np.power(e, -float(exponent_r)).astype(np.float32)
    amp_basis_fit = np.power(e_fit, float(exponent_r)).astype(np.float32)

    X = cube.reshape(h * w, L).astype(np.float32, copy=False)
    out = np.empty_like(X, dtype=np.float32)
    for st in range(0, X.shape[0], chunk_pixels):
        en = min(st + chunk_pixels, X.shape[0])
        Xc = X[st:en]
        fit_slice = Xc[:, l0:l1]
        A = np.nanmean(fit_slice * amp_basis_fit.reshape(1, -1), axis=1).astype(np.float32)
        bg = A.reshape(-1, 1) * basis_full.reshape(1, -1)
        corr = Xc - bg
        if clip_negative:
            corr = np.clip(corr, 0, None)
        out[st:en] = corr.astype(np.float32)
    return out.reshape(h, w, L)


