class ControlledMplCanvas(FigureCanvas):
    def __init__(self, width=12, height=8, dpi=100):
        self.base_width = float(width); self.base_height = float(height); self.zoom_factor = 1.0; self.dpi_value = int(dpi)
        self.fig = Figure(figsize=(width, height), dpi=dpi)
        super().__init__(self.fig)
        self.setSizePolicy(QSizePolicy.Fixed, QSizePolicy.Fixed)
        self._apply_canvas_size()
    def _apply_canvas_size(self):
        w_in, h_in = self.fig.get_size_inches()
        self.setFixedSize(int(w_in * self.dpi_value), int(h_in * self.dpi_value))
    def draw(self, *args, **kwargs):
        self._apply_canvas_size(); super().draw(*args, **kwargs)
    def set_base_size(self, width, height):
        self.base_width = max(2.0, float(width)); self.base_height = max(2.0, float(height)); self.apply_zoom()
    def apply_zoom(self):
        self.zoom_factor = max(0.15, min(float(self.zoom_factor), 8.0)); self.fig.set_size_inches(self.base_width * self.zoom_factor, self.base_height * self.zoom_factor, forward=True); self._apply_canvas_size(); self.draw()
    def zoom_in(self): self.zoom_factor *= 1.25; self.apply_zoom()
    def zoom_out(self): self.zoom_factor /= 1.25; self.apply_zoom()
    def reset_zoom(self): self.zoom_factor = 1.0; self.apply_zoom()
    def fit_width(self, viewport_width): self.zoom_factor = (max(4.0, float(viewport_width) / float(self.dpi_value) - 0.2) / self.base_width); self.apply_zoom()
    def clear(self): self.fig.clear(); self.draw()


class PlotPanel(QWidget):
    def __init__(self, canvas: ControlledMplCanvas):
        super().__init__(); self.canvas = canvas
        self.scroll = QScrollArea(); self.scroll.setWidget(canvas); self.scroll.setWidgetResizable(False); self.scroll.setAlignment(Qt.AlignLeft | Qt.AlignTop)
        btns = [("Zoom +", canvas.zoom_in), ("Zoom -", canvas.zoom_out), ("Fit Width", lambda: canvas.fit_width(self.scroll.viewport().width())), ("Reset", canvas.reset_zoom), ("←", lambda: self.pan(-250, 0)), ("→", lambda: self.pan(250, 0)), ("↑", lambda: self.pan(0, -250)), ("↓", lambda: self.pan(0, 250))]
        toolbar = QHBoxLayout()
        for t, cb in btns:
            b = QPushButton(t); b.clicked.connect(cb); toolbar.addWidget(b)
        toolbar.addStretch(1)
        layout = QVBoxLayout(self); layout.addLayout(toolbar); layout.addWidget(self.scroll)
    def pan(self, dx, dy):
        self.scroll.horizontalScrollBar().setValue(self.scroll.horizontalScrollBar().value() + dx)
        self.scroll.verticalScrollBar().setValue(self.scroll.verticalScrollBar().value() + dy)


